# Tests
# ============================================================================

fn test_property():
    """Test Property"""
    let prop = Property("name", LogicalType.STRING, 1)
    assert_equal(prop.name, "name")
    assert_true(prop.data_type == LogicalType.STRING)
    assert_true(not prop.is_primary_key)
    
    let pk = Property.primary_key("id", LogicalType.INT64, 0)
    assert_true(pk.is_primary_key)
    assert_true(not pk.is_nullable)
    print("✓ Property tests passed")


fn test_table_schema():
    """Test TableSchema"""
    var schema = TableSchema("Person", 1, TableType.NODE)
    
    let id_prop = Property.primary_key("id", LogicalType.INT64, 0)
    schema.add_property(id_prop)
    
    let name_prop = Property("name", LogicalType.STRING, 1)
    schema.add_property(name_prop)
    
    assert_equal(schema.get_num_properties(), 2)
    assert_true(schema.is_node_table())
    
    let pk = schema.get_primary_key()
    assert_equal(pk.name, "id")
    print("✓ TableSchema tests passed")


fn test_catalog():
    """Test Catalog"""
    var catalog = Catalog("test_db")
    
    # Create node tables
    let person_id = catalog.create_node_table("Person")
    let company_id = catalog.create_node_table("Company")
    
    # Add properties
    _ = catalog.add_primary_key("Person", "id", LogicalType.INT64)
    _ = catalog.add_property("Person", "name", LogicalType.STRING)
    _ = catalog.add_property("Person", "age", LogicalType.INT32)
    
    # Create relationship
    _ = catalog.create_rel_table("WORKS_FOR", "Person", "Company")
    
    assert_equal(catalog.get_num_tables(), 3)
    assert_true(catalog.has_table("Person"))
    assert_true(catalog.has_table("WORKS_FOR"))
    
    let person_schema = catalog.get_table_schema("Person")
    assert_equal(person_schema.get_num_properties(), 3)
    print("✓ Catalog tests passed")


fn main():
    """Run all tests"""
    print("Running Mojo catalog module tests...")
    test_property()
    test_table_schema()
    test_catalog()
    print("All tests passed! ✓")