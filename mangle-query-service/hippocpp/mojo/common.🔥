@value
struct InternalID:
    """Internal node/edge ID"""
    var table_id: UInt64
    var offset: UInt64
    
    fn __init__(inout self, table_id: UInt64, offset: UInt64):
        self.table_id = table_id
        self.offset = offset
    
    @staticmethod
    fn invalid() -> InternalID:
        return InternalID(0, NULL_PAGE_IDX)
    
    fn is_valid(self) -> Bool:
        return self.offset != NULL_PAGE_IDX


@value
struct Value:
    """Runtime value representation"""
    var data_type: LogicalType
    var is_null: Bool
    var int_value: Int64
    var float_value: Float64
    var string_value: String
    
    fn __init__(inout self):
        self.data_type = LogicalType.NULL_TYPE
        self.is_null = True
        self.int_value = 0
        self.float_value = 0.0
        self.string_value = ""
    
    @staticmethod
    fn null_value() -> Value:
        return Value()
    
    @staticmethod
    fn boolean(val: Bool) -> Value:
        var v = Value()
        v.data_type = LogicalType.BOOL
        v.is_null = False
        v.int_value = 1 if val else 0
        return v
    
    @staticmethod
    fn integer(val: Int64) -> Value:
        var v = Value()
        v.data_type = LogicalType.INT64
        v.is_null = False
        v.int_value = val
        return v
    
    @staticmethod
    fn double(val: Float64) -> Value:
        var v = Value()
        v.data_type = LogicalType.DOUBLE
        v.is_null = False
        v.float_value = val
        return v
    
    @staticmethod
    fn from_string(val: String) -> Value:
        var v = Value()
        v.data_type = LogicalType.STRING
        v.is_null = False
        v.string_value = val
        return v
    
    fn to_bool(self) -> Bool:
        if self.is_null:
            return False
        return self.int_value != 0
    
    fn to_int(self) -> Int64:
        if self.is_null:
            return 0
        if self.data_type == LogicalType.DOUBLE:
            return Int64(self.float_value)
        return self.int_value
    
    fn to_float(self) -> Float64:
        if self.is_null:
            return 0.0
        if self.data_type.is_integer():
            return Float64(self.int_value)
        return self.float_value


