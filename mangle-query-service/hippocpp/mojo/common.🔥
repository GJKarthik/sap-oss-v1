# ============================================================================
# Logical Types
# ============================================================================

@value
struct LogicalType:
    """Database logical type enumeration"""
    var value: Int
    
    alias BOOL = LogicalType(0)
    alias INT8 = LogicalType(1)
    alias INT16 = LogicalType(2)
    alias INT32 = LogicalType(3)
    alias INT64 = LogicalType(4)
    alias UINT8 = LogicalType(5)
    alias UINT16 = LogicalType(6)
    alias UINT32 = LogicalType(7)
    alias UINT64 = LogicalType(8)
    alias FLOAT = LogicalType(9)
    alias DOUBLE = LogicalType(10)
    alias STRING = LogicalType(11)
    alias BLOB = LogicalType(12)
    alias DATE = LogicalType(13)
    alias TIMESTAMP = LogicalType(14)
    alias INTERVAL = LogicalType(15)
    alias LIST = LogicalType(16)
    alias MAP = LogicalType(17)
    alias STRUCT = LogicalType(18)
    alias NODE = LogicalType(19)
    alias REL = LogicalType(20)
    alias INTERNAL_ID = LogicalType(21)
    alias ANY = LogicalType(22)
    alias NULL_TYPE = LogicalType(23)
    
    fn __init__(inout self, value: Int):
        self.value = value
    
    fn __eq__(self, other: LogicalType) -> Bool:
        return self.value == other.value
    
    fn __ne__(self, other: LogicalType) -> Bool:
        return self.value != other.value
    
    fn is_numeric(self) -> Bool:
        """Check if type is numeric"""
        return (self.value >= LogicalType.INT8.value and 
                self.value <= LogicalType.DOUBLE.value)
    
    fn is_integer(self) -> Bool:
        """Check if type is integer"""
        return (self.value >= LogicalType.INT8.value and 
                self.value <= LogicalType.UINT64.value)
    
    fn get_size(self) -> Int:
        """Get size in bytes for fixed-size types"""
        if self == LogicalType.BOOL:
            return 1
        elif self == LogicalType.INT8 or self == LogicalType.UINT8:
            return 1
        elif self == LogicalType.INT16 or self == LogicalType.UINT16:
            return 2
        elif self == LogicalType.INT32 or self == LogicalType.UINT32:
            return 4
        elif self == LogicalType.INT64 or self == LogicalType.UINT64:
            return 8
        elif self == LogicalType.FLOAT:
            return 4
        elif self == LogicalType.DOUBLE:
            return 8
        elif self == LogicalType.DATE:
            return 4
        elif self == LogicalType.TIMESTAMP:
            return 8
        elif self == LogicalType.INTERNAL_ID:
            return 8
        else:
            return 0  # Variable size


