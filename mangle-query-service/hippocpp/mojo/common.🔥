fn test_logical_type():
    """Test LogicalType"""
    let int_type = LogicalType.INT64
    assert_true(int_type.is_numeric())
    assert_true(int_type.is_integer())
    assert_equal(int_type.get_size(), 8)
    
    let string_type = LogicalType.STRING
    assert_true(not string_type.is_numeric())
    assert_equal(string_type.get_size(), 0)
    print("✓ LogicalType tests passed")


fn test_value():
    """Test Value"""
    let null_val = Value.null_value()
    assert_true(null_val.is_null)
    
    let int_val = Value.integer(42)
    assert_true(not int_val.is_null)
    assert_equal(int_val.to_int(), 42)
    
    let bool_val = Value.boolean(True)
    assert_true(bool_val.to_bool())
    print("✓ Value tests passed")


fn test_internal_id():
    """Test InternalID"""
    let id = InternalID(1, 100)
    assert_true(id.is_valid())
    assert_equal(id.table_id, 1)
    assert_equal(id.offset, 100)
    
    let invalid = InternalID.invalid()
    assert_true(not invalid.is_valid())
    print("✓ InternalID tests passed")


fn test_utilities():
    """Test utility functions"""
    assert_equal(align_up(100, 64), 128)
    assert_equal(align_up(64, 64), 64)
    assert_true(is_power_of_two(64))
    assert_true(not is_power_of_two(100))
    print("✓ Utility tests passed")


fn main():
    """Run all tests"""
    print("Running Mojo common module tests...")
    test_logical_type()
    test_value()
    test_internal_id()
    test_utilities()
    print("All tests passed! ✓")