{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "lib": ["ES2020"]
  },
  "include": ["cds-plugin.ts", "src/**/*.ts", "srv/**/*.ts", "lib/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "tests", "coverage", "dist"]
}
