{
  "$schema": "https://aicore.sap.com/schemas/serving-config.json",
  "name": "ai-core-streaming-openai",
  "description": "OpenAI-compatible API server with smart routing for SAP AI Core",
  "version": "1.0.0",
  
  "scenario": {
    "id": "ai-core-streaming-openai",
    "name": "AI Core Streaming OpenAI API",
    "description": "OpenAI-compatible inference API with governance-based routing"
  },
  
  "executable": {
    "id": "ai-core-streaming-openai-exec",
    "name": "OpenAI API Server",
    "description": "FastAPI server exposing OpenAI-compatible endpoints",
    "deployable": true
  },
  
  "serving": {
    "minReplicas": 1,
    "maxReplicas": 10,
    "resourcePlan": "infer.s",
    "timeout": 300
  },
  
  "parameters": {
    "AI_CORE_RESOURCE_GROUP": {
      "type": "string",
      "default": "default",
      "description": "Resource group for model deployments"
    },
    "VLLM_URL": {
      "type": "string",
      "default": "",
      "description": "Optional vLLM endpoint for confidential data routing"
    },
    "LOG_LEVEL": {
      "type": "string",
      "default": "INFO",
      "enum": ["DEBUG", "INFO", "WARNING", "ERROR"]
    }
  },
  
  "endpoints": {
    "/v1/chat/completions": {
      "method": "POST",
      "description": "OpenAI-compatible chat completion",
      "streaming": true
    },
    "/v1/completions": {
      "method": "POST", 
      "description": "OpenAI-compatible text completion (legacy)",
      "streaming": true
    },
    "/v1/embeddings": {
      "method": "POST",
      "description": "OpenAI-compatible embeddings generation"
    },
    "/v1/models": {
      "method": "GET",
      "description": "List available models"
    },
    "/health": {
      "method": "GET",
      "description": "KServe health check"
    }
  },
  
  "models": {
    "supported": [
      {
        "id": "gpt-4",
        "backend": "ai-core",
        "description": "GPT-4 via AI Core"
      },
      {
        "id": "gpt-4-turbo",
        "backend": "ai-core",
        "description": "GPT-4 Turbo via AI Core"
      },
      {
        "id": "gpt-3.5-turbo",
        "backend": "ai-core",
        "description": "GPT-3.5 Turbo via AI Core"
      },
      {
        "id": "claude-3-sonnet",
        "backend": "ai-core",
        "description": "Claude 3 Sonnet via AI Core"
      },
      {
        "id": "claude-3-opus",
        "backend": "ai-core",
        "description": "Claude 3 Opus via AI Core"
      },
      {
        "id": "text-embedding-ada-002",
        "backend": "ai-core",
        "description": "OpenAI text embeddings via AI Core"
      },
      {
        "id": "llama-3.1-70b",
        "backend": "vllm",
        "description": "Llama 3.1 70B via vLLM (confidential)"
      },
      {
        "id": "llama-3.1-8b",
        "backend": "vllm",
        "description": "Llama 3.1 8B via vLLM (confidential)"
      }
    ]
  },
  
  "routing": {
    "description": "Smart routing based on security classification and content",
    "rules": [
      {
        "name": "security-confidential",
        "condition": "X-Mesh-Security-Class == 'confidential'",
        "backend": "vllm"
      },
      {
        "name": "security-restricted",
        "condition": "X-Mesh-Security-Class == 'restricted'",
        "backend": "vllm"
      },
      {
        "name": "content-confidential",
        "condition": "content contains confidential keywords",
        "backend": "vllm"
      },
      {
        "name": "default",
        "condition": "always",
        "backend": "ai-core"
      }
    ]
  },
  
  "docker": {
    "registry": "docker.io/sap",
    "image": "ai-core-streaming-openai",
    "tag": "latest",
    "buildContext": "../..",
    "dockerfile": "deploy/aicore/Dockerfile"
  }
}