# SAP HANA Cloud Credentials
# Copy this file to .env and fill in your credentials

# HANA Cloud Connection
HANA_HOST=your-instance.hana.prod-us10.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-secure-password

# Optional: Schema to use (will create if not exists)
HANA_SCHEMA=VECTOR_TEST

# Test Configuration
TEST_TABLE_PREFIX=TEST_