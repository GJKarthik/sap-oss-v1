{
  "name": "@sap-ai-sdk/elasticsearch",
  "version": "0.1.0",
  "description": "Elasticsearch vector store integration for SAP AI SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0"
  },
  "peerDependencies": {
    "@sap-ai-sdk/core": "^2.0.0",
    "@sap-ai-sdk/orchestration": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@sap-ai-sdk/orchestration": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "elasticsearch",
    "vector-store",
    "embeddings",
    "rag",
    "ai",
    "sap"
  ],
  "author": "SAP AI SDK Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SAP/ai-sdk-js.git",
    "directory": "packages/elasticsearch"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}