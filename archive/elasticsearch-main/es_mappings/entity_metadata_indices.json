{
  "indices": {
    "entity_registry": {
      "mappings": {
        "properties": {
          "entity_name": {"type": "keyword"},
          "hana_view": {"type": "keyword"},
          "hana_schema": {"type": "keyword"},
          "table_name": {"type": "keyword"},
          "description": {"type": "text"},
          "namespace": {"type": "keyword"},
          "odata_namespace": {"type": "keyword"},
          "is_analytical": {"type": "boolean"},
          "source": {"type": "keyword"},
          "last_updated": {"type": "date"}
        }
      }
    },
    "entity_dimensions": {
      "mappings": {
        "properties": {
          "entity_name": {"type": "keyword"},
          "dimension_name": {"type": "keyword"},
          "dimension_type": {"type": "keyword"},
          "label": {"type": "text"},
          "description": {"type": "text"},
          "data_type": {"type": "keyword"},
          "is_key": {"type": "boolean"},
          "sort_order": {"type": "integer"}
        }
      }
    },
    "entity_measures": {
      "mappings": {
        "properties": {
          "entity_name": {"type": "keyword"},
          "measure_name": {"type": "keyword"},
          "aggregation_type": {"type": "keyword"},
          "label": {"type": "text"},
          "description": {"type": "text"},
          "unit": {"type": "keyword"},
          "data_type": {"type": "keyword"},
          "formula": {"type": "text"}
        }
      }
    },
    "entity_hierarchies": {
      "mappings": {
        "properties": {
          "entity_name": {"type": "keyword"},
          "hierarchy_name": {"type": "keyword"},
          "node_column": {"type": "keyword"},
          "parent_column": {"type": "keyword"},
          "level_column": {"type": "keyword"},
          "description": {"type": "text"},
          "max_depth": {"type": "integer"}
        }
      }
    },
    "entity_gdpr": {
      "mappings": {
        "properties": {
          "entity_name": {"type": "keyword"},
          "field_name": {"type": "keyword"},
          "sensitivity": {"type": "keyword"},
          "data_subject_role": {"type": "keyword"},
          "purpose": {"type": "text"},
          "retention_days": {"type": "integer"},
          "requires_consent": {"type": "boolean"}
        }
      }
    }
  },
  "setup_script": "#!/bin/bash\n# Create indices for entity metadata\nES_URL=${ELASTICSEARCH_URL:-http://localhost:9200}\n\nfor index in entity_registry entity_dimensions entity_measures entity_hierarchies entity_gdpr; do\n  curl -X PUT \"$ES_URL/$index\" -H 'Content-Type: application/json' -d @- << EOF\n  $(jq \".indices.$index\" entity_metadata_indices.json)\nEOF\ndone"
}