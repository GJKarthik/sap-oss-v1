{
  "$schema": "https://help.sap.com/docs/ai-core/api/deployment-configuration-schema",
  "_comment": "SAP BTP AI Core Deployment Configuration for LLM Server with T4 GPU",
  
  "configurations": {
    "llm-server-t4-standard": {
      "name": "llm-server-t4-standard",
      "scenarioId": "ainuc-llm-inference",
      "executableId": "llm-server",
      "parameters": {
        "dockerImage": "${DOCKER_REGISTRY}/ainuc-llm-server:latest",
        "resourcePlan": "gpu_nvidia_t4",
        "modelFile": "phi-2.Q4_K_M.gguf",
        "contextSize": "4096",
        "parallelRequests": "4",
        "minReplicas": "1",
        "maxReplicas": "4",
        "mangleEnabled": "true"
      },
      "inputArtifacts": {
        "llm-model": "${MODEL_ARTIFACT_ID}"
      }
    },
    
    "llm-server-t4-highperf": {
      "name": "llm-server-t4-highperf",
      "scenarioId": "ainuc-llm-inference",
      "executableId": "llm-server",
      "parameters": {
        "dockerImage": "${DOCKER_REGISTRY}/ainuc-llm-server:latest",
        "resourcePlan": "gpu_nvidia_t4",
        "modelFile": "mistral-7b-instruct-q8_0.gguf",
        "contextSize": "8192",
        "parallelRequests": "8",
        "minReplicas": "2",
        "maxReplicas": "8",
        "mangleEnabled": "true"
      },
      "inputArtifacts": {
        "llm-model": "${MODEL_ARTIFACT_ID}"
      }
    },
    
    "llm-server-cpu-dev": {
      "name": "llm-server-cpu-dev",
      "scenarioId": "ainuc-llm-inference",
      "executableId": "llm-server",
      "parameters": {
        "dockerImage": "${DOCKER_REGISTRY}/ainuc-llm-server:latest",
        "resourcePlan": "infer.s",
        "modelFile": "phi-2.Q4_K_M.gguf",
        "contextSize": "2048",
        "parallelRequests": "2",
        "minReplicas": "1",
        "maxReplicas": "2",
        "mangleEnabled": "true"
      },
      "inputArtifacts": {
        "llm-model": "${MODEL_ARTIFACT_ID}"
      }
    }
  },
  
  "artifacts": {
    "phi2-model": {
      "name": "phi-2-q4km",
      "kind": "model",
      "description": "Microsoft Phi-2 Q4_K_M quantized model",
      "url": "ai://default/llm-models/phi-2.Q4_K_M.gguf",
      "labels": {
        "model.family": "phi",
        "model.size": "2.7B",
        "model.quantization": "Q4_K_M"
      }
    },
    "mistral-7b-model": {
      "name": "mistral-7b-instruct-q8",
      "kind": "model",
      "description": "Mistral 7B Instruct Q8_0 quantized model",
      "url": "ai://default/llm-models/mistral-7b-instruct-q8_0.gguf",
      "labels": {
        "model.family": "mistral",
        "model.size": "7B",
        "model.quantization": "Q8_0"
      }
    }
  },
  
  "resourcePlans": {
    "_comment": "Available AI Core resource plans for reference",
    "cpu": {
      "infer.s": {
        "cpu": "1",
        "memory": "2Gi",
        "description": "Small CPU instance"
      },
      "infer.m": {
        "cpu": "2",
        "memory": "4Gi",
        "description": "Medium CPU instance"
      },
      "infer.l": {
        "cpu": "4",
        "memory": "8Gi",
        "description": "Large CPU instance"
      }
    },
    "gpu": {
      "gpu_nvidia_t4": {
        "gpu": "1 x T4",
        "memory": "16Gi VRAM",
        "cpu": "4",
        "description": "NVIDIA Tesla T4 (Turing) - Best for inference"
      },
      "gpu_nvidia_v100": {
        "gpu": "1 x V100",
        "memory": "32Gi VRAM",
        "cpu": "8",
        "description": "NVIDIA Tesla V100 - High performance"
      },
      "gpu_nvidia_a10g": {
        "gpu": "1 x A10G",
        "memory": "24Gi VRAM",
        "cpu": "4",
        "description": "NVIDIA A10G (Ampere) - Balanced"
      }
    }
  },
  
  "scaling": {
    "_comment": "Scaling recommendations by model size",
    "small_model_3b": {
      "resourcePlan": "gpu_nvidia_t4",
      "minReplicas": 1,
      "maxReplicas": 8,
      "parallelRequests": 8,
      "contextSize": 8192,
      "estimatedThroughput": "150 tok/s per replica"
    },
    "medium_model_7b": {
      "resourcePlan": "gpu_nvidia_t4",
      "minReplicas": 2,
      "maxReplicas": 8,
      "parallelRequests": 4,
      "contextSize": 4096,
      "estimatedThroughput": "100 tok/s per replica"
    },
    "large_model_13b": {
      "resourcePlan": "gpu_nvidia_t4",
      "minReplicas": 2,
      "maxReplicas": 4,
      "parallelRequests": 2,
      "contextSize": 2048,
      "estimatedThroughput": "50 tok/s per replica",
      "notes": "Requires Q8_0 or lower quantization"
    }
  },
  
  "apiExamples": {
    "createConfiguration": {
      "method": "POST",
      "url": "/v2/lm/configurations",
      "body": {
        "name": "llm-server-t4-standard",
        "scenarioId": "ainuc-llm-inference",
        "executableId": "llm-server",
        "parameterBindings": [
          {"key": "dockerImage", "value": "your-registry/ainuc-llm-server:latest"},
          {"key": "resourcePlan", "value": "gpu_nvidia_t4"},
          {"key": "modelFile", "value": "phi-2.Q4_K_M.gguf"},
          {"key": "contextSize", "value": "4096"},
          {"key": "parallelRequests", "value": "4"},
          {"key": "minReplicas", "value": "1"},
          {"key": "maxReplicas", "value": "4"}
        ],
        "inputArtifactBindings": [
          {"key": "llm-model", "artifactId": "your-model-artifact-id"}
        ]
      }
    },
    "createDeployment": {
      "method": "POST",
      "url": "/v2/lm/deployments",
      "body": {
        "configurationId": "your-configuration-id"
      }
    },
    "getDeploymentUrl": {
      "method": "GET",
      "url": "/v2/lm/deployments/{deploymentId}",
      "response": {
        "deploymentUrl": "https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2/inference/deployments/{deploymentId}"
      }
    },
    "invokeInference": {
      "method": "POST",
      "url": "{deploymentUrl}/v1/chat/completions",
      "headers": {
        "Authorization": "Bearer {ai-core-token}",
        "AI-Resource-Group": "default",
        "Content-Type": "application/json"
      },
      "body": {
        "model": "phi-2",
        "messages": [
          {"role": "user", "content": "Hello, how are you?"}
        ],
        "max_tokens": 100
      }
    }
  }
}