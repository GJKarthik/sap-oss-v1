# =============================================================================
# SAP OSS Suite Root Environment
# Copy to .env for production-style docker compose at the repo root.
# =============================================================================

# -----------------------------------------------------------------------------
# SAP HANA Cloud
# -----------------------------------------------------------------------------
HANA_HOST=your-hana-instance.hanacloud.ondemand.com
HANA_PORT=443
HANA_SCHEMA=PAL_STORE
HANA_ENCRYPT=true
HANA_USER_FILE_SOURCE=./.secrets.example/hana_user
HANA_PASSWORD_FILE_SOURCE=./.secrets.example/hana_password

# -----------------------------------------------------------------------------
# SAP AI Core
# -----------------------------------------------------------------------------
AICORE_AUTH_URL=https://your-auth-url/oauth/token
AICORE_BASE_URL=https://your-ai-core-base-url
AICORE_RESOURCE_GROUP=default
AICORE_CLIENT_ID_FILE_SOURCE=./.secrets.example/aicore_client_id
AICORE_CLIENT_SECRET_FILE_SOURCE=./.secrets.example/aicore_client_secret
