regulatory_framework("MGF-Agentic-AI", "SAP Model Governance Framework - Agentic AI", "enforced").

framework_dimension("MGF-Agentic-AI", "accountability").
framework_dimension("MGF-Agentic-AI", "transparency").
framework_dimension("MGF-Agentic-AI", "safety").

framework_review_reason("MGF-Agentic-AI", "accountability", "mgf-human-oversight").
framework_review_reason("MGF-Agentic-AI", "transparency", "mgf-auditability").
framework_review_reason("MGF-Agentic-AI", "safety", "mgf-risk-control").

framework_action("MGF-Agentic-AI", "impact_assessment", "transparency").
framework_action("MGF-Agentic-AI", "strategic_recommendation", "accountability").
framework_action("MGF-Agentic-AI", "model_fine_tune", "safety").