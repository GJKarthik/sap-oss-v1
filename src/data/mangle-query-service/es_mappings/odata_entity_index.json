{
  "settings": {
    "index": {
      "number_of_shards": 3,
      "number_of_replicas": 1,
      "refresh_interval": "5s",
      "analysis": {
        "analyzer": {
          "odata_text_analyzer": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase", "asciifolding", "snowball"]
          },
          "entity_id_analyzer": {
            "type": "custom",
            "tokenizer": "keyword",
            "filter": ["uppercase"]
          }
        },
        "normalizer": {
          "keyword_lowercase": {
            "type": "custom",
            "filter": ["lowercase"]
          }
        }
      }
    }
  },
  "mappings": {
    "_meta": {
      "version": "2.0.0",
      "description": "OData Entity Index with Full Vocabulary Semantics - Phase 2",
      "odata_vocabulary_version": "2024-11-05",
      "created_at": "2026-02-26",
      "features": [
        "odata_metadata",
        "common_annotations",
        "analytics_annotations",
        "personal_data_tracking",
        "hana_cloud_integration",
        "vector_embeddings"
      ]
    },
    "properties": {
      "entity_type": {
        "type": "keyword",
        "doc_values": true,
        "_meta": {
          "description": "OData EntityType name",
          "vocabulary_term": "Common.SAPObjectNodeType"
        }
      },
      "entity_namespace": {
        "type": "keyword",
        "_meta": {
          "description": "OData namespace containing the entity type"
        }
      },
      "entity_set": {
        "type": "keyword",
        "_meta": {
          "description": "OData EntitySet name"
        }
      },
      "hana_key": {
        "type": "keyword",
        "_meta": {
          "description": "Primary key value from HANA source"
        }
      },

      "odata_metadata": {
        "type": "object",
        "properties": {
          "namespace": {
            "type": "keyword",
            "_meta": {
              "description": "Full OData namespace"
            }
          },
          "entity_set": {
            "type": "keyword",
            "_meta": {
              "description": "EntitySet name for URL construction"
            }
          },
          "key_properties": {
            "type": "keyword",
            "_meta": {
              "description": "List of key property names"
            }
          },
          "key_values": {
            "type": "object",
            "dynamic": true,
            "_meta": {
              "description": "Key property name-value pairs"
            }
          },
          "is_analytical": {
            "type": "boolean",
            "_meta": {
              "description": "True if entity supports Analytics annotations",
              "vocabulary_term": "Analytics.AggregatedProperties"
            }
          },
          "has_hierarchy": {
            "type": "boolean",
            "_meta": {
              "description": "True if entity has recursive hierarchy",
              "vocabulary_term": "Hierarchy.RecursiveHierarchy"
            }
          },
          "has_draft": {
            "type": "boolean",
            "_meta": {
              "description": "True if entity supports drafts",
              "vocabulary_term": "Common.DraftRoot"
            }
          },
          "etag": {
            "type": "keyword",
            "_meta": {
              "description": "Entity version for optimistic locking"
            }
          },
          "media_type": {
            "type": "keyword",
            "_meta": {
              "description": "MIME type for media entities"
            }
          }
        }
      },

      "common_annotations": {
        "type": "object",
        "_meta": {
          "description": "Common vocabulary annotations",
          "vocabulary": "com.sap.vocabularies.Common.v1"
        },
        "properties": {
          "label": {
            "type": "text",
            "analyzer": "odata_text_analyzer",
            "fields": {
              "keyword": {
                "type": "keyword"
              }
            },
            "_meta": {
              "vocabulary_term": "Common.Label"
            }
          },
          "heading": {
            "type": "text",
            "_meta": {
              "vocabulary_term": "Common.Heading"
            }
          },
          "quick_info": {
            "type": "text",
            "_meta": {
              "vocabulary_term": "Common.QuickInfo"
            }
          },
          "description": {
            "type": "text",
            "analyzer": "odata_text_analyzer",
            "_meta": {
              "vocabulary_term": "Core.Description"
            }
          },
          "semantic_object": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "Common.SemanticObject"
            }
          },
          "semantic_key": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "Common.SemanticKey"
            }
          },
          "text_properties": {
            "type": "object",
            "dynamic": true,
            "_meta": {
              "description": "Property -> Text mappings",
              "vocabulary_term": "Common.Text"
            }
          },
          "value_list_references": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "Common.ValueList"
            }
          }
        }
      },

      "analytics_annotations": {
        "type": "object",
        "_meta": {
          "description": "Analytics vocabulary annotations",
          "vocabulary": "com.sap.vocabularies.Analytics.v1"
        },
        "properties": {
          "dimensions": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "Analytics.Dimension"
            }
          },
          "measures": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "Analytics.Measure"
            }
          },
          "aggregation_methods": {
            "type": "object",
            "dynamic": true,
            "_meta": {
              "description": "Measure -> Aggregation method mapping"
            }
          },
          "hierarchy_qualifier": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "Aggregation.RecursiveHierarchy"
            }
          },
          "rollup_node": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "Analytics.RollupNode"
            }
          }
        }
      },

      "ui_annotations": {
        "type": "object",
        "_meta": {
          "description": "UI vocabulary annotations",
          "vocabulary": "com.sap.vocabularies.UI.v1"
        },
        "properties": {
          "header_info": {
            "type": "object",
            "properties": {
              "type_name": {"type": "keyword"},
              "type_name_plural": {"type": "keyword"},
              "title_property": {"type": "keyword"},
              "description_property": {"type": "keyword"},
              "image_url_property": {"type": "keyword"}
            },
            "_meta": {
              "vocabulary_term": "UI.HeaderInfo"
            }
          },
          "line_item_properties": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "UI.LineItem"
            }
          },
          "selection_fields": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "UI.SelectionFields"
            }
          },
          "identification_properties": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "UI.Identification"
            }
          },
          "chart_type": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "UI.Chart"
            }
          }
        }
      },

      "personal_data": {
        "type": "object",
        "_meta": {
          "description": "PersonalData vocabulary annotations for GDPR",
          "vocabulary": "com.sap.vocabularies.PersonalData.v1"
        },
        "properties": {
          "is_data_subject": {
            "type": "boolean",
            "_meta": {
              "vocabulary_term": "PersonalData.EntitySemantics"
            }
          },
          "data_subject_role": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "PersonalData.DataSubjectRole"
            }
          },
          "data_subject_role_description": {
            "type": "text"
          },
          "potentially_personal_fields": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "PersonalData.IsPotentiallyPersonal"
            }
          },
          "potentially_sensitive_fields": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "PersonalData.IsPotentiallySensitive"
            }
          },
          "field_semantics": {
            "type": "object",
            "dynamic": true,
            "_meta": {
              "description": "Field -> FieldSemantics enum mapping",
              "vocabulary_term": "PersonalData.FieldSemantics"
            }
          }
        }
      },

      "hana_metadata": {
        "type": "object",
        "_meta": {
          "description": "HANA Cloud specific metadata",
          "vocabulary": "com.sap.vocabularies.HANACloud.v1"
        },
        "properties": {
          "schema": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "HANACloud.CalculationView.SchemaName"
            }
          },
          "table_or_view": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "HANACloud.CalculationView.ViewName"
            }
          },
          "calculation_view": {
            "type": "keyword"
          },
          "view_type": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "HANACloud.ViewTypeEnum"
            }
          },
          "is_analytical": {
            "type": "boolean",
            "_meta": {
              "vocabulary_term": "HANACloud.CalculationView.IsAnalytical"
            }
          },
          "supports_hierarchies": {
            "type": "boolean",
            "_meta": {
              "vocabulary_term": "HANACloud.CalculationView.SupportsHierarchies"
            }
          },
          "input_parameters": {
            "type": "nested",
            "properties": {
              "name": {"type": "keyword"},
              "data_type": {"type": "keyword"},
              "mandatory": {"type": "boolean"},
              "default_value": {"type": "keyword"}
            },
            "_meta": {
              "vocabulary_term": "HANACloud.InputParameters"
            }
          },
          "delta_tracking": {
            "type": "object",
            "properties": {
              "method": {"type": "keyword"},
              "timestamp_column": {"type": "keyword"},
              "change_type_column": {"type": "keyword"}
            },
            "_meta": {
              "vocabulary_term": "HANACloud.DeltaTracking"
            }
          },
          "column_mappings": {
            "type": "object",
            "dynamic": true,
            "_meta": {
              "description": "OData property -> HANA column mapping",
              "vocabulary_term": "HANACloud.ColumnMapping"
            }
          }
        }
      },

      "data_integration": {
        "type": "object",
        "_meta": {
          "description": "DataIntegration vocabulary annotations",
          "vocabulary": "com.sap.vocabularies.DataIntegration.v1"
        },
        "properties": {
          "source_system": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "DataIntegration.OriginalDataType"
            }
          },
          "original_type": {
            "type": "keyword"
          },
          "conversion_exit": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "DataIntegration.ConversionExit"
            }
          },
          "delta_method": {
            "type": "keyword",
            "_meta": {
              "vocabulary_term": "DataIntegration.DeltaMethod"
            }
          }
        }
      },

      "fields": {
        "type": "object",
        "dynamic": true,
        "_meta": {
          "description": "Dynamic entity properties from OData"
        }
      },

      "display_text": {
        "type": "text",
        "analyzer": "odata_text_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        },
        "_meta": {
          "description": "Human-readable display text derived from Common.Text"
        }
      },

      "display_text_embedding": {
        "type": "dense_vector",
        "dims": 1536,
        "index": true,
        "similarity": "cosine",
        "_meta": {
          "description": "Vector embedding of display_text for semantic search",
          "model": "text-embedding-3-small"
        }
      },

      "searchable_content": {
        "type": "text",
        "analyzer": "odata_text_analyzer",
        "_meta": {
          "description": "Combined searchable content from all text fields"
        }
      },

      "last_synced_at": {
        "type": "date",
        "format": "strict_date_optional_time||epoch_millis",
        "_meta": {
          "description": "Last successful sync from HANA"
        }
      },

      "hana_changed_at": {
        "type": "date",
        "format": "strict_date_optional_time||epoch_millis",
        "_meta": {
          "description": "Last modification timestamp from HANA",
          "vocabulary_term": "Common.ChangedAt"
        }
      },

      "hana_created_at": {
        "type": "date",
        "format": "strict_date_optional_time||epoch_millis",
        "_meta": {
          "vocabulary_term": "Common.CreatedAt"
        }
      },

      "hana_changed_by": {
        "type": "keyword",
        "_meta": {
          "vocabulary_term": "Common.ChangedBy"
        }
      },

      "hana_created_by": {
        "type": "keyword",
        "_meta": {
          "vocabulary_term": "Common.CreatedBy"
        }
      },

      "sync_status": {
        "type": "keyword",
        "_meta": {
          "description": "Current sync status (synced, pending, error)"
        }
      },

      "sync_error": {
        "type": "text",
        "_meta": {
          "description": "Last sync error message if any"
        }
      }
    }
  }
}