#! Purpose:
#! Represents expression trees for query evaluation.
#! Supports literals, columns, functions, comparisons, conjunctions.

from collections import Dict, List
from common import LogicalType, Value

# ============================================================================
# Expression Types
# ============================================================================

@value
struct ExpressionType:
    """Expression type enumeration"""
    var value: Int
    
    alias LITERAL = ExpressionType(0)
    alias COLUMN = ExpressionType(1)
    alias PARAMETER = ExpressionType(2)
    alias FUNCTION = ExpressionType(3)
    alias AGGREGATE = ExpressionType(4)
    alias CASE = ExpressionType(5)
    alias CAST = ExpressionType(6)
    alias COMPARISON = ExpressionType(7)
    alias CONJUNCTION = ExpressionType(8)
    alias DISJUNCTION = ExpressionType(9)
    alias NEGATION = ExpressionType(10)
    alias PROPERTY = ExpressionType(11)
    alias SUBQUERY = ExpressionType(12)
    alias PATTERN = ExpressionType(13)
    alias PATH = ExpressionType(14)
    alias STAR = ExpressionType(15)
    alias NULL_LITERAL = ExpressionType(16)
    
    fn __init__(inout self, value: Int):
        self.value = value
    
    fn __eq__(self, other: ExpressionType) -> Bool:
        return self.value == other.value


# ============================================================================
# Comparison Operations
# ============================================================================

@value
struct ComparisonType:
    """Comparison operation type"""
    var value: Int
    
    alias EQUAL = ComparisonType(0)
    alias NOT_EQUAL = ComparisonType(1)
    alias LESS_THAN = ComparisonType(2)
    alias LESS_THAN_OR_EQUAL = ComparisonType(3)
    alias GREATER_THAN = ComparisonType(4)
    alias GREATER_THAN_OR_EQUAL = ComparisonType(5)
    alias IS_NULL = ComparisonType(6)
    alias IS_NOT_NULL = ComparisonType(7)
    alias LIKE = ComparisonType(8)
    alias NOT_LIKE = ComparisonType(9)
    alias IN = ComparisonType(10)
    alias NOT_IN = ComparisonType(11)
    
    fn __init__(inout self, value: Int):
        self.value = value
    
    fn get_symbol(self) -> String:
        """Get the operator symbol"""
        if self.value == 0:
            return "="
        elif self.value == 1:
            return "<>"
        elif self.value == 2:
            return "<"
        elif self.value == 3:
            return "<="
        elif self.value == 4:
            return ">"
        elif self.value == 5:
            return ">="
        elif self.value == 6:
            return "IS NULL"
        elif self.value == 7:
            return "IS NOT NULL"
        elif self.value == 8:
            return "LIKE"
        elif self.value == 9:
            return "NOT LIKE"
        elif self.value == 10:
            return "IN"
        elif self.value == 11:
            return "NOT IN"
        return "?"


# ============================================================================
# Aggregate Functions
# ============================================================================

@value
struct AggregateType:
    """Aggregate function type"""
    var value: Int
    
    alias COUNT = AggregateType(0)
    alias SUM = AggregateType(1)
    alias AVG = AggregateType(2)
    alias MIN = AggregateType(3)
    alias MAX = AggregateType(4)
    alias COUNT_STAR = AggregateType(5)
    alias COLLECT = AggregateType(6)
    alias STD_DEV = AggregateType(7)
    alias VARIANCE = AggregateType(8)
    
    fn __init__(inout self, value: Int):
        self.value = value
    
    fn get_name(self) -> String:
        """Get function name"""
        if self.value == 0:
            return "COUNT"
        elif self.value == 1:
            return "SUM"
        elif self.value == 2:
            return "AVG"
        elif self.value == 3:
            return "MIN"
        elif self.value == 4:
            return "MAX"
        elif self.value == 5:
            return "COUNT(*)"
        elif self.value == 6:
            return "COLLECT"
        elif self.value == 7:
            return "STDDEV"
        elif self.value == 8:
            return "VARIANCE"
        return "UNKNOWN"


# ============================================================================
# Expression
# ============================================================================

struct Expression:
    """Expression tree node"""
    var expr_type: ExpressionType
    var data_type: LogicalType
    var alias_name: String
    var children: List[Expression]
    
    # Literal value
    var literal_value: Value
    
    # Column reference
    var table_name: String
    var column_name: String
    
    # Function call
    var function_name: String
    
    # Comparison
    var comparison_type: ComparisonType
    
    # Aggregate
    var aggregate_type: AggregateType
    var is_distinct: Bool
    
    fn __init__(inout self, expr_type: ExpressionType, data_type: LogicalType):
        self.expr_type = expr_type
        self.data_type = data_type
        self.alias_name = ""
        self.children = List[Expression]()
        self.literal_value = Value()
        self.table_name = ""
        self.column_name = ""
        self.function_name = ""
        self.comparison_type = ComparisonType.EQUAL
        self.aggregate_type = AggregateType.COUNT
        self.is_distinct = False
    
    fn add_child(inout self, child: Expression):
        """Add child expression"""
        self.children.append(child)
    
    fn get_num_children(self) -> Int:
        """Get number of children"""
        return len(self.children)
    
    fn has_alias(self) -> Bool:
        """Check if expression has alias"""
        return len(self.alias_name) > 0
    
    fn is_literal(self) -> Bool:
        return self.expr_type == ExpressionType.LITERAL
    
    fn is_column(self) -> Bool:
        return self.expr_type == ExpressionType.COLUMN
    
    fn is_function(self) -> Bool:
        return self.expr_type == ExpressionType.FUNCTION
    
    fn is_aggregate(self) -> Bool:
        return self.expr_type == ExpressionType.AGGREGATE
    
    fn is_comparison(self) -> Bool:
        return self.expr_type == ExpressionType.COMPARISON


# ============================================================================
# Expression Factory
# ============================================================================

struct ExpressionFactory:
    """Factory for creating expressions"""
    
    fn __init__(inout self):
        pass
    
    @staticmethod
    fn literal_null() -> Expression:
        """Create NULL literal"""
        var expr = Expression(ExpressionType.NULL_LITERAL, LogicalType.NULL_TYPE)
        expr.literal_value = Value.null_value()
        return expr
    
    @staticmethod
    fn literal_bool(val: Bool) -> Expression:
        """Create boolean literal"""
        var expr = Expression(ExpressionType.LITERAL, LogicalType.BOOL)
        expr.literal_value = Value.boolean(val)
        return expr
    
    @staticmethod
    fn literal_int(val: Int64) -> Expression:
        """Create integer literal"""
        var expr = Expression(ExpressionType.LITERAL, LogicalType.INT64)
        expr.literal_value = Value.integer(val)
        return expr
    
    @staticmethod
    fn literal_double(val: Float64) -> Expression:
        """Create double literal"""
        var expr = Expression(ExpressionType.LITERAL, LogicalType.DOUBLE)
        expr.literal_value = Value.double(val)
        return expr
    
    @staticmethod
    fn literal_string(val: String) -> Expression:
        """Create string literal"""
        var expr = Expression(ExpressionType.LITERAL, LogicalType.STRING)
        expr.literal_value = Value.from_string(val)
        return expr
    
    @staticmethod
    fn column_ref(table: String, column: String, dtype: LogicalType) -> Expression:
        """Create column reference"""
        var expr = Expression(ExpressionType.COLUMN, dtype)
        expr.table_name = table
        expr.column_name = column
        return expr
    
    @staticmethod
    fn function_call(name: String, return_type: LogicalType) -> Expression:
        """Create function call (add children separately)"""
        var expr = Expression(ExpressionType.FUNCTION, return_type)
        expr.function_name = name
        return expr
    
    @staticmethod
    fn comparison(comp_type: ComparisonType, left: Expression, right: Expression) -> Expression:
        """Create comparison expression"""
        var expr = Expression(ExpressionType.COMPARISON, LogicalType.BOOL)
        expr.comparison_type = comp_type
        expr.children.append(left)
        expr.children.append(right)
        return expr
    
    @staticmethod
    fn conjunction(children: List[Expression]) -> Expression:
        """Create AND expression"""
        var expr = Expression(ExpressionType.CONJUNCTION, LogicalType.BOOL)
        for child in children:
            expr.children.append(child[])
        return expr
    
    @staticmethod
    fn disjunction(children: List[Expression]) -> Expression:
        """Create OR expression"""
        var expr = Expression(ExpressionType.DISJUNCTION, LogicalType.BOOL)
        for child in children:
            expr.children.append(child[])
        return expr
    
    @staticmethod
    fn negation(child: Expression) -> Expression:
        """Create NOT expression"""
        var expr = Expression(ExpressionType.NEGATION, LogicalType.BOOL)
        expr.children.append(child)
        return expr
    
    @staticmethod
    fn aggregate(agg_type: AggregateType, child: Expression, distinct: Bool = False) -> Expression:
        """Create aggregate expression"""
        var expr = Expression(ExpressionType.AGGREGATE, LogicalType.INT64)
        expr.aggregate_type = agg_type
        expr.is_distinct = distinct
        expr.children.append(child)
        return expr
    
    @staticmethod
    fn count_star() -> Expression:
        """Create COUNT(*) expression"""
        var expr = Expression(ExpressionType.AGGREGATE, LogicalType.INT64)
        expr.aggregate_type = AggregateType.COUNT_STAR
        return expr
    
    @staticmethod
    fn star() -> Expression:
        """Create * (all columns) expression"""
        return Expression(ExpressionType.STAR, LogicalType.ANY)


# ============================================================================
# Tests
# ============================================================================

fn test_expression_types():
    """Test ExpressionType"""
    let lit = ExpressionType.LITERAL
    let col = ExpressionType.COLUMN
    assert_true(lit != col)
    print("✓ ExpressionType tests passed")


fn test_comparison_type():
    """Test ComparisonType"""
    let eq = ComparisonType.EQUAL
    assert_equal(eq.get_symbol(), "=")
    
    let gt = ComparisonType.GREATER_THAN
    assert_equal(gt.get_symbol(), ">")
    print("✓ ComparisonType tests passed")


fn test_aggregate_type():
    """Test AggregateType"""
    let sum_agg = AggregateType.SUM
    assert_equal(sum_agg.get_name(), "SUM")
    
    let count_star = AggregateType.COUNT_STAR
    assert_equal(count_star.get_name(), "COUNT(*)")
    print("✓ AggregateType tests passed")


fn test_expression_factory():
    """Test ExpressionFactory"""
    # Literal expressions
    let int_lit = ExpressionFactory.literal_int(42)
    assert_true(int_lit.is_literal())
    assert_equal(int_lit.literal_value.to_int(), 42)
    
    let str_lit = ExpressionFactory.literal_string("hello")
    assert_true(str_lit.is_literal())
    
    # Column reference
    let col = ExpressionFactory.column_ref("Person", "name", LogicalType.STRING)
    assert_true(col.is_column())
    assert_equal(col.table_name, "Person")
    assert_equal(col.column_name, "name")
    
    # Comparison
    let left = ExpressionFactory.column_ref("", "age", LogicalType.INT32)
    let right = ExpressionFactory.literal_int(18)
    let comp = ExpressionFactory.comparison(ComparisonType.GREATER_THAN, left, right)
    assert_true(comp.is_comparison())
    assert_equal(comp.get_num_children(), 2)
    
    # Aggregate
    let sum_expr = ExpressionFactory.aggregate(
        AggregateType.SUM,
        ExpressionFactory.column_ref("", "salary", LogicalType.DOUBLE)
    )
    assert_true(sum_expr.is_aggregate())
    
    print("✓ ExpressionFactory tests passed")


fn main():
    """Run all tests"""
    print("Running Mojo expression module tests...")
    test_expression_types()
    test_comparison_type()
    test_aggregate_type()
    test_expression_factory()
    print("All tests passed! ✓")