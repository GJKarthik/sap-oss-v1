# ========================================
# Mangle Query Service Configuration
# ========================================
# Copy this file to .env and customize values
# DO NOT commit .env to version control
#
# IMPORTANT: All LLM access goes through SAP AI Core or private vLLM
# NO direct external API access (OpenAI, Anthropic, etc.)

# ========================================
# Environment
# ========================================
# development, staging, production, test
MANGLE_ENV=development
SERVICE_NAME=mangle-query-service
SERVICE_VERSION=1.0.0

# ========================================
# Server Configuration
# ========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
REQUEST_TIMEOUT=60.0

# ========================================
# Elasticsearch Configuration
# ========================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=mangle
# Authentication (choose one method)
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=
# TLS Configuration
ELASTICSEARCH_CA_CERT=
ELASTICSEARCH_TIMEOUT=30.0
ELASTICSEARCH_MAX_RETRIES=3
ELASTICSEARCH_POOL_SIZE=10

# ========================================
# SAP HANA Cloud Configuration
# ========================================
HANA_HOST=
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_SCHEMA=
HANA_ENCRYPT=true
HANA_SSL_TRUST_STORE=
HANA_POOL_SIZE=5
HANA_STATEMENT_TIMEOUT=300

# ========================================
# LLM Backend Configuration
# ========================================
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120.0
LLM_RETRY_COUNT=2

# ========================================
# SAP AI Core Configuration (PRIMARY - Required for LLM access)
# ========================================
# All model access goes through AI Core - no direct external APIs
AICORE_BASE_URL=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com
AICORE_CLIENT_ID=your-client-id
AICORE_CLIENT_SECRET=your-client-secret
AICORE_TOKEN_URL=https://your-subdomain.authentication.us10.hana.ondemand.com/oauth/token
AICORE_DEPLOYMENT_ID=
AICORE_RESOURCE_GROUP=default
AICORE_TIMEOUT=120.0

# ========================================
# Private vLLM Configuration (Optional - for self-hosted models)
# ========================================
VLLM_BASE_URL=http://vllm.internal:8000/v1
VLLM_API_KEY=

# ========================================
# Caching Configuration
# ========================================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_ENTRIES=10000
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95

# ========================================
# Resilience Configuration
# ========================================
# Retry settings
RETRY_ENABLED=true
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=8.0

# Circuit breaker settings
CIRCUIT_BREAKER_ENABLED=true
CB_FAILURE_THRESHOLD=5
CB_SUCCESS_THRESHOLD=2
CB_RECOVERY_TIMEOUT=30.0

# Timeout settings
DEFAULT_TIMEOUT=30.0

# ========================================
# Security Configuration
# ========================================
API_KEY_HEADER=X-API-Key
# Comma-separated list of valid API keys
API_KEYS=
# JWT Configuration
JWT_ENABLED=false
JWT_SECRET=
JWT_ALGORITHM=HS256
# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ========================================
# Observability Configuration
# ========================================
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=false
TRACING_ENDPOINT=
LOG_FORMAT=json
# Warning: Enable only for debugging
LOG_REQUEST_BODY=false
LOG_RESPONSE_BODY=false