# Elastic Cloud Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Cloud Configuration
# =============================================================================

# Elastic Cloud ID (from Elastic Cloud console)
# Format: deployment-name:base64-encoded-cloud-config
ELASTIC_CLOUD_ID=my-deployment:dXMtY2VudHJhbDEuZ2NwLmNsb3VkLmVzLmlvOjQ0MyQzNmQyZjY5...

# API Key (recommended for production)
# Create via Kibana: Stack Management > API Keys
ELASTIC_API_KEY=your-api-key-here

# =============================================================================
# ALTERNATIVE: Username/Password Authentication
# =============================================================================

# Username (usually 'elastic')
# ELASTIC_USERNAME=elastic

# Password (from deployment creation or reset)
# ELASTIC_PASSWORD=your-password-here

# =============================================================================
# Optional: Index Configuration
# =============================================================================

# Index name for the vector store
INDEX_NAME=knowledge-base

# Embedding dimension (default: 1536 for OpenAI ada-002)
EMBEDDING_DIMENSION=1536

# Similarity metric: cosine, dot_product, or l2_norm
SIMILARITY=cosine

# =============================================================================
# Optional: Embedding API Configuration
# =============================================================================

# OpenAI API Key for embeddings (if using OpenAI)
# OPENAI_API_KEY=sk-...

# Or use custom embedding endpoint
# EMBEDDING_API_URL=https://your-embedding-api.com/embed

# =============================================================================
# Optional: Advanced Settings
# =============================================================================

# Request timeout in milliseconds
# REQUEST_TIMEOUT=30000

# Maximum retries for failed requests
# MAX_RETRIES=3

# Enable debug logging
# DEBUG=true