{
  "name": "mcp-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/mcp-client/src",
  "tags": ["type:lib", "scope:data", "runtime:browser"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "yarn workspace @sap-ai-fabric/mcp-client build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/mcp-client/**/*.ts", "packages/mcp-client/**/*.tsx"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn workspace @sap-ai-fabric/mcp-client typecheck"
      }
    }
  }
}
