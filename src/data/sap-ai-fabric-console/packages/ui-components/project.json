{
  "name": "ui-components",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/ui-components/src",
  "tags": ["type:lib", "framework:react", "scope:frontend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "yarn workspace @sap-ai-fabric/ui-components build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/ui-components/**/*.ts", "packages/ui-components/**/*.tsx"]
      }
    }
  }
}
