# SAP AI Fabric Console — API Server
# Copy to .env and fill in your credentials.

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-hex-string
STORE_BACKEND=sqlite
# Used when STORE_BACKEND=sqlite
STORE_DATABASE_PATH=./.data/sap-ai-fabric-console.sqlite3
EXPOSE_API_DOCS=
AUTH_RATE_LIMIT_PER_MINUTE=10
MCP_RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60

# ── SAP AI Core ───────────────────────────────────────────────────────────────
AICORE_CLIENT_ID=
AICORE_CLIENT_SECRET=
AICORE_AUTH_URL=https://<tenant>.authentication.<region>.hana.ondemand.com/oauth/token
AICORE_BASE_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com/v2
AICORE_RESOURCE_GROUP=default

# ── HANA Cloud Vector Engine ──────────────────────────────────────────────────
HANA_HOST=<instance>.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_ENCRYPT=true
# Used when STORE_BACKEND=hana
HANA_STORE_SCHEMA=
HANA_STORE_TABLE_PREFIX=SAP_AIFABRIC

# ── MCP Service Endpoints (optional — set if running the MCP servers) ─────────
LANGCHAIN_MCP_URL=http://localhost:9140/mcp
STREAMING_MCP_URL=http://localhost:9190/mcp

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@sap-ai-fabric.local
