# Docker Compose / production-style deployment
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

JWT_SECRET_KEY=
STORE_BACKEND=hana
SEED_REFERENCE_DATA=false
EXPOSE_API_DOCS=false
REQUIRE_MCP_DEPENDENCIES=true
MCP_HEALTHCHECK_TIMEOUT_SECONDS=5
ALERT_WINDOW_SECONDS=300
AUTH_FAILURE_ALERT_THRESHOLD=5
MCP_FAILURE_ALERT_THRESHOLD=3
READINESS_FAILURE_ALERT_THRESHOLD=1

AUTH_RATE_LIMIT_PER_MINUTE=10
MCP_RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60

BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@sap-ai-fabric.local

HANA_HOST=
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_ENCRYPT=true
HANA_STORE_SCHEMA=
HANA_STORE_TABLE_PREFIX=SAP_AIFABRIC

AICORE_CLIENT_ID=
AICORE_CLIENT_SECRET=
AICORE_AUTH_URL=
AICORE_BASE_URL=
AICORE_RESOURCE_GROUP=default

LANGCHAIN_MCP_URL=
STREAMING_MCP_URL=
DATA_CLEANING_MCP_URL=

SAP_API_BASE_URL=/api/v1
SAP_API_UPSTREAM=http://api:8000
SAP_LANGCHAIN_MCP_URL=
SAP_STREAMING_MCP_URL=
SAP_DATA_CLEANING_MCP_URL=
