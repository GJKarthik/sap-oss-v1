{
  "name": "shell",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/shell/src",
  "tags": ["type:app", "framework:react", "scope:frontend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "yarn workspace @sap-ai-fabric/shell build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn workspace @sap-ai-fabric/shell dev"
      },
      "continuous": true
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/shell/**/*.ts", "apps/shell/**/*.tsx"]
      }
    }
  }
}
