# SAP AI Fabric Console Environment Configuration

# MCP Endpoints (Backend services from src/data)
VITE_LANGCHAIN_MCP_URL=http://localhost:9140/mcp
VITE_STREAMING_MCP_URL=http://localhost:9190/mcp

# Optional: MCP Authentication Token
# Set this if your MCP servers require authentication
VITE_MCP_AUTH_TOKEN=

# HANA Cloud Connection (for direct HANA operations)
VITE_HANA_HOST=
VITE_HANA_PORT=443
VITE_HANA_USER=
VITE_HANA_PASSWORD=

# AI Core Configuration
VITE_AICORE_BASE_URL=
VITE_AICORE_RESOURCE_GROUP=default

# Feature Flags
VITE_ENABLE_RAG=true
VITE_ENABLE_STREAMING=true
VITE_ENABLE_KUZU_GRAPH=true