# =============================================================================
# OData Vocabularies Universal Dictionary - Production Configuration
# =============================================================================
# Copy this file to .env and configure for your environment

# =============================================================================
# Server Configuration
# =============================================================================
MCP_PORT=9150
MCP_HOST=0.0.0.0
LOG_LEVEL=INFO
CORS_ENABLED=true
CORS_ORIGINS=*

# SSL/TLS (optional, for HTTPS)
SSL_ENABLED=false
SSL_CERT_FILE=/path/to/cert.pem
SSL_KEY_FILE=/path/to/key.pem

# Server scaling
SERVER_WORKERS=4
MAX_REQUEST_SIZE=10485760

# =============================================================================
# SAP HANA Cloud Configuration
# =============================================================================
# Required for HANA integration features

HANA_HOST=your-hana-instance.hana.cloud.sap
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-secure-password
HANA_SCHEMA=MY_SCHEMA
HANA_ENCRYPT=true
HANA_SSL_VALIDATE=true
HANA_TIMEOUT=30

# =============================================================================
# HANA Vector Store Configuration
# =============================================================================
# Uses the same HANA Cloud instance for vector search (REAL_VECTOR columns)

# Override schema for vector tables (defaults to HANA_SCHEMA above)
# HANA_VECTOR_SCHEMA=MY_SCHEMA
HANA_VECTOR_TABLE_PREFIX=ODATA
# HANA_VECTOR_EMBEDDING_DIM=1536

# =============================================================================
# OpenAI Configuration
# =============================================================================
# Required for generating real embeddings

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
OPENAI_MAX_TOKENS=8191
OPENAI_BATCH_SIZE=100
OPENAI_TIMEOUT=60

# =============================================================================
# Authentication Configuration
# =============================================================================
# Enable for production security

# Enable authentication (set to true for production)
AUTH_ENABLED=false

# API Keys (comma-separated list)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=your-api-key-1,your-api-key-2

# JWT Configuration
# Generate secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# OAuth 2.0 (optional, for enterprise SSO)
OAUTH_PROVIDER=azure
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_TOKEN_URL=https://login.microsoftonline.com/your-tenant/oauth2/v2.0/token

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# Audit Configuration
# =============================================================================
# GDPR compliance and access logging

AUDIT_ENABLED=true
AUDIT_LOG_DIR=_audit_logs
AUDIT_MAX_ENTRIES=10000
AUDIT_FLUSH_INTERVAL=60
AUDIT_RETENTION_DAYS=90

# Centralized logging (optional)
AUDIT_SYSLOG_ENABLED=false
AUDIT_SYSLOG_HOST=syslog.example.com
AUDIT_SYSLOG_PORT=514
AUDIT_SYSLOG_FACILITY=local0

# HANA audit table (optional)
AUDIT_HANA_ENABLED=false
AUDIT_HANA_TABLE=ODATA_AUDIT

# =============================================================================
# Path Configuration
# =============================================================================
# Override default paths if needed

# VOCABULARIES_DIR=/custom/path/to/vocabularies
# EMBEDDINGS_DIR=/custom/path/to/embeddings
# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable specific features

FEATURE_SEMANTIC_SEARCH=true
FEATURE_RAG_CONTEXT=true
FEATURE_PERSONAL_DATA_CLASSIFIER=true
FEATURE_CDS_GENERATOR=true
FEATURE_GRAPHQL_GENERATOR=true
FEATURE_HANA_INTEGRATION=true
