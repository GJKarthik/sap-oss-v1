# =============================================================================
# SAP BTP Integration Test Environment
# =============================================================================
# Copy this file to .env and fill in your credentials from BTP service keys
# Never commit .env - it is listed in .gitignore

# =============================================================================
# 1. SAP HANA Cloud
# =============================================================================
# Get from: BTP Cockpit → HANA Cloud → Service Key
HANA_HOST=<your-hana-host>.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=<your-hana-user>
HANA_PASSWORD=<your-hana-password>
HANA_DATABASE=<your-hana-database>
HANA_ENCRYPT=true

# =============================================================================
# 2. SAP AI Core
# =============================================================================
# Get from: BTP Cockpit → AI Core → Service Key
AICORE_CLIENT_ID=<your-client-id>
AICORE_CLIENT_SECRET=<your-client-secret>
AICORE_AUTH_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
AICORE_BASE_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=default

# Deployment IDs (create deployments in AI Launchpad)
# Set to xxx to skip if no embedding model is deployed
AICORE_EMBEDDING_DEPLOYMENT_ID=xxx
AICORE_CHAT_DEPLOYMENT_ID=<your-chat-deployment-id>

# =============================================================================
# 3. BTP Object Store (S3-compatible)
# =============================================================================
# Get from: BTP Cockpit → Object Store → Service Key
OBJECT_STORE_ACCESS_KEY=<your-access-key>
OBJECT_STORE_SECRET_KEY=<your-secret-key>
OBJECT_STORE_BUCKET=<your-bucket>
OBJECT_STORE_ENDPOINT=https://s3.<region>.amazonaws.com
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_URI=s3://<access-key>:<secret-key>@s3.amazonaws.com/<bucket>
OBJECT_STORE_USERNAME=<your-object-store-username>

# =============================================================================
# 4. Elasticsearch Connection
# =============================================================================
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=<your-es-password>
# Use API key instead of username/password if available
ES_API_KEY=
ES_INDEX_PREFIX=sap_openai
ES_VECTOR_DIMS=768

# =============================================================================
# 5. MCP Server Authentication
# =============================================================================
# Set XSUAA_VERIFY_TOKEN=false ONLY in local development.
# In production leave it unset (defaults to true).
XSUAA_VERIFY_TOKEN=true

# Option A: static API key (simpler, suitable for service-to-service)
# Callers must send:  Authorization: ApiKey <value>
MCP_API_KEY=<generate-a-strong-random-secret>

# Option B: XSUAA JWT validation (recommended for user-facing deployments)
# Set to the PEM-encoded RSA public key from your XSUAA service key.
# Leave empty to skip JWT signature verification (token still parsed for existence).
XSUAA_PUBLIC_KEY=

# CORS origins allowed to call the MCP server (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# 6. Graph-RAG (KùzuDB)
# =============================================================================
# Path to the KùzuDB database directory for persistent graph storage.
# Default is :memory: (in-process, wiped on container restart).
# Set to a persistent volume path in production, e.g. /data/kuzu
KUZU_DB_PATH=/data/kuzu

# =============================================================================
# 7. MCP Server Limits
# =============================================================================
MCP_MAX_REQUEST_BYTES=1048576
MCP_MAX_SEARCH_SIZE=100
MCP_MAX_KNN_K=50

# =============================================================================
# Test Configuration
# =============================================================================
TEST_PREFIX=TEST_
TEST_HANA=true
TEST_AICORE=true
TEST_OBJECTSTORE=true
