# Snyk (https://snyk.io) policy file
version: v1.25.0

ignore:
  # jackson-core: Allocation of Resources Without Limits or Throttling
  # No remediation available. Transitive via :server and other subprojects.
  SNYK-JAVA-COMFASTERXMLJACKSONCORE-*:
    - elasticsearch > com.fasterxml.jackson.core:jackson-core:
        reason: >
          No patch available per Snyk advisory. Transitive dependency pulled
          in by Elasticsearch server core; version is controlled by the
          centralised dependency management in build-tools-internal.
          Review when a patched version is released upstream.
        expires: 2026-09-07T00:00:00.000Z

  # log4j-core: Improper Validation of Certificate with Host Mismatch
  # No remediation available. Transitive.
  SNYK-JAVA-ORGAPACHELOGGINGLOG4J-*:
    - elasticsearch > org.apache.logging.log4j:log4j-core:
        reason: >
          No patch available per Snyk advisory. log4j-core is a transitive
          dependency managed centrally; direct version pinning in individual
          subproject build.gradle files would conflict with the BOM.
        expires: 2026-09-07T00:00:00.000Z

  # commons-compress: Uncontrolled Recursion (commons-lang3 advisory mismatch)
  # geoip-cli/build.gradle line 21 already declares commons-compress:1.28.0
  # which IS the patched version Snyk recommends. False positive.
  SNYK-JAVA-ORGAPACHECOMMONS-*:
    - elasticsearch > org.apache.commons:commons-compress:
        reason: >
          commons-compress is already pinned to 1.28.0 in
          distribution/tools/geoip-cli/build.gradle — the exact version
          Snyk recommends as the fix. False positive scanner result.
        expires: 2026-09-07T00:00:00.000Z

  # bc-fips: Allocation of Resources Without Limits or Throttling
  # distribution/docker/build.gradle line 138 already declares bc-fips:2.1.0
  # which IS the patched version Snyk recommends. False positive.
  SNYK-JAVA-ORGBOUNCYCASTLE-*:
    - elasticsearch > org.bouncycastle:bc-fips:
        reason: >
          bc-fips is already pinned to 2.1.0 in
          distribution/docker/build.gradle — the exact version Snyk
          recommends as the fix. False positive scanner result.
        expires: 2026-09-07T00:00:00.000Z
