# Dockerfile for SAP Elasticsearch + Mangle Query Service (merged)
# Includes: MCP Server, OpenAI Server, Agent, Go Mangle gRPC Engine
#
# Build: docker build -f Dockerfile.sap -t sap-elasticsearch:latest .
# Run:   docker run -p 9120:9120 -p 9201:9201 -p 8080:8080 sap-elasticsearch:latest

# ---------------------------------------------------------------------------
# Go build stage: compile the Mangle gRPC engine
# ---------------------------------------------------------------------------
FROM golang:1.24-bookworm AS go-builder

WORKDIR /go/src/app

# Copy Go module files and vendor directory first for layer caching
COPY go.mod go.sum ./
COPY vendor/ vendor/

# Copy Go source
COPY cmd/ cmd/
COPY internal/ internal/
COPY api/ api/

RUN go build -mod=vendor -o /mangle-engine ./cmd/server/main.go

# ---------------------------------------------------------------------------
# Python base image
# ---------------------------------------------------------------------------
FROM python:3.11-slim AS base

# Set labels for SBOM and governance
LABEL org.opencontainers.image.title="SAP Elasticsearch Integration"
LABEL org.opencontainers.image.description="MCP Server and OpenAI-compatible API for Elasticsearch"
LABEL org.opencontainers.image.version="1.0.0"
LABEL org.opencontainers.image.vendor="SAP"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.source="https://github.com/SAP/elasticsearch-main"
LABEL ai.sap.component.type="mcp-server"
LABEL ai.sap.governance.level="L2"

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Create non-root user for security
RUN groupadd -r sap && useradd -r -g sap sap

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ---------------------------------------------------------------------------
# Build stage: Install Python dependencies
# ---------------------------------------------------------------------------
FROM base AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install Python dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    pydantic \
    elasticsearch \
    httpx \
    python-dotenv \
    opentelemetry-api \
    opentelemetry-sdk \
    opentelemetry-instrumentation-fastapi==0.43b0 \
    prometheus-client \
    hdbcli \
    PyJWT \
    kuzu

# ---------------------------------------------------------------------------
# Production stage
# ---------------------------------------------------------------------------
FROM base AS production

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy Go Mangle engine binary from go-builder stage
COPY --from=go-builder /mangle-engine /usr/local/bin/mangle-engine

# Copy application code
COPY mcp_server/ /app/mcp_server/
COPY sap_openai_server/ /app/sap_openai_server/
COPY agent/ /app/agent/
COPY middleware/ /app/middleware/
COPY mangle/ /app/mangle/
COPY data_products/ /app/data_products/
COPY rules/ /app/rules/
COPY cmd/ /app/cmd/
COPY connectors/ /app/connectors/
COPY intelligence/ /app/intelligence/
COPY openai/ /app/openai/
COPY performance/ /app/performance/
COPY efficiency/ /app/efficiency/
COPY observability/ /app/observability/
COPY routing/ /app/routing/
COPY scripts/entrypoint.sh /app/entrypoint.sh

# Create middleware __init__.py if missing
RUN touch /app/middleware/__init__.py

# Make entrypoint executable
RUN chmod +x /app/entrypoint.sh

# Set ownership
RUN chown -R sap:sap /app

# Switch to non-root user
USER sap

# Expose ports
# 9120: MCP Server
# 9201: ES OpenAI-compatible Server
# 8080: Mangle Query API
# 50051: Go gRPC Mangle Engine (internal)
EXPOSE 9120 9201 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:${MCP_PORT:-9120}/health || exit 1

# Set entrypoint
ENTRYPOINT ["/app/entrypoint.sh"]

# Default command (run MCP server)
CMD []