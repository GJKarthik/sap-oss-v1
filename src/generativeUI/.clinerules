# -----------------------------------------------------------------------------
# ANGULAR APP CONFIGURATION STANDARDS
# -----------------------------------------------------------------------------

## app.config.ts / environment.ts Rules

1. **Base Href Aware Path Construction:**
```typescript
// services/i18n.service.ts
@Injectable({ providedIn: 'root' })
export class I18nService {
  private getBaseHref(): string {
    return document.querySelector('base')?.getAttribute('href') || '/';
  }
  
  loadTranslations(locale: string): Observable<any> {
    const baseHref = this.getBaseHref();
    // Remove trailing slash, add it back consistently
    const base = baseHref.endsWith('/') ? baseHref.slice(0, -1) : baseHref;
    return this.http.get(`${base}/assets/i18n/messages_${locale}.json`);
  }
}
```

2. **APP_INITIALIZER Must Handle Failures Gracefully:**
```typescript
// app.config.ts
export function initializeApp(config: ConfigService): () => Promise<void> {
  return async () => {
    try {
      await config.load();
    } catch (error) {
      console.error('App initialization failed, using defaults:', error);
      config.useDefaults(); // Prevent blank page on init failure
    }
  };
}
```

3. **Environment Flags:**
```typescript
// environment.prod.ts
export const environment = {
  production: true,
  requireRealBackends: true, // Set false for testing without APIs
  apiBaseUrl: '', // Empty = relative to current origin
  ui5ThemeRoot: 'assets/theming/', // Relative path
};
```

