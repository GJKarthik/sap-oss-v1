# Data Cleaning Copilot — Environment Configuration
# Copy to .env and fill in your SAP AI Core credentials.

# ── SAP AI Core ───────────────────────────────────────────────────────────────
AICORE_CLIENT_ID=
AICORE_CLIENT_SECRET=
AICORE_AUTH_URL=https://<tenant>.authentication.<region>.hana.ondemand.com/oauth/token
AICORE_BASE_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com/v2
AICORE_RESOURCE_GROUP=default

# ── AI Core Deployment IDs (Claude models via SAP AI Core) ───────────────────
# Obtain from SAP AI Launchpad → AI Core → Deployments
AICORE_DEPLOYMENT_ID_CLAUDE_3_7=
AICORE_DEPLOYMENT_ID_CLAUDE_4=
