# =============================================================================
# Data Cleaning Copilot Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control!
# =============================================================================

# =============================================================================
# SAP Gen AI Hub Configuration (Required)
# =============================================================================

# OAuth2 token endpoint for authentication
AICORE_AUTH_URL=https://your-tenant.authentication.sap.hana.ondemand.com/oauth/token

# Gen AI Hub API base URL
AICORE_BASE_URL=https://api.ai.your-region.sap.hana.ondemand.com

# OAuth2 client credentials
AICORE_CLIENT_ID=your-client-id
AICORE_CLIENT_SECRET=your-client-secret

# AI Core resource group (default: "default")
AICORE_RESOURCE_GROUP=default

# =============================================================================
# MCP Server Configuration
# =============================================================================

# Authentication token for MCP server
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty for development (authentication disabled)
MCP_AUTH_TOKEN=

# Set to "true" to require authentication even if MCP_AUTH_TOKEN is empty
# This prevents accidental deployment without authentication
MCP_AUTH_REQUIRED=false

# Comma-separated list of hosts that bypass authentication
# Used for internal service-to-service communication
MCP_AUTH_BYPASS_HOSTS=127.0.0.1,localhost

# Maximum request body size in bytes (default: 1MB)
MCP_MAX_REQUEST_BYTES=1048576

# Maximum results per query (default: 100)
MCP_MAX_TOP_K=100

# Maximum columns to profile (default: 100)
MCP_MAX_PROFILE_COLUMNS=100

# Maximum remote MCP endpoints (default: 25)
MCP_MAX_REMOTE_ENDPOINTS=25

# Remote MCP call timeout in seconds (default: 3)
MCP_REMOTE_TIMEOUT_SECONDS=3

# =============================================================================
# Server Configuration
# =============================================================================

# Port for Gradio UI (default: 7860)
GRADIO_PORT=7860

# Port for FastAPI server (default: 8000)
API_PORT=8000

# Port for MCP server (default: 9110)
MCP_PORT=9110

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Database Configuration
# =============================================================================

# Default database to load (rel-stack, finsight, or custom path)
DATABASE_CONFIG=rel-stack

# Table scopes to limit agent exploration (comma-separated, empty = all tables)
TABLE_SCOPES=

# =============================================================================
# Agent Configuration
# =============================================================================

# Default agent version (v1, v2, v3)
AGENT_VERSION=v3

# Maximum iterations for iterative agents (v2, v3)
AGENT_MAX_ITERATIONS=100

# LLM model for interactive session
SESSION_MODEL=anthropic--claude-4-sonnet

# LLM model for agent workers (can be different for cost optimization)
AGENT_MODEL=anthropic--claude-3.7-sonnet

# =============================================================================
# Sandbox Configuration
# =============================================================================

# Default sandbox timeout in seconds
SANDBOX_TIMEOUT=30

# Default sandbox memory limit in MB
SANDBOX_MEMORY_MB=512

# =============================================================================
# Graph Database (KùzuDB) Configuration
# =============================================================================

# Path to KùzuDB database (":memory:" for in-memory)
KUZU_DB_PATH=:memory:

# =============================================================================
# Remote MCP Endpoints (Optional)
# =============================================================================

# Analytics MCP endpoint (e.g., Elasticsearch)
DATA_CLEANING_ANALYTICS_MCP_ENDPOINT=http://localhost:9120/mcp

# Context MCP endpoint (e.g., OData vocabulary)
DATA_CLEANING_CONTEXT_MCP_ENDPOINT=http://localhost:9150/mcp

# Additional remote MCP endpoints (comma-separated)
DATA_CLEANING_REMOTE_MCP_ENDPOINTS=

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format ("json" for production, empty for human-readable)
LOG_FORMAT=

# Log file path (optional, logs to stdout if not set)
LOG_FILE=

# =============================================================================
# Observability
# =============================================================================

# Application version (used in metrics)
DCC_VERSION=0.1.0

# Enable/disable metrics endpoint (requires prometheus_client package)
# Metrics are automatically enabled if prometheus_client is installed