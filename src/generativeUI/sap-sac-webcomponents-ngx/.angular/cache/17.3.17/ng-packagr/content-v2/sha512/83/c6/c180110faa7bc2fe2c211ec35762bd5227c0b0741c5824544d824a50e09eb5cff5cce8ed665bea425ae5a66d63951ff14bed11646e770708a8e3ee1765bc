veIds(): string[] {\n    return Array.from(this.dataSources.keys());\n  }\n}\n\n/**\n * Individual DataSource instance.\n */\nexport class DataSourceInstance implements DataSource {\n  readonly id: string;\n  readonly modelId: string;\n\n  private readonly data$ = new BehaviorSubject<ResultSet | null>(null);\n  private readonly loading$ = new BehaviorSubject<boolean>(false);\n  private readonly error$ = new BehaviorSubject<Error | null>(null);\n  private readonly filters$ = new BehaviorSubject<Map<string, FilterValue>>(new Map());\n\n  private dimensions: DimensionInfo[] = [];\n  private measures: MeasureInfo[] = [];\n  private variables: VariableInfo[] = [];\n  private paused = false;\n\n  constructor(\n    id: string,\n    modelId: string,\n    private http: HttpClient,\n    private sacConfig?: SacConfig,\n    private config?: Partial<DataSourceConfig>,\n  ) {\n    this.id = id;\n    this.modelId = modelId;\n  }\n\n  // ---------------------------------------------------------------------------\n  // Observable streams\n  // ---------------------------------------------------------------------------\n\n  get resultSet$(): Observable<ResultSet | null> {\n    return this.data$.asObservable();\n  }\n\n  get isLoading$(): Observable<boolean> {\n    return this.loading$.asObservable();\n  }\n\n  get lastError$(): Observable<Error | null> {\n    return this.error$.asObservable();\n  }\n\n  get activeFilters$(): Observable<Map<string, FilterValue>> {\n    return this.filters$.asObservable();\n  }\n\n  // ---------------------------------------------------------------------------\n  // Query methods (from mangle service_method facts)\n  // ---------------------------------------------------------------------------\n\n  /**\n   * Get data from the datasource.\n   * Implements: service_method(\"DataSource\", \"getData\", \"ResultSet\", \"async\")\n   */\n  async getData(): Promise<ResultSet> {\n    if (this.paused) {\n      const current = this.data$.getValue();\n      if (current) return current;\n      throw new Error('DataSource is paused and has no cached data');\n    }\n\n    this.loading$.next(true);\n    this.error$.next(null);\n\n    try {\n      const url = this.buildApiUrl('/data');\n      const body = {\n        modelId: this.modelId,\n        filters: Object.fromEntries(this.filters$.getValue()),\n      };\n\n      const response = await firstValueFrom(\n        this.http.post<ResultSet>(url, body)\n      );\n\n      this.data$.next(response);\n      return response;\n    } catch (err) {\n      this.error$.next(err as Error);\n      throw err;\n    } finally {\n      this.loading$.next(false);\n    }\n  }\n\n  /**\n   * Get dimensions.\n   * Implements: service_method(\"DataSource\", \"getDimensions\", \"DimensionInfo[]\", \"sync\")\n   */\n  getDimensions(): DimensionInfo[] {\n    return [...this.dimensions];\n  }\n\n  /**\n   * Get measures.\n   * Implements: service_method(\"DataSource\", \"getMeasures\", \"MeasureInfo[]\", \"sync\")\n   */\n  getMeasures(): MeasureInfo[] {\n    return [...this.measures];\n  }\n\n  /**\n   * Get variables.\n   * Implements: service_method(\"DataSource\", \"getVariables\", \"VariableInfo[]\", \"sync\")\n   */\n  getVariables(): VariableInfo[] {\n    return [...this.variables];\n  }\n\n  // ---------------------------------------------------------------------------\n  // Filter methods (from mangle service_method facts)\n  // ---------------------------------------------------------------------------\n\n  /**\n   * Set dimension filter.\n   * Implements: service_method(\"DataSource\", \"setDimensionFilter\", \"void\", \"async\")\n   */\n  async setFilter(dimension: string, value: FilterValue): Promise<void> {\n    const filters = new Map(this.filters$.getValue());\n    filters.set(dimension, value);\n    this.filters$.next(filters);\n    \n    if (!this.paused) {\n      await this.getData();\n    }\n  }\n\n  /**\n   * Remove dimension filter.\n   * Implements: service_method(\"DataSource\", \"removeDimensionFilter\", \"void\", \"async\")\n   */\n  async removeFilter(dimension: string): Promise<void> {\n    const filters = new Map(this.filters$.getValue());\n    filters.delete(dimension);\n    this.filters$.next(filters);\n    \n    if (!this.paused) {\n      await this.getData();\n    }\n  }\n\n  /**\n   * Clear all filters.\n   * Implements: service_method(\"DataSource\", \"clearAllFilters\", \"void\", \"async\")\n   */\n  async clearFilters(): Promise<void> {\n    this.filters$.next(new Map());\n    \n    if (!this.paused) {\n      await this.getData();\n    }\n  }\n\n  /**\n   * Get active filters.\n   * Implements: service_method(\"DataSource\", \"getActiveFilters\", \"FilterValue[]\", \"sync\")\n   */\n  getActiveFilters(): FilterValue[] {\n    return Array.from(this.filters$.getValue().values());\n  }\n\n  // ---------------------------------------------------------------------------\n  // State methods (from mangle service_method facts)\n  // ---------------------------------------------------------------------------\n\n  /**\n   * Refresh data.\n   * Implements: service_method(\"DataSource\", \"refresh\", \"void\", \"async\")\n   */\n  async refresh(): Promise<void> {\n    await this.getData();\n  }\n\n  /**\n   * Pause datasource.\n   * Implements: service_method(\"DataSource\", \"pause\", \"void\", \"sync\")\n   */\n  pause(): void {\n    this.paused = true;\n  }\n\n  /**\n   * Resume datasource.\n   * Implements: service_method(\"DataSource\", \"resume\", \"void\", \"sync\")\n   */\n  resume(): void {\n    this.paused = false;\n  }\n\n  /**\n   * Get current state.\n   * Implements: service_method(\"DataSource\", \"getState\", \"DataSourceState\", \"sync\")\n   */\n  getState(): DataSourceState {\n    return {\n      id: this.id,\n      modelId: this.modelId,\n      paused: this.paused,\n      loading: this.loading$.getValue(),\n      hasData: this.data$.getValue() !== null,\n      filterCount: this.filters$.getValue().size,\n    };\n  }\n\n  /**\n   * Dispose of resources.\n   */\n  dispose(): void {\n    this.data$.complete();\n    this.loading$.complete();\n    this.error$.complete();\n    this.filters$.complete();\n  }\n\n  // ---------------------------------------------------------------------------\n  // Private methods\n  // ---------------------------------------------------------------------------\n\n  private buildApiUrl(endpoint: string): string {\n    const base = this.sacConfig?.apiUrl || '';\n    return `${base}/api/v1/datasources/${this.modelId}${endpoint}`;\n  }\n}"]},"resolvedIds":{"@angular/core":{"attributes":{},"external":true,"id":"@angular/core","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"rxjs":{"attributes":{},"external":true,"id":"rxjs","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"@nucleus/sac-ngx-core":{"attributes":{},"external":true,"id":"@nucleus/sac-ngx-core","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"@angular/common/http":{"attributes":{},"external":true,"id":"@angular/common/http","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false}},"safeVariableNames":{"SacDataSourceService":"SacDataSourceService","DataSourceInstance":"DataSourceInstance"},"sourcemapChain":[],"syntheticNamedExports":false,"transformDependencies":[]},{"ast":{"type":"Program","start":0,"end":4260,"body":[{"type":"ImportDeclaration","start":0,"end":43,"specifiers":[{"type":"ImportSpecifier","start":9,"end":19,"imported":{"type":"Identifier","start":9,"end":19,"name":"Injectable"},"local":{"type":"Identifier","start":9,"end":19,"name":"Injectable"}}],"source":{"type":"Literal","start":27,"end":42,"value":"@angular/core","raw":"'@angular/core'"},"attributes":[]},{"type":"ImportDeclaration","start":44,"end":83,"specifiers":[{"type":"ImportSpecifier","start":53,"end":68,"imported":{"type":"Identifier","start":53,"end":68,"name":"BehaviorSu