PointClickEvent,\n  ChartLegendClickEvent,\n  ChartSelectionChangeEvent,\n} from '../types/chart-events.types';\n\n@Component({\n  selector: 'sac-chart',\n  template: `\n    <div #chartContainer\n         class=\"sac-chart\"\n         [class]=\"cssClass\"\n         [style.width]=\"width\"\n         [style.height]=\"height\"\n         [style.display]=\"visible ? 'block' : 'none'\">\n      <div class=\"sac-chart__header\" *ngIf=\"showTitle && title\">\n        <h3 class=\"sac-chart__title\">{{ title }}</h3>\n        <p class=\"sac-chart__subtitle\" *ngIf=\"subtitle\">{{ subtitle }}</p>\n      </div>\n      <div class=\"sac-chart__canvas\" #canvasContainer>\n        <!-- Chart rendered here by service -->\n      </div>\n      <div class=\"sac-chart__legend\" *ngIf=\"showLegend\">\n        <!-- Legend rendered based on legendPosition -->\n      </div>\n      <div class=\"sac-chart__loading\" *ngIf=\"loading\">\n        <span class=\"sac-chart__spinner\"></span>\n      </div>\n      <div class=\"sac-chart__error\" *ngIf=\"error\">\n        <span class=\"sac-chart__error-message\">{{ error }}</span>\n      </div>\n    </div>\n  `,\n  styles: [`\n    .sac-chart {\n      position: relative;\n      width: 100%;\n      height: 100%;\n      min-height: 200px;\n    }\n    .sac-chart__header {\n      padding: 8px 12px;\n    }\n    .sac-chart__title {\n      margin: 0;\n      font-size: 14px;\n      font-weight: 600;\n    }\n    .sac-chart__subtitle {\n      margin: 4px 0 0;\n      font-size: 12px;\n      color: #666;\n    }\n    .sac-chart__canvas {\n      flex: 1;\n      min-height: 150px;\n    }\n    .sac-chart__loading {\n      position: absolute;\n      top: 0;\n      left: 0;\n      right: 0;\n      bottom: 0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: rgba(255, 255, 255, 0.8);\n    }\n    .sac-chart__spinner {\n      width: 32px;\n      height: 32px;\n      border: 3px solid #f3f3f3;\n      border-top: 3px solid #0854a0;\n      border-radius: 50%;\n      animation: spin 1s linear infinite;\n    }\n    @keyframes spin {\n      0% { transform: rotate(0deg); }\n      100% { transform: rotate(360deg); }\n    }\n    .sac-chart__error {\n      padding: 16px;\n      text-align: center;\n      color: #bb0000;\n    }\n  `],\n  changeDetection: ChangeDetectionStrategy.OnPush,\n})\nexport class SacChartComponent implements OnInit, OnChanges, OnDestroy {\n  // ---------------------------------------------------------------------------\n  // Standard widget inputs (from mangle widget_input facts)\n  // ---------------------------------------------------------------------------\n  \n  @Input() visible = true;\n  @Input() enabled = true;\n  @Input() cssClass = '';\n  @Input() width = 'auto';\n  @Input() height = 'auto';\n\n  // ---------------------------------------------------------------------------\n  // Chart-specific inputs (from mangle chart_input facts)\n  // ---------------------------------------------------------------------------\n\n  @Input() chartType: ChartType = ChartType.Bar;\n  @Input() dataSource: any = null;\n  @Input() showLegend = true;\n  @Input() legendPosition: ChartLegendPosition = ChartLegendPosition.Bottom;\n  \n  @Input() title = '';\n  @Input() subtitle = '';\n  @Input() showTitle = true;\n  \n  @Input() axisScale?: ChartAxisScale;\n  @Input() numberFormat?: ChartNumberFormat;\n  @Input() legendConfig?: ChartLegendConfig;\n  @Input() forecastConfig?: ForecastConfig;\n  \n  @Input() feeds: Map<Feed, string[]> = new Map();\n  @Input() colorPalette?: string[];\n  @Input() enableZoom = false;\n  @Input() enableDrillDown = false;\n\n  // ---------------------------------------------------------------------------\n  // Standard widget outputs (from mangle widget_output facts)\n  // ---------------------------------------------------------------------------\n\n  @Output() onClick = new EventEmitter<MouseEvent>();\n  @Output() onResize = new EventEmitter<{ width: number; height: number }>();\n  @Output() onSelectionChange = new EventEmitter<ChartSelectionChangeEvent>();\n\n  // ---------------------------------------------------------------------------\n  // Chart-specific outputs (from mangle chart_output facts)\n  // ---------------------------------------------------------------------------\n\n  @Output() onDataPointClick = new EventEmitter<ChartDataPointClickEvent>();\n  @Output() onLegendClick = new EventEmitter<ChartLegendClickEvent>();\n  @Output() onZoom = new EventEmitter<{ zoomLevel: number }>();\n  @Output() onDataLoad = new EventEmitter<void>();\n  @Output() onError = new EventEmitter<Error>();\n\n  // ---------------------------------------------------------------------------\n  // Internal state\n  // ---------------------------------------------------------------------------\n\n  @ViewChild('chartContainer') chartContainer!: ElementRef<HTMLDivElement>;\n  @ViewChild('canvasContainer') canvasContainer!: ElementRef<HTMLDivElement>;\n\n  loading = false;\n  error: string | null = null;\n  private destroy$ = new Subject<void>();\n\n  constructor(\n    private chartService: SacChartService,\n    private cdr: ChangeDetectorRef,\n  ) {}\n\n  ngOnInit(): void {\n    this.initializeChart();\n  }\n\n  ngOnChanges(changes: SimpleChanges): void {\n    if (changes['chartType'] || changes['dataSource'] || changes['feeds']) {\n      this.updateChart();\n    }\n    if (changes['legendPosition'] || changes['showLegend']) {\n      this.updateLegend();\n    }\n  }\n\n  ngOnDestroy(): void {\n    this.destroy$.next();\n    this.destroy$.complete();\n    this.chartService.destroyChart();\n  }\n\n  // ---------------------------------------------------------------------------\n  // Public API methods\n  // ---------------------------------------------------------------------------\n\n  /** Refresh chart data */\n  refresh(): void {\n    this.loading = true;\n    this.error = null;\n    this.cdr.markForCheck();\n    \n    this.chartService.refreshData()\n      .then(() => {\n        this.loading = false;\n        this.onDataLoad.emit();\n        this.cdr.markForCheck();\n      })\n      .catch((err) => {\n        this.loading = false;\n        this.error = err.message;\n        this.onError.emit(err);\n        this.cdr.markForCheck();\n      });\n  }\n\n  /** Get current chart configuration */\n  getConfig(): ChartConfig {\n    return {\n      chartType: this.chartType,\n      showLegend: this.showLegend,\n      legendPosition: this.legendPosition,\n      enableZoom: this.enableZoom,\n      enableDrillDown: this.enableDrillDown,\n    };\n  }\n\n  /** Export chart as image */\n  exportAsImage(format: 'png' | 'svg' = 'png'): Promise<Blob> {\n    return this.chartService.exportChart(format);\n  }\n\n  // ---------------------------------------------------------------------------\n  // Private methods\n  // ---------------------------------------------------------------------------\n\n  private initializeChart(): void {\n    if (!this.canvasContainer) return;\n    \n    this.chartService.initialize(this.canvasContainer.nativeElement, {\n      chartType: this.chartType,\n      legendPosition: this.legendPosition,\n    });\n\n    if (this.dataSource) {\n      this.refresh();\n    }\n  }\n\n  private updateChart(): void {\n    this.chartService.updateConfig({\n      chartType: this.chartType,\n      feeds: this.feeds,\n    });\n  }\n\n  private updateLegend(): void {\n    this.chartService.updateLegend({\n      show: this.showLegend,\n      position: this.legendPosition,\n    });\n  }\n}"]},"resolvedIds":{"@angular/core":{"attributes":{},"external":true,"id":"@angular/core","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"rxjs":{"attributes":{},"external":true,"id":"rxjs","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"@nucleus/sac-ngx-core":{"attributes":{},"external":true,"id":"@nucleus/sac-ngx-core","meta":{},"moduleSideEff