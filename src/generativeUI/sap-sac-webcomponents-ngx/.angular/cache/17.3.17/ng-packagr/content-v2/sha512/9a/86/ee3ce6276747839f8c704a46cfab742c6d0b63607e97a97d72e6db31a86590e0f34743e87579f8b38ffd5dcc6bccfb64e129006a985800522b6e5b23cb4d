servable();\n  }\n\n  /**\n   * Initialize the chart with a container element and configuration.\n   */\n  initialize(container: HTMLElement, config: Partial<ChartConfig>): void {\n    this.containerElement = container;\n    this.config = { ...config };\n    this.createChartInstance();\n  }\n\n  /**\n   * Update chart configuration.\n   */\n  updateConfig(config: Partial<ChartConfig>): void {\n    this.config = { ...this.config, ...config };\n    this.applyConfig();\n  }\n\n  /**\n   * Update legend configuration.\n   */\n  updateLegend(legendConfig: ChartLegendConfig): void {\n    if (this.chartInstance) {\n      // Apply legend configuration\n      this.config = { ...this.config };\n      this.applyConfig();\n    }\n  }\n\n  /**\n   * Refresh chart data from datasource.\n   */\n  async refreshData(): Promise<void> {\n    this.loading$.next(true);\n    this.error$.next(null);\n\n    try {\n      // In a real implementation, this would fetch data from the SAC API\n      await this.simulateDataFetch();\n      this.renderChart();\n    } catch (err) {\n      this.error$.next(err as Error);\n      throw err;\n    } finally {\n      this.loading$.next(false);\n    }\n  }\n\n  /**\n   * Export chart as image.\n   */\n  async exportChart(format: 'png' | 'svg'): Promise<Blob> {\n    if (!this.containerElement) {\n      throw new Error('Chart not initialized');\n    }\n\n    // Placeholder implementation\n    // In production, would use canvas.toBlob() or SVG serialization\n    const canvas = document.createElement('canvas');\n    canvas.width = this.containerElement.clientWidth;\n    canvas.height = this.containerElement.clientHeight;\n    \n    return new Promise((resolve, reject) => {\n      canvas.toBlob((blob) => {\n        if (blob) {\n          resolve(blob);\n        } else {\n          reject(new Error('Failed to export chart'));\n        }\n      }, format === 'png' ? 'image/png' : 'image/svg+xml');\n    });\n  }\n\n  /**\n   * Get data point at coordinates.\n   */