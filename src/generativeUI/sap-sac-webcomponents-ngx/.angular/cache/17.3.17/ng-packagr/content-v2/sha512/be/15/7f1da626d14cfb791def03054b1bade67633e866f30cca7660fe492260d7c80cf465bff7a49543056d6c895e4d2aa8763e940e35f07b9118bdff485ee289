eights for equal distribution.\\n   */\\n  calculateEqualWeights(targetMembers: string[]): Record<string, number> {\\n    const weight = 1 / targetMembers.length;\\n    return targetMembers.reduce((acc, member) => {\\n      acc[member] = weight;\\n      return acc;\\n    }, {} as Record<string, number>);\\n  }\\n\\n  /**\\n   * Calculate weights based on proportional values.\\n   */\\n  calculateProportionalWeights(values: Record<string, number>): Record<string, number> {\\n    const total = Object.values(values).reduce((sum, v) => sum + v, 0);\\n    if (total === 0) return {};\\n    \\n    return Object.entries(values).reduce((acc, [key, value]) => {\\n      acc[key] = value / total;\\n      return acc;\\n    }, {} as Record<string, number>);\\n  }\\n\\n  // ---------------------------------------------------------------------------\\n  // Private methods\\n  // ---------------------------------------------------------------------------\\n\\n  private buildUrl(endpoint: string): string {\\n    const base = this.config?.apiUrl || '';\\n    return `${base}/api/v1/planning${endpoint}`;\\n  }\\n}\",\"import {\\n  Component,\\n  Input,\\n  Output,\\n  EventEmitter,\\n  ChangeDetectionStrategy,\\n} from '@angular/core';\\n\\n@Component({\\n  selector: 'sac-planning-panel',\\n  changeDetection: ChangeDetectionStrategy.OnPush,\\n  template: `\\n    <div class=\\\"sac-planning-panel\\\"\\n         [class]=\\\"cssClass\\\"\\n         [style.display]=\\\"visible ? 'block' : 'none'\\\">\\n      <div class=\\\"sac-planning-panel__header\\\" *ngIf=\\\"title\\\">\\n        <h3>{{ title }}</h3>\\n        <span class=\\\"sac-planning-panel__status\\\" *ngIf=\\\"status\\\">{{ status }}</span>\\n      </div>\\n      <div class=\\\"sac-planning-panel__content\\\">\\n        <ng-content></ng-content>\\n      </div>\\n    </div>\\n  `,\\n  styles: [`\\n    .sac-planning-panel { border: 1px solid #d9d9d9; border-radius: 4px; overflow: hidden; }\\n    .sac-planning-panel__header { display