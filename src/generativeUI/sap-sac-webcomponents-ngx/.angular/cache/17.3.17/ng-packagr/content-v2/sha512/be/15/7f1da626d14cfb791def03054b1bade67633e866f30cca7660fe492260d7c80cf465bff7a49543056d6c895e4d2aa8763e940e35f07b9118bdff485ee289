---------------------------\\n\\n  /**\\n   * Save data.\\n   * Implements: service_method(\\\"PlanningModel\\\", \\\"saveData\\\", \\\"void\\\", \\\"async\\\")\\n   */\\n  async saveData(): Promise<void> {\\n    const url = this.buildUrl('/data/save');\\n    await firstValueFrom(this.http.post(url, {}));\\n    this.dirty$.next(false);\\n  }\\n\\n  /**\\n   * Revert data.\\n   * Implements: service_method(\\\"PlanningModel\\\", \\\"revertData\\\", \\\"void\\\", \\\"async\\\")\\n   */\\n  async revertData(): Promise<void> {\\n    const url = this.buildUrl('/data/revert');\\n    await firstValueFrom(this.http.post(url, {}));\\n    this.dirty$.next(false);\\n  }\\n\\n  /**\\n   * Initialize with a model.\\n   */\\n  initialize(modelId: string): void {\\n    this.currentModelId = modelId;\\n    this.refreshVersions();\\n    this.refreshLockStatus();\\n  }\\n\\n  // ---------------------------------------------------------------------------\\n  // Private methods\\n  // ---------------------------------------------------------------------------\\n\\n  private async refreshVersions(): Promise<void> {\\n    if (!this.currentModelId) return;\\n    await this.getVersions();\\n  }\\n\\n  private async refreshLockStatus(): Promise<void> {\\n    if (!this.currentModelId) return;\\n    try {\\n      const url = this.buildUrl('/lock/status');\\n      const status = await firstValueFrom(this.http.get<LockInfo>(url));\\n      this.lockStatus$.next(status);\\n    } catch {\\n      this.lockStatus$.next(null);\\n    }\\n  }\\n\\n  private buildUrl(endpoint: string): string {\\n    const base = this.config?.apiUrl || '';\\n    return `${base}/api/v1/planning/models/${this.currentModelId}${endpoint}`;\\n  }\\n}\",\"/**\\n * SAC Data Action Service\\n *\\n * Service for executing SAC data actions.\\n * Derived from mangle/sac_planning.mg service_method \\\"DataAction\\\" facts.\\n */\\n\\nimport { Injectable, Inject, Optional } from '@angular/core';\\nimport { HttpClient } from '@angula