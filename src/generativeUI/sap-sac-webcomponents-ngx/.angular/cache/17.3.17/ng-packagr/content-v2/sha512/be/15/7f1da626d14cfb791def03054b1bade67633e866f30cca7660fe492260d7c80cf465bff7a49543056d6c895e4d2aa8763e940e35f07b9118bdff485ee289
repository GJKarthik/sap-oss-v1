ataAction\\\", \\\"execute\\\", \\\"DataActionResult\\\", \\\"async\\\")\\n   */\\n  async execute(dataActionId: string, parameters?: Record<string, unknown>): Promise<DataActionResult> {\\n    this.executionStatus$.next(DataActionStatus.Running);\\n\\n    try {\\n      const url = this.buildUrl(`/dataactions/${dataActionId}/execute`);\\n      const result = await firstValueFrom(\\n        this.http.post<DataActionResult>(url, { parameters: parameters ?? {} })\\n      );\\n      \\n      this.executionStatus$.next(result.status);\\n      this.lastResult$.next(result);\\n      return result;\\n    } catch (err) {\\n      this.executionStatus$.next(DataActionStatus.Failed);\\n      throw err;\\n    }\\n  }\\n\\n  /**\\n   * Execute in background.\\n   * Implements: service_method(\\\"DataAction\\\", \\\"executeBackground\\\", \\\"string\\\", \\\"async\\\")\\n   */\\n  async executeBackground(dataActionId: string, parameters?: Record<string, unknown>): Promise<string> {\\n    const url = this.buildUrl(`/dataactions/${dataActionId}/execute?async=true`);\\n    const response = await firstValueFrom(\\n      this.http.post<{ executionId: string }>(url, { parameters: parameters ?? {} })\\n    );\\n    return response.executionId;\\n  }\\n\\n  /**\\n   * Get execution status.\\n   * Implements: service_method(\\\"DataAction\\\", \\\"getStatus\\\", \\\"DataActionStatus\\\", \\\"async\\\")\\n   */\\n  async getStatus(dataActionId: string, executionId: string): Promise<DataActionResult> {\\n    const url = this.buildUrl(`/dataactions/${dataActionId}/status/${executionId}`);\\n    const result = await firstValueFrom(this.http.get<DataActionResult>(url));\\n    this.executionStatus$.next(result.status);\\n    this.lastResult$.next(result);\\n    return result;\\n  }\\n\\n  /**\\n   * Cancel execution.\\n   * Implements: service_method(\\\"DataAction\\\", \\\"cancel\\\", \\\"void\\\", \\\"async\\\")\\n   */\\n  async cancel(dataActionId: string, executionId: string): Promise<void> {\\n    const url = this.buildUrl(`/dataactions/${dataActionId}/cancel/${executionId}`);\\n    await firstValueFrom(this.http.post(url, {}));\\n    this.executionStatus$.next(DataActionStatus.Cancelled);\\n  }\\n\\n  // ---------------------------------------------------------------------------\\n  // Parameter methods (from mangle service_method facts)\\n  // ---------------------------------------------------------------------------\\n\\n  /**\\n   * Get parameters for a data action.\\n   * Implements: service_method(\\\"DataAction\\\", \\\"getParameters\\\", \\\"DataActionParameter[]\\\", \\\"sync\\\")\\n   */\\n  getParameters(dataAction: DataAction): DataActionParameter[] {\\n    return dataAction.parameters.map(p => ({\\n      ...p,\\n      currentValue: this.currentParameters.get(p.id) ?? p.defaultValue,\\n    }));\\n  }\\n\\n  /**\\n   * Set parameter value.\\n   * Implements: service_method(\\\"DataAction\\\", \\\"setParameter\\\", \\\"void\\\", \\\"sync\\\")\\n   */\\n  setParameter(parameterId: string, value: unknown): void {\\n    this.currentParameters.set(parameterId, value);\\n  }\\n\\n  /**\\n   * Validate parameters.\\n   * Implements: service_method(\\\"DataAction\\\", \\\"validateParameters\\\", \\\"ValidationResult\\\", \\\"sync\\\")\\n   */\\n  validateParameters(dataAction: DataAction): { valid: boolean; errors: string[] } {\\n    const errors: string[] = [];\\n    \\n    for (const param of dataAction.parameters) {\\n      if (param.required && !this.currentParameters.has(param.id)) {\\n        errors.push(`Required parameter \\\"${param.name}\\\" is missing`);\\n      }\\n    }\\n    \\n    return { valid: errors.length === 0, errors };\\n  }\\n\\n  /** Clear all parameters */\\n  clearParameters(): void {\\n    this.currentParameters.clear();\\n  }\\n\\n  // ---------------------------------------------------------------------------\\n  // Private methods\\n  // ---------------------------------------------------------------------------\\n\\n  private buildUrl(endpoint: string): string {\\n    const base = this.config?.apiUrl || '';\\n    return `${base}/api/v1${endpoint}`;\\n  }\\n}\",\"/**\\n * SAC Allocation Service\\n *\\n * Service for executing SAC allocation operations.\\n * Derived from mangle/sac_planning.mg allocation_type, service_method \\\"Allocation\\\" facts.\\n */\\n\\nimport { Injectable, Inject, Optional } from '@angular/core';\\nimport { HttpClient } from '@angular/common/http';\\nimport { firstValueFrom } from 'rxjs';\\n\\nimport { SAC_CONFIG } from '@nucleus/sac-ngx-core';\\nimport type { SacConfig } from '@nucleus/sac-ngx-core';\\n\\nexport enum AllocationType {\\n  TopDown = 'top_down',\\n  BottomUp = 'bottom_up',\\n  Distribute = 'distribute',\\n  WeightBased = 'weight_based',\\n  Reference = 'reference',\\n}\\n\\nexport interface Allocation {\\n  id: string;\\n  name: string;\\n  type: AllocationType;\\n  sourceDimension: string;\\n  targetDimension: string;\\n  measure: string;\\n}\\n\\nexport interface AllocationParameter {\\n  sourceMember: string;\\n  targetMembers: string[];\\n  amount?: number;\\n  weights?: Record<string, number>;\\n  referenceDimension?: string;\\n}\\n\\nexport interface AllocationResult {\\n  success: boolean;\\n  rowsAffected: number;\\n  sourceValue: number;\\n  targetValues: Record<string, number>;\\n  message?: string;\\n}\\n\\n@Injectable({ providedIn: 'root' })\\nexport class SacAllocationService {\\n  constructor(\\n    private http: HttpClient,\\n    @Optional() @Inject(SAC_CONFIG) private config?: SacConfig,\\n  ) {}\\n\\n  // ---------------------------------------------------------------------------\\n  // Allocation methods (from mangle service_method \\\"Allocation\\\")\\n  // ---------------------------------------------------------------------------\\n\\n  /**\\n   * Execute allocation.\\n   * Implements: service_method(\\\"Allocation\\\", \\\"execute\\\", \\\"AllocationResult\\\", \\\"async\\\")\\n   */\\n  async execute(allocation: Al