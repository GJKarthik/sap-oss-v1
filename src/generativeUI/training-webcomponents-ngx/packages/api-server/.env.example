MODELOPT_URL=http://localhost:8001
# Dev shells; add http://localhost:8080 when using src/generativeUI/docker-compose suite-gateway
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://127.0.0.1:8080,http://localhost:8080
PORT=8000

# Optional: idempotent translation-memory seed at API startup (5 reference rows). Full demos: scripts/seed_demo_data.py
# SEED_DEMO_DATA=1

# Database — omit to auto-detect from HANA_* vars, or fall back to SQLite
# DATABASE_URL=hana+hdbcli://USER:PASSWORD@host:443?encrypt=true

# SAP HANA Cloud (used when DATABASE_URL is not set)
HANA_HOST=your-hana-instance.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_ENCRYPT=true

# Auth — JWT secret for local user registration / login tokens
AUTH_JWT_SECRET=replace-with-a-strong-random-secret

# Preview-only escape hatch. Leave unset/false in production to prevent
# unauthenticated requests from choosing arbitrary workspace identities.
# ALLOW_UNAUTHENTICATED_WORKSPACE_HINTS=false

# Optional: require this value in X-Internal-Token for POST /audit/batch
# AUDIT_SINK_TOKEN=

# vLLM / TurboQuant (health: GET {base}/health). VLLM_TURBOQUANT_URL overrides VLLM_URL for probes only.
# VLLM_URL=http://vllm:8080
# VLLM_TURBOQUANT_URL=http://vllm:8000

# LLM upstream circuit breaker (per vLLM / AI Core route keys)
# LLM_CIRCUIT_FAILURE_THRESHOLD=5
# LLM_CIRCUIT_COOLDOWN_SEC=30

# SAP AI Core (client credentials; used for readiness when all four are set)
# AICORE_CLIENT_ID=
# AICORE_CLIENT_SECRET=
# AICORE_AUTH_URL=
# AICORE_BASE_URL=
# Optional dedicated Anthropic/OpenAI-compatible proxy for LLMRouter (defaults to AICORE_BASE_URL)
# AICORE_ANTHROPIC_URL=

# PAL / AI Core PAL proxy base (optional; same logical URL as gateway AI_CORE_PAL_UPSTREAM)
# PAL_UPSTREAM_URL=
