MODELOPT_URL=http://localhost:8001
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201
PORT=8000

# Database — omit to auto-detect from HANA_* vars, or fall back to SQLite
# DATABASE_URL=hana+hdbcli://USER:PASSWORD@host:443?encrypt=true

# SAP HANA Cloud (used when DATABASE_URL is not set)
HANA_HOST=your-hana-instance.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_ENCRYPT=true

# Auth — JWT secret for local user registration / login tokens
AUTH_JWT_SECRET=change-me-in-production
