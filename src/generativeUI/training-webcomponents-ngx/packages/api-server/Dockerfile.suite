FROM python:3.12-slim

WORKDIR /app

# Suite image keeps API/runtime dependencies lean for fast startup.
COPY requirements.suite.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ src/

EXPOSE 8000
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000"]
