* Selector: sac-table (derived from mangle/sac_widget.mg)\n */\n\nimport {\n  Component,\n  Input,\n  Output,\n  EventEmitter,\n  OnInit,\n  OnChanges,\n  OnDestroy,\n  SimpleChanges,\n  ChangeDetectionStrategy,\n  ChangeDetectorRef,\n  TrackByFunction,\n} from '@angular/core';\nimport { Subject } from 'rxjs';\n\nimport type {\n  TableConfig,\n  TableColumn,\n  TableRow,\n  TableSortConfig,\n  TablePaginationConfig,\n} from '../types/table.types';\nimport type {\n  TableCellClickEvent,\n  TableRowClickEvent,\n  TableSelectionChangeEvent,\n  TableSortChangeEvent,\n} from '../types/table-events.types';\n\n@Component({\n  selector: 'sac-table',\n  template: `\n    <div class=\"sac-table\" [class]=\"cssClass\" [style.display]=\"visible ? 'block' : 'none'\">\n      <div class=\"sac-table__header\" *ngIf=\"showTitle && title\">\n        <h3 class=\"sac-table__title\">{{ title }}</h3>\n      </div>\n      \n      <div class=\"sac-table__container\">\n        <table class=\"sac-table__grid\">\n          <thead class=\"sac-table__head\">\n            <tr>\n              <th *ngIf=\"selectable\" class=\"sac-table__th sac-table__th--checkbox\">\n                <input type=\"checkbox\" (change)=\"toggleSelectAll($event)\" />\n              </th>\n              <th\n                *ngFor=\"let col of columns; trackBy: trackByColumnId\"\n                class=\"sac-table__th\"\n                [class.sac-table__th--sortable]=\"col.sortable\"\n                [style.width]=\"col.width\"\n                (click)=\"col.sortable && handleSort(col)\">\n                {{ col.label }}\n                <span class=\"sac-table__sort-icon\" *ngIf=\"col.sortable\">\n                  {{ sortConfig?.column === col.id ? (sortConfig?.direction === 'asc' ? '▲' : '▼') : '' }}\n                </span>\n              </th>\n            </tr>\n          </thead>\n          <tbody class=\"sac-table__body\">\n            <tr\n              *ngFor=\"let row of displayRows; trackBy: trackByRowId\"\n              class=\"sac-table__row\"\n              [class.sac-table__row--selected]=\"isRowSelected(row)\"\n              (click)=\"handleRowClick(row, $event)\">\n              <td *ngIf=\"selectable\" class=\"sac-table__td sac-table__td--checkbox\">\n                <input\n                  type=\"checkbox\"\n                  [checked]=\"isRowSelected(row)\"\n                  (click)=\"$event.stopPropagation()\"\n                  (change)=\"toggleRowSelection(row, $event)\"\n                />\n              </td>\n              <td\n                *ngFor=\"let col of columns; trackBy: trackByColumnId\"\n                class=\"sac-table__td\"\n                (click)=\"handleCellClick(row, col, $event)\">\n                {{ row[col.id] }}\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n      \n      <div class=\"sac-table__footer\" *ngIf=\"pagination\">\n        <div class=\"sac-table__pagination\">\n          <span>{{ paginationInfo }}</span>\n          <button [disabled]=\"currentPage <= 1\" (click)=\"goToPage(currentPage - 1)\">←</button>\n          <button [disabled]=\"currentPage >= totalPages\" (click)=\"goToPage(currentPage + 1)\">→</button>\n        </div>\n      </div>\n      \n      <div class=\"sac-table__loading\" *ngIf=\"loading\">\n        <span class=\"sac-table__spinner\"></span>\n      </div>\n    </div>\n  `,\n  styles: [`\n    .sac-table {\n      position: relative;\n      border: 1px solid #e5e5e5;\n      border-radius: 4px;\n      overflow: hidden;\n    }\n    .sac-table__header {\n      padding: 12px 16px;\n      border-bottom: 1px solid #e5e5e5;\n    }\n    .sac-table__title {\n      margin: 0;\n      font-size: 14px;\n      font-weight: 600;\n    }\n    .sac-table__container {\n      overflow-x: auto;\n    }\n    .sac-table__grid {\n      width: 100%;\n      border-collapse: collapse;\n    }\n    .sac-table__th {\n      padding: 12px 16px;\n      text-align: left;\n      font-weight: 600;\n      font-size: 12px;\n      color: #32363a;\n      background: #f5f6f7;\n      border-bottom: 1px solid #e5e5e5;\n      white-space: nowrap;\n    }\n    .sac-table__th--sortable {\n      cursor: pointer;\n    }\n    .sac-table__th--sortable:hover {\n      background: #e5e5e5;\n    }\n    .sac-table__th--checkbox {\n      width: 40px;\n      text-align: center;\n    }\n    .sac-table__sort-icon {\n      margin-left: 4px;\n      font-size: 10px;\n    }\n    .sac-table__td {\n      padding: 10px 16px;\n      font-size: 14px;\n      border-bottom: 1px solid #e5e5e5;\n    }\n    .sac-table__td--checkbox {\n      text-align: center;\n    }\n    .sac-table__row:hover {\n      background: #f5f6f7;\n    }\n    .sac-table__row--selected {\n      background: #e6f0fa;\n    }\n    .sac-table__footer {\n      padding: 12px 16px;\n      border-top: 1px solid #e5e5e5;\n      display: flex;\n      justify-content: flex-end;\n    }\n    .sac-table__pagination {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n    }\n    .sac-table__pagination button {\n      padding: 4px 12px;\n      border: 1px solid #89919a;\n      border-radius: 4px;\n      background: white;\n      cursor: pointer;\n    }\n    .sac-table__pagination button:disabled {\n      opacity: 0.5;\n      cursor: not-allowed;\n    }\n    .sac-table__loading {\n      position: absolute;\n      top: 0;\n      left: 0;\n      right: 0;\n      bottom: 0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: rgba(255, 255, 255, 0.8);\n    }\n    .sac-table__spinner {\n      width: 32px;\n      height: 32px;\n      border: 3px solid #f3f3f3;\n      border-top: 3px solid #0854a0;\n      border-radius: 50%;\n      animation: spin 1s linear infinite;\n    }\n    @keyframes spin {\n      0% { transform: rotate(0deg); }\n      100% { transform: rotate(360deg); }\n    }\n  `],\n  changeDetection: ChangeDetectionStrategy.OnPush,\n})\nexport class SacTableComponent implements OnInit, OnChanges, OnDestroy {\n  @Input() columns: TableColumn[] = [];\n  @Input() rows: TableRow[] = [];\n  @Input() title = '';\n  @Input() showTitle = true;\n  @Input() selectable = false;\n  @Input() multiSelect = true;\n  @Input() pagination?: TablePaginationConfig;\n  @Input() sortConfig?: TableSortConfig;\n  @Input() loading = false;\n  @Input() visible = true;\n  @Input() cssClass = '';\n\n  @Output() onCellClick = new EventEmitter<TableCellClickEvent>();\n  @Output() onRowClick = new EventEmitter<TableRowClickEvent>();\n  @Output() onSelectionChange = new EventEmitter<TableSelectionChangeEvent>();\n  @Output() onSortChange = new EventEmitter<TableSortChangeEvent>();\n\n  selectedRows = new Set<string>();\n  currentPage = 1;\n  pageSize = 10;\n\n  private destroy$ = new Subject<void>();\n\n  constructor(private cdr: ChangeDetectorRef) {}\n\n  ngOnInit(): void {\n    if (this.pagination) {\n      this.pageSize = this.pagination.pageSize || 10;\n    }\n  }\n\n  ngOnChanges(changes: SimpleChanges): void {\n    if (changes['rows'] || changes['sortConfig']) {\n      this.cdr.markForCheck();\n    }\n  }\n\n  ngOnDestroy(): void {\n    this.destroy$.next();\n    this.destroy$.complete();\n  }\n\n  get displayRows(): TableRow[] {\n    let result = [...this.rows];\n    \n    if (this.sortConfig) {\n      result.sort((a, b) => {\n        const val1 = a[this.sortConfig!.column];\n        const val2 = b[this.sortConfig!.column];\n        const cmp = val1 < val2 ? -1 : val1 > val2 ? 1 : 0;\n        return this.sortConfig!.direction === 'asc' ? cmp : -cmp;\n      });\n    }\n    \n    if (this.pagination) {\n      const start = (this.currentPage - 1) * this.pageSize;\n      result = result.slice(start, start + this.pageSize);\n    }\n    \n    return result;\n  }\n\n  get totalPages(): number {\n    return Math.ceil(this.rows.length / this.pageSize);\n  }\n\n  get paginationInfo(): string {\n    const start = (this.currentPage - 1) * this.pageSize + 1;\n    const end = Math.min(this.currentPage * this.pageSize, this.rows.length);\n    return `${start}-${end} of ${this.rows.length}`;\n  }\n\n  trackByColumnId: TrackByFunction<TableColumn> = (_, col) => col.id;\n  trackByRowId: TrackByFunction<TableRow> = (_, row) => row.id ?? row;\n\n  isRowSelected(row: TableRow): boolean {\n    return this.selectedRows.has(row.id);\n  }\n\n  toggleSelectAll(event: Event): void {\n    const checked = (event.target as HTMLInputElement).checked;\n    if (checked) {\n      this.rows.forEach(r => this.selectedRows.add(r.id));\n    } else {\n      this.selectedRows.clear();\n    }\n    this.emitSelectionChange();\n  }\n\n  toggleRowSelection(row: TableRow, event: Event): void {\n    const checked = (event.target as HTMLInputElement).checked;\n    if (checked) {\n      if (!this.multiSelect) this.selectedRows.clear();\n      this.selectedRows.add(row.id);\n    } else {\n      this.selectedRows.delete(row.id);\n    }\n    this.emitSelectionChange();\n  }\n\n  handleRowClick(row: TableRow, event: MouseEvent): void {\n    this.onRowClick.emit({ row, originalEvent: event });\n  }\n\n  handleCellClick(row: TableRow, column: TableColumn, event: MouseEvent): void {\n    event.stopPropagation();\n    this.onCellClick.emit({ row, column, value: row[column.id], originalEvent: event });\n  }\n\n  handleSort(column: TableColumn): void {\n    const direction = \n      this.sortConfig?.column === column.id && this.sortConfig?.direction === 'asc'\n        ? 'desc' : 'asc';\n    this.onSortChange.emit({ column: column.id, direction });\n  }\n\n  goToPage(page: number): void {\n    this.currentPage = page;\n    this.cdr.markForCheck();\n  }\n\n  private emitSelectionChange(): void {\n    const selected = this.rows.filter(r => this.selectedRows.has(r.id));\n    this.onSelectionChange.emit({ selectedRows: selected, selectedCount: selected.length });\n    this.cdr.markForCheck();\n  }\n}"]},"resolvedIds":{"@angular/core":{"attributes":{},"external":true,"id":"@an