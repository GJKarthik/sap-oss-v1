ethods\n  // ---------------------------------------------------------------------------\n\n  /** Set table data */\n  setData(rows: TableRow[]): void {\n    this.rows$.next(rows);\n  }\n\n  /** Get current rows */\n  getData(): TableRow[] {\n    return this.rows$.getValue();\n  }\n\n  /** Add row */\n  addRow(row: TableRow): void {\n    const current = this.rows$.getValue();\n    this.rows$.next([...current, row]);\n  }\n\n  /** Update row */\n  updateRow(rowId: string, updates: Partial<TableRow>): void {\n    const current = this.rows$.getValue();\n    const updated = current.map(r => \n      r.id === rowId ? { ...r, ...updates } : r\n    );\n    this.rows$.next(updated);\n  }\n\n  /** Remove row */\n  removeRow(rowId: string): void {\n    const current = this.rows$.getValue();\n    this.rows$.next(current.filter(r => r.id !== rowId));\n  }\n\n  // ---------------------------------------------------------------------------\n  // Selection methods\n  // ---------------------------------------------------------------------------\n\n  /** Select row */\n  selectRow(rowId: string, multiSelect = true): void {\n    const current = this.selection$.getValue();\n    const rows = this.rows$.getValue();\n    \n    let selectedIds = multiSelect \n      ? [...current.selectedRowIds, rowId]\n      : [rowId];\n    \n    selectedIds = [...new Set(selectedIds)];\n    const selectedRows = rows.filter(r => selectedIds.includes(r.id));\n    \n    this.selection$.next({\n      selectedRowIds: selectedIds,\n      selectedRows,\n      allSelected: selectedIds.length === rows.length,\n    });\n  }\n\n  /** Deselect row */\n  deselectRow(rowId: string): void {\n    const current = this.selection$.getValue();\n    const rows = this.rows$.getValue();\n    \n    const selectedIds = current.selectedRowIds.filter(id => id !== rowId);\n    const selectedRows = rows.filter(r => selectedIds.includes(r.id));\n    \n    this.selection$.next({\n      selectedRowIds: selectedIds,\n      selectedRows,\n      allSelected: false,\n    });\n  }\n\n  /** Select all */\n  selectAll(): void {\n    const rows = this.rows$.getValue();\n    this.selection$.next({\n      selectedRowIds: rows.map(r => r.id),\n      selectedRows: rows,\n      allSelected: true,\n    });\n  }\n\n  /** Clear selection */\n  clearSelection(): void {\n    this.selection$.next({\n      selectedRowIds: [],\n      selectedRows: [],\n      allSelected: false,\n    });\n  }\n\n  // ---------------------------------------------------------------------------\n  // Sort methods\n  // ---------------------------------------------------------------------------\n\n  /** Set sort */\n  setSort(config: TableSortConfig): void {\n    this.sortConfig$.next(config);\n    this.applySort();\n  }\n\n  /** Clear sort */\n  clearSort(): void {\n    this.sortConfig$.next(null);\n  }\n\n  private applySort(): void {\n    const config = this.sortConfig$.getValue();\n    if (!config) return;\n\n    const rows = [...this.rows$.getValue()];\n    rows.sort((a, b) => {\n      const val1 = a[config.column];\n      const val2 = b[config.column];\n      \n      let cmp = 0;\n      if (typeof val1 === 'string' && typeof val2 === 'string') {\n        cmp = val1.localeCompare(val2);\n      } else if (typeof val1 === 'number' && typeof val2 === 'number') {\n        cmp = val1 - val2;\n      } else {\n        cmp = String(val1).localeCompare(String(val2));\n      }\n      \n      return config.direction === 'asc' ? cmp : -cmp;\n    });\n    \n    this.rows$.next(rows);\n  }\n\n  // ---------------------------------------------------------------------------\n  // Filter methods\n  // ---------------------------------------------------------------------------\n\n  /** Add filter */\n  addFilter(filter: TableFilterConfig): void {\n    const current = this.filters$.getValue();\n    const updated = current.filter(f => f.column !== filter.column);\n    this.filters$.next([...updated, filter]);\n  }\n\n  /** Remove filter */\n  removeFilter(column: string): void {\n    const current = this.filters$.getValue();\n    this.filters$.next(current.filter(f => f.column !== column));\n  }\n\n  /** Clear all filters */\n  clearFilters(): void {\n    this.filters$.next([]);\n  }\n\n  /** Get filtered rows */\n  getFilteredRows(): TableRow[] {\n    const rows = this.rows$.getValue();\n    const filters = this.filters$.getValue();\n    \n    if (filters.length === 0) return rows;\n    \n    return rows.filter(row => {\n      return filters.every(filter => {\n        const value = String(row[filter.column] ?? '');\n        const filterValue = filter.value;\n        \n        switch (filter.operator) {\n          case 'equals': return value === filterValue;\n          case 'contains': return value.includes(filterValue);\n          case 'startsWith': return value.startsWith(filterValue);\n          case 'endsWith': return value.endsWith(filterValue);\n          case 'gt': return Number(value) > Number(filterValue);\n          case 'lt': return Number(value) < Number(filterValue);\n          case 'gte': return Number(value) >= Number(filterValue);\n          case 'lte': return Number(value) <= Number(filterValue);\n          default: return true;\n        }\n      });\n    });\n  }\n}"]},"resolvedIds":{"@angular/core":{"attributes":{},"external":true,"id":"@angular/core","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"rxjs":{"attributes":{},"external":true,"id":"rxjs","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false}},"safeVariableNames":{"SacTableService":"SacTableService"},"sourcemapChain":[],"syntheticNamedExports":false,"transformDependencies":[]},{"ast":{"type":"Program","start":0,"end":3043,"body":[{"type":"ImportDeclaration","start":131,"end":172,"specifiers":[{"type":"ImportSpecifier","start":140,"end":148,"imported":{"type":"Identifier","start":140,"end":148,"name":"NgModule"},"local":{"type":"Identifier","start":140,"end":148,"