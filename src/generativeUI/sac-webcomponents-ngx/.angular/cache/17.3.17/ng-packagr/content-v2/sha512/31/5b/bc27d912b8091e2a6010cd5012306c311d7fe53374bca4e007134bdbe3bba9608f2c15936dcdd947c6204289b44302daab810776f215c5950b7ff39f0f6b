{"css":".sac-table{position:relative;border:1px solid #e5e5e5;border-radius:4px;overflow:hidden}.sac-table__header{padding:12px 16px;border-bottom:1px solid #e5e5e5}.sac-table__title{margin:0;font-size:14px;font-weight:600}.sac-table__container{overflow-x:auto}.sac-table__grid{width:100%;border-collapse:collapse}.sac-table__th{padding:12px 16px;text-align:left;font-weight:600;font-size:12px;color:#32363a;background:#f5f6f7;border-bottom:1px solid #e5e5e5;white-space:nowrap}.sac-table__th--sortable{cursor:pointer}.sac-table__th--sortable:hover{background:#e5e5e5}.sac-table__th--checkbox{width:40px;text-align:center}.sac-table__sort-icon{margin-left:4px;font-size:10px}.sac-table__td{padding:10px 16px;font-size:14px;border-bottom:1px solid #e5e5e5}.sac-table__td--checkbox{text-align:center}.sac-table__row:hover{background:#f5f6f7}.sac-table__row--selected{background:#e6f0fa}.sac-table__footer{padding:12px 16px;border-top:1px solid #e5e5e5;display:flex;justify-content:flex-end}.sac-table__pagination{display:flex;align-items:center;gap:12px}.sac-table__pagination button{padding:4px 12px;border:1px solid #89919a;border-radius:4px;background:#fff;cursor:pointer}.sac-table__pagination button:disabled{opacity:.5;cursor:not-allowed}.sac-table__loading{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#fffc}.sac-table__spinner{width:32px;height:32px;border:3px solid #f3f3f3;border-top:3px solid #0854a0;border-radius:50%;animation:spin 1s linear infinite}@keyframes spin{0%{transform:rotate(0)}to{transform:rotate(360deg)}}\n","warnings":[]}