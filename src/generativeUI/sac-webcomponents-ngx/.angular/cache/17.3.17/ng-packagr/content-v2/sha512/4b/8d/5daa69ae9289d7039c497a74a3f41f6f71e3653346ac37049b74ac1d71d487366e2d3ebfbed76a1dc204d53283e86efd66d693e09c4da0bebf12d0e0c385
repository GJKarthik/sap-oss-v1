{"css":".sac-chart{position:relative;width:100%;height:100%;min-height:200px}.sac-chart__header{padding:8px 12px}.sac-chart__title{margin:0;font-size:14px;font-weight:600}.sac-chart__subtitle{margin:4px 0 0;font-size:12px;color:#666}.sac-chart__canvas{flex:1;min-height:150px}.sac-chart__loading{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#fffc}.sac-chart__spinner{width:32px;height:32px;border:3px solid #f3f3f3;border-top:3px solid #0854a0;border-radius:50%;animation:spin 1s linear infinite}@keyframes spin{0%{transform:rotate(0)}to{transform:rotate(360deg)}}.sac-chart__error{padding:16px;text-align:center;color:#b00}\n","warnings":[]}