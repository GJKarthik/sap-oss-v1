lockedBy?: string;\n  lockedAt?: Date;\n  scope: DataLockingScope;\n}\n\nexport interface PlanningSession {\n  modelId: string;\n  workingVersionId?: string;\n  isDirty: boolean;\n  lockInfo: LockInfo;\n}\n\n@Injectable({ providedIn: 'root' })\nexport class SacPlanningModelService {\n  private readonly versions$ = new BehaviorSubject<VersionInfo[]>([]);\n  private readonly lockStatus$ = new BehaviorSubject<LockInfo | null>(null);\n  private readonly dirty$ = new BehaviorSubject<boolean>(false);\n  private currentModelId: string | null = null;\n\n  constructor(\n    private http: HttpClient,\n    @Optional() @Inject(SAC_CONFIG) private config?: SacConfig,\n  ) {}\n\n  /** Observable: all versions */\n  get allVersions$(): Observable<VersionInfo[]> {\n    return this.versions$.asObservable();\n  }\n\n  /** Observable: lock status */\n  get currentLockStatus$(): Observable<LockInfo | null> {\n    return this.lockStatus$.asObservable();\n  }\n\n  /** Observable: dirty state */\n  get isDirty$(): Observable<boolean> {\n    return this.dirty$.asObservable();\n  }\n\n  // ---------------------------------------------------------------------------\n  // Version methods (from mangle service_method \"PlanningModel\")\n  // ---------------------------------------------------------------------------\n\n  /**\n   * Create a private version.\n   * Implements: service_method(\"PlanningModel\", \"createPrivateVersion\", \"VersionInfo\", \"async\")\n   */\n  async createPrivateVersion(name: string): Promise<VersionInfo> {\n    const url = this.buildUrl('/versions');\n    const response = await firstValueFrom(\n      this.http.post<VersionInfo>(url, { name, type: 'Private' })\n    );\n    await this.refreshVersions();\n    return response;\n  }\n\n  /**\n   * Publish private version.\n   * Implements: service_method(\"PlanningModel\", \"publishPrivateVersion\", \"void\", \"async\")\n   */\n  async publishPrivateVersion(versionId: string): Promise<void> {\n    const url = this.buildUrl(`/versions/${versionId}/publish`);\n    await firstValueFrom(this.http.post(url, {}));\n    await this.refreshVersions();\n  }\n\n  /**\n   * Delete private version.\n   * Implements: service_method(\"PlanningModel\", \"deletePrivateVersion\", \"void\", \"async\")\n   */\n  async deletePrivateVersion(versionId: string): Promise<void> {\n    const url = this.buildUrl(`/versions/${versionId}`);\n    await firstValueFrom(this.http.delete(url));\n    await this.refreshVersions();\n  }\n\n  /**\n   * Get all versions.\n   * Implements: service_method(\"PlanningModel\", \"getVersions\", \"VersionInfo[]\", \"async\")\n   */\n  async getVersions(): Promise<VersionInfo[]> {\n    const url = this.buildUrl('/versions');\n    const versions = await firstValueFrom(this.http.get<VersionInfo[]>(url));\n    this.versions$.next(versions);\n    return versions;\n  }\n\n  /**\n   * Set working version.\n   * Implements: service_method(\"PlanningModel\", \"setWorkingVersion\", \"void\", \"sync\")\n   */\n  setWorkingVersion(versionId: string): void {\n    const versions = this.versions$.getValue().map(v => ({\n      ...v,\n      isWorkingVersion: v.id === versionId,\n    }));\n    this.versions$.next(versions);\n  }\n\n  // ---------------------------------------------------------------------------\n  // Lock methods (from mangle service_method facts)\n  // ---------------------------------------------------------------------------\n\n  /**\n   * Lock data.\n   * Implements: service_method(\"PlanningModel\", \"lockData\", \"LockInfo\", \"async\")\n   */\n  async lockData(scope: DataLockingScope = DataLockingScope.All): Promise<LockInfo> {\n    const url = this.buildUrl('/lock');\n    const lockInfo = await firstValueFrom(\n      this.http.post<LockInfo>(url, { scope })\n    );\n    this.lockStatus$.next(lockInfo);\n    return lockInfo;\n  }\n\n  /**\n   * Unlock data.\n   * Implements: service_method(\"PlanningModel\", \"unlockData\", \"void\", \"async\")\n   */\n  async unlockData(): Promise<void> {\n    const url = this.buildUrl('/lock');\n    await firstValueFrom(this.http.delete(url));\n    this.lockStatus$.next(null);\n  }\n\n  /**\n   * Get lock status.\n   * Implements: service_method(\"PlanningModel\", \"getLockStatus\", \"LockInfo\", \"sync\")\n   */\n  getLockStatus(): LockInfo | null {\n    return this.lockStatus$.getValue();\n  }\n\n  // ---------------------------------------------------------------------------\n  // Data methods (from mangle service_method facts)\n  // ---------------------------------------------------------------------------\n\n  /**\n   * Save data.\n   * Implements: service_method(\"PlanningModel\", \"saveData\", \"void\", \"async\")\n   */\n  async saveData(): Promise<void> {\n    const url = this.buildUrl('/data/save');\n    await firstValueFrom(this.http.post(url, {}));\n    this.dirty$.next(false);\n  }\n\n  /**\n   * Revert data.\n   * Implements: service_method(\"PlanningModel\", \"revertData\", \"void\", \"async\")\n   */\n  async revertData(): Promise<void> {\n    const url = this.buildUrl('/data/revert');\n    await firstValueFrom(this.http.post(url, {}));\n    this.dirty$.next(false);\n  }\n\n  /**\n   * Initialize with a model.\n   */\n  initialize(modelId: string): void {\n    this.currentModelId = modelId;\n    this.refreshVersions();\n    this.refreshLockStatus();\n  }\n\n  // ---------------------------------------------------------------------------\n  // Private methods\n  // ---------------------------------------------------------------------------\n\n  private async refreshVersions(): Promise<void> {\n    if (!this.currentModelId) return;\n    await this.getVersions();\n  }\n\n  private async refreshLockStatus(): Promise<void> {\n    if (!this.currentModelId) return;\n    try {\n      const url = this.buildUrl('/lock/status');\n      const status = await firstValueFrom(this.http.get<LockInfo>(url));\n      this.lockStatus$.next(status);\n    } catch {\n      this.lockStatus$.next(null);\n    }\n  }\n\n  private buildUrl(endpoint: string): string {\n    const base = this.config?.apiUrl || '';\n    return `${base}/api/v1/planning/models/${this.currentModelId}${endpoint}`;\n  }\n}"]},"resolvedIds":{"@angular/core":{"attributes":{},"external":true,"id":"@angular/core","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"rxjs":{"attributes":{},"external":true,"id":"rxjs","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"@nucleus/sac-ngx-core":{"attributes":{},"external":true,"id":"@nucleus/sac-ngx-core","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false},"@angular/common/http":{"attributes":{},"external":true,"id":"@angular/common/http","meta":{},"moduleSideEffects":true,"resolvedBy":"rollup","syntheticNamedExports":false}},"safeVariableNames":{"DataLockingScope":"DataLockingScope","SacPlanningModelService":"SacPlanningModelService"},"sourcemapChain":[],"syntheticNamedExports":false,"transformDependencies":[]},{"ast":{"type":"Program","start":0,"end":19227,"body":[{"type":"ImportDeclaration","start":155,"end":216,"specifiers":[{"type":"ImportSpecifier","start":164,"end":174,"imported":{"type":"Identifier","start":164,"end":174,"name":"Injectable"},"local":{"type":"Identifier","start":164,"end":174,"name":"Injectable"}},{"type":"ImportSpecifier","start":176,"end":182,"imported":{"type":"Identifier","start":176,"end":182,"name":"Inject"},"local":{"type":"Identifier","start":176,"end":182,"name":"Inject"}},{"type":"ImportSpecifier","start":184,"end":192,"imported":{"type":"Identifier","start":184,"end":192,"name":"Optional"},"local":{"type":"Identifier","start":184,"end":192,"name":"Optional"}}],"source":{"type":"Literal","start":200,"end":215,"value":"@angular/core","raw":"'@angular/core'"},"attributes":[]},{"type":"ImportDeclaration","start":217,"end":272,"specifiers":[{"type":"ImportSpecifier","start":226,"end":241,"imported":{"type":"Identifier",