# =============================================================================
# SAP SAC Web Components Angular — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SAP Analytics Cloud — widget deployment target
# -----------------------------------------------------------------------------
# Base URL of your SAC tenant (used by the widget harness and verify scripts).
SAC_BASE_URL=https://<your-tenant>.sapanalytics.cloud

# Story / app ID to embed in the widget harness for local testing.
SAC_STORY_ID=

# -----------------------------------------------------------------------------
# SAP AI Core — generative AI features (sac-ai-widget)
# -----------------------------------------------------------------------------
AICORE_CLIENT_ID=
AICORE_CLIENT_SECRET=
AICORE_AUTH_URL=https://<your-aicore-auth>.authentication.eu10.hana.ondemand.com/oauth/token
AICORE_BASE_URL=https://api.ai.internalprod.eu-central-1.aws.ml.hana.ondemand.com/v2
AICORE_RESOURCE_GROUP=default

# Deployment IDs for the LLM endpoints used by the SAC AI widget.
AICORE_DEPLOYMENT_ID_CHAT=

# -----------------------------------------------------------------------------
# Nx Cloud remote cache (CI only)
# -----------------------------------------------------------------------------
# Read-only access token. Set in CI secrets; do NOT hardcode here.
NX_CLOUD_ACCESS_TOKEN=
