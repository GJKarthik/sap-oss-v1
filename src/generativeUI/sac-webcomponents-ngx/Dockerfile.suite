FROM node:20-slim AS build

WORKDIR /workspace

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build:widget

FROM nginx:1.27-alpine

COPY docker/nginx-suite.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/dist /usr/share/nginx/html/dist
COPY --from=build /workspace/harness /usr/share/nginx/html/harness

EXPOSE 80
