upstream health_aggregator {
  server health-aggregator:8090;
}
upstream aifabric_web {
  server aifabric-web:80;
}
upstream training_web {
  server training-web:80;
}
upstream sac_web {
  server sac-web:80;
}
upstream ui5_web {
  server ui5-web:80;
}
upstream ui5_mcp {
  server ui5-mcp:9160;
}
upstream aifabric_api {
  server aifabric-api:8000;
}
upstream training_api {
  server training-api:8000;
}

server {
    listen 80;
    server_name _;

    location = / {
      default_type text/html;
      return 200 '<!doctype html><html><head><title>SAP AI Open Source Suite</title></head><body><h1>SAP AI Open Source Suite</h1><ul><li><a href="/aifabric/">AI Fabric</a></li><li><a href="/training/">Training</a></li><li><a href="/sac/">SAC</a></li><li><a href="/ui5/">UI5</a></li><li><a href="/health">Global Health</a></li></ul></body></html>';
    }

    location = /health {
      proxy_pass http://health_aggregator/health;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
    }

    location = /health/details {
      proxy_pass http://health_aggregator/health/details;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
    }

    location /aifabric/ {
      proxy_pass http://aifabric_web/;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header Accept-Encoding "";
      sub_filter_types text/html;
      sub_filter_once off;
      sub_filter 'href="/' 'href="/aifabric/';
      sub_filter 'src="/' 'src="/aifabric/';
    }

    location /training/ {
      proxy_pass http://training_web/;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header Accept-Encoding "";
      sub_filter_types text/html;
      sub_filter_once off;
      sub_filter 'href="/' 'href="/training/';
      sub_filter 'src="/' 'src="/training/';
    }

    location /sac/ {
      proxy_pass http://sac_web/;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header Accept-Encoding "";
      sub_filter_types text/html;
      sub_filter_once off;
      sub_filter 'href="/' 'href="/sac/';
      sub_filter 'src="/' 'src="/sac/';
    }

    location /ui5/ {
      proxy_pass http://ui5_web/;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header Accept-Encoding "";
      sub_filter_types text/html;
      sub_filter_once off;
      sub_filter '<base href="/ui5/">' '<base href="/ui5/">';
      sub_filter 'href="/' 'href="/ui5/';
      sub_filter 'src="/' 'src="/ui5/';
    }

    location /ag-ui/ {
      proxy_pass http://ui5_mcp/;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header Authorization $http_authorization;
      proxy_buffering off;
      proxy_cache off;
      proxy_read_timeout 600s;
      chunked_transfer_encoding on;
    }

    location /collab/ {
      proxy_pass http://ui5_mcp/;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
    }

    location /api/v1/aifabric/ {
      rewrite ^/api/v1/aifabric/(.*)$ /$1 break;
      proxy_pass http://aifabric_api;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    # Legacy aliases (workspace / older clients) — same upstreams as /api/v1/*
    location /api/training/ {
      rewrite ^/api/training/(.*)$ /$1 break;
      proxy_pass http://training_api;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    location /api/openai/ {
      rewrite ^/api/openai/(.*)$ /$1 break;
      proxy_pass http://training_api;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    location /api/mcp/ {
      rewrite ^/api/mcp/(.*)$ /$1 break;
      proxy_pass http://ui5_mcp;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    location /api/v1/training/ {
      rewrite ^/api/v1/training/(.*)$ /$1 break;
      proxy_pass http://training_api;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    location /api/v1/sac/ {
      rewrite ^/api/v1/sac/(.*)$ /$1 break;
      proxy_pass http://sac_web;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    location /api/v1/ui5/mcp/ {
      rewrite ^/api/v1/ui5/mcp/(.*)$ /$1 break;
      proxy_pass http://ui5_mcp;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    location /api/v1/ui5/openai/ {
      rewrite ^/api/v1/ui5/openai/(.*)$ /$1 break;
      proxy_pass http://training_api;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    # External PAL MCP through gateway
    location /api/v1/ui5/pal/ {
      rewrite ^/api/v1/ui5/pal/(.*)$ /$1 break;
      proxy_pass ${AI_CORE_PAL_UPSTREAM};
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Correlation-ID $request_id;
    }

    location /api/v1/ui5/ {
      default_type application/json;
      return 400 '{"status":"bad_request","message":"Use /api/v1/ui5/mcp/*, /api/v1/ui5/openai/*, or /api/v1/ui5/pal/*"}';
    }
}
