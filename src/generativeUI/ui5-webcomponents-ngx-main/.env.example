# =============================================================================
# UI5 Web Components Angular — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Finding 4: CORS configuration (mcp-server/src/server.ts)
# -----------------------------------------------------------------------------
# Set to 1 only for fully isolated localhost development. In non-localhost mode
# the server now requires both MCP_AUTH_TOKEN and CORS_ALLOWED_ORIGINS.
MCP_LOCALHOST_ONLY=1
#
# Comma-separated list of allowed request origins for the MCP server.
# Required unless MCP_LOCALHOST_ONLY=1.
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Set to 1/true/yes to allow ALL origins (development only — never in prod).
MCP_ALLOW_ALL_ORIGINS=

# -----------------------------------------------------------------------------
# Finding 1: Mangle query service endpoint
# -----------------------------------------------------------------------------
# HTTP(S) URL of the Mangle reasoning engine. If unset, mangle_query falls
# back to the local fact-store dict inside MangleEngine / MCPServer.
MANGLE_ENDPOINT=http://localhost:50051

# -----------------------------------------------------------------------------
# Finding 2 + 5: HANA Cloud REST SQL API (audit log + metrics persistence)
# -----------------------------------------------------------------------------
# All four variables must be set to activate HANA-backed persistence.
# If any are missing, audit entries and metrics remain in-memory only.
HANA_BASE_URL=https://<your-hana-instance>.hanacloud.ondemand.com
HANA_AUTH_URL=https://<your-oauth-server>/oauth/token
HANA_CLIENT_ID=
HANA_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Finding 6: Nx Cloud remote cache token
# -----------------------------------------------------------------------------
# Read-only Nx Cloud access token used for remote build-cache hits in CI.
# Set in CI secrets; do NOT hardcode here.
# Rotate the token at https://cloud.nx.app if this repository is forked
# or made public.
NX_CLOUD_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# SAP AI Core (OpenAI-compatible server — libs/openai-server)
# -----------------------------------------------------------------------------
AICORE_CLIENT_ID=
AICORE_CLIENT_SECRET=
AICORE_AUTH_URL=https://<your-aicore-auth>.authentication.eu10.hana.ondemand.com/oauth/token
AICORE_BASE_URL=https://api.ai.internalprod.eu-central-1.aws.ml.hana.ondemand.com/v2

# -----------------------------------------------------------------------------
# MCP Server authentication (mcp-server/src/server.ts)
# -----------------------------------------------------------------------------
# Bearer token required on POST /mcp. Generate with: openssl rand -hex 32
# Required unless MCP_LOCALHOST_ONLY=1.
MCP_AUTH_TOKEN=

# Python agent must set the same value to authenticate against the MCP server.
# (agent/ui5_ngx_agent.py reads this env var automatically)
# MCP_AUTH_TOKEN is shared by both server and agent — set once in your .env.

# -----------------------------------------------------------------------------
# OpenAI-compatible server internal token (libs/openai-server/src/server.ts)
# -----------------------------------------------------------------------------
# Required on X-Internal-Token header for all /v1/hana/* routes.
# Generate with: openssl rand -hex 32
#
# Set to 1 only for fully isolated localhost development. In non-localhost mode
# both OPENAI_INTERNAL_TOKEN and OPENAI_OCR_INTERNAL_TOKEN are required, and
# OPENAI_ALLOWED_ORIGINS must be explicitly configured.
OPENAI_LOCALHOST_ONLY=1
OPENAI_INTERNAL_TOKEN=

# OCR route token. Clients must send X-OCR-Token for:
#   POST /v1/ocr/documents
#   GET  /v1/ocr/documents
#   GET  /v1/ocr/documents/:id
# Required unless OPENAI_LOCALHOST_ONLY=1. Generate with: openssl rand -hex 32
OPENAI_OCR_INTERNAL_TOKEN=

# Optional OCR upload guardrails
# Max decoded upload size in bytes for file_content_base64 (default: 5242880 / 5MB)
OPENAI_OCR_MAX_UPLOAD_BYTES=5242880
# Comma-separated allowed mime types for OCR uploads
OPENAI_OCR_ALLOWED_MIME_TYPES=text/plain,application/pdf,image/png,image/jpeg,image/webp

# Comma-separated allowed CORS origins for the OpenAI-compat server.
# Required unless OPENAI_LOCALHOST_ONLY=1.
OPENAI_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# -----------------------------------------------------------------------------
# KùzuDB graph database (mcp-server — graph-RAG features)
# -----------------------------------------------------------------------------
# Path to the KùzuDB database directory.
# Use ':memory:' (default) for ephemeral in-memory storage (dev/test).
# Set to a filesystem path for persistence across server restarts.
KUZU_DB_PATH=:memory:
