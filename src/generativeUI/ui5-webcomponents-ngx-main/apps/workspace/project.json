{
  "name": "workspace",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/workspace/src",
  "prefix": "ui-angular",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/workspace",
        "index": "apps/workspace/src/index.html",
        "main": "apps/workspace/src/main.ts",
        "polyfills": "apps/workspace/src/polyfills.ts",
        "tsConfig": "apps/workspace/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/workspace/src/favicon.ico",
          "apps/workspace/src/assets"
        ],
        "styles": ["apps/workspace/src/styles.scss"],
        "scripts": [],
        "allowedCommonJsDependencies": ["@zxing/library"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "5mb",
              "maximumError": "10mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/workspace/src/environments/environment.ts",
              "with": "apps/workspace/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all",
          "optimization": true,
          "buildOptimizer": true,
          "vendorChunk": true,
          "extractLicenses": true,
          "namedChunks": true
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "workspace:build:production"
        },
        "development": {
          "buildTarget": "workspace:build:development",
          "proxyConfig": "apps/workspace/proxy.conf.js"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "workspace:build"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/workspace"],
      "options": {
        "jestConfig": "apps/workspace/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
