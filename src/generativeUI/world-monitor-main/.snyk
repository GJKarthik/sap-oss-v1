# Snyk (https://snyk.io) policy file
version: v1.25.0

ignore:
  # ── analytics.ts: hardcoded "secrets" are short analytics property name aliases ──
  # e.g. 'groq', 'fred', 'eia' — not credentials; values are analytics event key names.
  SNYK-JS-*:
    - world-monitor > src/services/analytics.ts:
        reason: >
          SECRET_ANALYTICS_NAMES values ('groq', 'fred', 'eia', etc.) are
          PostHog event property name aliases, not credentials or secrets.
          Snyk misclassifies short identifier strings as hardcoded secrets.
        expires: 2027-03-07T00:00:00.000Z

  # ── RuntimeConfigPanel.ts: SIGNUP_URLS are public documentation URLs ──
  SNYK-CODE-SECRET-HARDCODED-*:
    - world-monitor > src/components/RuntimeConfigPanel.ts:
        reason: >
          SIGNUP_URLS values are public sign-up page URLs (e.g.
          https://console.groq.com/keys). Not credentials. Snyk flags any
          string containing 'key' or 'token' in a URL as a hardcoded secret.
        expires: 2027-03-07T00:00:00.000Z

  # ── RuntimeConfigPanel.ts line 570-572: DOM XSS — already escaped ──
  SNYK-CODE-XSS-DOM-*:
    - world-monitor > src/components/RuntimeConfigPanel.ts:
        reason: >
          Both value="" and text content in the <option> template at line
          570-572 are wrapped in escapeHtml(). Snyk does not track the
          escapeHtml() sanitizer call. False positive.
        expires: 2027-03-07T00:00:00.000Z

  # ── local-api-server.mjs: SSRF — fetchWithTimeout receives allowlisted URLs only ──
  SNYK-CODE-SSRF-*:
    - world-monitor > src-tauri/sidecar/local-api-server.mjs:
        reason: >
          fetchWithTimeout() is an internal helper; all callers (proxyToCloud,
          route handlers) validate URLs against an allowlist before passing
          them in. The function itself is not exposed to raw user input.
          Lines 454-456 are inside the HTTPS branch that reads from the
          already-parsed URL object. False positive.
        expires: 2027-03-07T00:00:00.000Z

  # ── local-api-server.mjs: HTTP server — localhost sidecar by design ──
  SNYK-CODE-CLEARTEXT-*:
    - world-monitor > src-tauri/sidecar/local-api-server.mjs:
        reason: >
          This is a Tauri desktop sidecar that listens on 127.0.0.1 only.
          HTTP on loopback is intentional and standard practice; TLS on
          localhost provides no security benefit and breaks Tauri IPC.
        expires: 2027-03-07T00:00:00.000Z
    - world-monitor > scripts/ais-relay.cjs:
        reason: >
          ais-relay.cjs is a development/Railway relay script. The HTTP
          server listens on a controlled port; upstream fetches use https://
          for all external sources (gated by protocol check). The plain
          http.get path is only reached for already-validated URLs.
        expires: 2027-03-07T00:00:00.000Z

  # ── local-api-server.mjs line 985-1047: resource throttling on localhost ──
  SNYK-CODE-THROTTLING-*:
    - world-monitor > src-tauri/sidecar/local-api-server.mjs:
        reason: >
          localhost-only sidecar with a single trusted client (the Tauri
          renderer). DoS from resource exhaustion is not a realistic threat
          model for a local desktop process.
        expires: 2027-03-07T00:00:00.000Z

  # ── node_modules findings — third-party, not actionable ──
  SNYK-JS-CARTO-*:
    - world-monitor > node_modules/@carto/api-client:
        reason: Third-party dep. ReDoS in basemap.ts; no patch available upstream.
        expires: 2026-09-07T00:00:00.000Z
  SNYK-JS-DECKGLCARTO-*:
    - world-monitor > node_modules/@deck.gl/carto:
        reason: Third-party dep. Same ReDoS as @carto/api-client; bundled copy.
        expires: 2026-09-07T00:00:00.000Z
  SNYK-JS-UPSTASHREDIS-*:
    - world-monitor > node_modules/@upstash/redis:
        reason: >
          SSRF in @upstash/redis internal HTTP client. The URL it fetches is
          the configured Redis REST endpoint from env vars, not user input.
          Not exploitable in this deployment.
        expires: 2026-09-07T00:00:00.000Z
  SNYK-JS-WORKBOXROUTING-*:
    - world-monitor > node_modules/workbox-routing:
        reason: Third-party service worker routing lib in node_modules. Not first-party code.
        expires: 2026-09-07T00:00:00.000Z
