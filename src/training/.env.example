# =============================================================================
# training-main Environment Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# --- NVIDIA ModelOpt API Server ---

# API authentication (set REQUIRE_AUTH=true to enforce)
MODELOPT_API_KEY=
MODELOPT_REQUIRE_AUTH=false

# Server binding
HOST=0.0.0.0
PORT=8001
WORKERS=1
LOG_LEVEL=info

# Hugging Face token (for downloading gated models)
HF_TOKEN=

# --- HippoCPP Graph Database ---

# Backend mode: native-python | upstream-kuzu | auto
HIPPOCPP_BACKEND_MODE=auto

# Semantic backend module (Python import path)
HIPPOCPP_SEMANTIC_BACKEND=hippocpp.native_zig

# Allow fallback to upstream kuzu when native backend is unavailable
HIPPOCPP_ALLOW_KUZU_FALLBACK=0

# Path to Zig executable (leave empty to use system zig)
HIPPOCPP_ZIG_BIN=

# Path to Zig engine source (leave empty for default)
HIPPOCPP_ZIG_ENGINE_SOURCE=

# Database root directory (leave empty for ephemeral temp dirs)
DB_ROOT=

