# =============================================================================
# training-main Environment Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# --- NVIDIA ModelOpt API Server ---

# API authentication (set REQUIRE_AUTH=true to enforce)
MODELOPT_API_KEY=
MODELOPT_REQUIRE_AUTH=false

# Server binding
HOST=0.0.0.0
PORT=8001
WORKERS=1
LOG_LEVEL=info

# Hugging Face token (for downloading gated models)
HF_TOKEN=

# --- SAP HANA Cloud ---

# HANA Cloud connection
HANA_HOST=your-hana-instance.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_SCHEMA=PAL_STORE
HANA_ENCRYPT=true
HANA_SSL_VALIDATE=true

# Embedding configuration
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MODEL=text-embedding-ada-002

