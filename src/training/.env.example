# =============================================================================
# training-main Environment Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# --- NVIDIA ModelOpt API Server ---

# API authentication (set REQUIRE_AUTH=true to enforce)
MODELOPT_API_KEY=
MODELOPT_REQUIRE_AUTH=false

# Server binding
HOST=0.0.0.0
PORT=8001
WORKERS=1
LOG_LEVEL=info

# Hugging Face token (for downloading gated models)
HF_TOKEN=

# --- SAP HANA Cloud ---

# HANA Cloud connection (direct - if using hana_client.py)
HANA_HOST=your-hana-instance.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_SCHEMA=PAL_STORE
HANA_ENCRYPT=true
HANA_SSL_VALIDATE=true

# Embedding configuration
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MODEL=text-embedding-ada-002

# =============================================================================
# Simula Framework — HANA-Direct Training Data Pipeline
# =============================================================================

# --- HANA Schema Extraction via AI Core PAL MCP ---

# AI Core PAL MCP endpoint (external or in-cluster)
AICORE_PAL_MCP_URL=https://ai-core-pal.c-054c570.kyma.ondemand.com/mcp

# HANA schemas to extract (comma-separated)
HANA_SCHEMAS=PAL_STORE

# Optional: SQL LIKE pattern to filter table names
# HANA_TABLE_PATTERN=%FACT%

# MCP request timeout (seconds)
HANA_MCP_TIMEOUT=30

# --- vLLM TurboQuant (OpenAI-compatible API) ---

# vLLM TurboQuant endpoint
VLLM_BASE_URL=http://localhost:8000/v1

# Model name
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# LLM provider: vllm-turboquant, aicore, or openai
SIMULA_LLM_PROVIDER=vllm-turboquant

# Generation temperature
SIMULA_TEMPERATURE=0.7

# Max tokens per generation
SIMULA_MAX_TOKENS=2048

# Max concurrent LLM requests
SIMULA_MAX_CONCURRENT=8

# --- Taxonomy Generation (Algorithm 1) ---

# Maximum taxonomy tree depth
SIMULA_TAXONOMY_DEPTH=3

# Best-of-N sampling count for node proposals
SIMULA_BEST_OF_N=5

# Enable critic refinement step
SIMULA_ENABLE_CRITIC=true

# Enable level planning for consistent granularity
SIMULA_ENABLE_LEVEL_PLANNING=true

# Optional: Directory to cache taxonomies
# SIMULA_TAXONOMY_CACHE=data/taxonomy_cache

# --- Data Generation (Algorithm 2) ---

# Target number of training examples
SIMULA_TARGET_COUNT=100000

# Fraction of examples to complexify (0.0 - 1.0)
SIMULA_COMPLEXITY_RATIO=0.5

# Number of meta-prompts per taxonomy mix
SIMULA_META_PROMPTS_PER_MIX=3

# Enable double-critic filtering
SIMULA_ENABLE_GEN_CRITIC=true

# Max retries for critic rejection
SIMULA_MAX_CRITIC_RETRIES=3

# Output directory
SIMULA_OUTPUT_DIR=data/hana_generated

# Output format (jsonl or json)
SIMULA_OUTPUT_FORMAT=jsonl

# Random seed for reproducibility
SIMULA_SEED=42

# =============================================================================
# Simula Evaluation Framework (Section 2.3, 3.1, 3.3 from 6171 paper)
# =============================================================================

# --- Complexity Calibration (Algorithm 3, Appendix E.3) ---

# Batch size for relative scoring (BS parameter)
# BS=5 found optimal in Figure 10
SIMULA_COMPLEXITY_BATCH_SIZE=5

# Number of times each example appears in batches (N parameter)
# N=5 found optimal in Figure 10
SIMULA_COMPLEXITY_N_SAMPLES=5

# Enable Elo-based calibration (vs. raw score averaging)
SIMULA_COMPLEXITY_ENABLE_ELO=true

# --- Taxonomic Coverage Evaluation (Section 2.3, Figure 4) ---

# Maximum taxonomy level for coverage evaluation
SIMULA_COVERAGE_MAX_LEVEL=4

# Sample size for coverage evaluation (0 = all examples)
SIMULA_COVERAGE_SAMPLE_SIZE=1000

# --- Diversity Metrics (Section 3.3) ---

# Embedding model for diversity analysis
# Paper uses Gecko (Lee et al. 2024b)
SIMULA_DIVERSITY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# K for k-nearest neighbors in local diversity
SIMULA_DIVERSITY_KNN=10

# --- Critic Validation (Section 3.1, Figure 3) ---

# Fraction of dataset to use for critic validation
SIMULA_CRITIC_VALIDATION_SPLIT=0.05

# Maximum samples for critic validation
SIMULA_CRITIC_MAX_SAMPLES=200

# --- Student-Teacher Gap Analysis (Section 4.3) ---

# Teacher model (used for synthetic data generation)
SIMULA_TEACHER_MODEL=Qwen/Qwen3.5-35B

# Student model (target for fine-tuning)
SIMULA_STUDENT_MODEL=google/gemma-3-4b

# Teacher accuracy on target task (0-1, leave blank if unknown)
# SIMULA_TEACHER_ACCURACY=0.70

# Student baseline accuracy (0-1, leave blank if unknown)
# SIMULA_STUDENT_BASELINE=0.40

# Empirical saturation ratio from paper
# (student bridges this fraction of the performance gap)
SIMULA_SATURATION_RATIO=0.83

# =============================================================================
# Adaptive Features (v1.2 — Address Review Gaps)
# =============================================================================

# --- Adaptive Complexity (Figure 7) ---

# Enable adaptive complexity ratio based on teacher strength
# When teacher accuracy < 60%, reduces complexity ratio to 0.2
SIMULA_ADAPTIVE_COMPLEXITY=true

# --- Adaptive Critic Thresholding (Figure 3b) ---

# Enable complexity-aware critic rejection threshold
# Higher complexity = more conservative threshold
SIMULA_CRITIC_ADAPTIVE_THRESHOLD=true

# Base critic threshold for acceptance
SIMULA_CRITIC_THRESHOLD=0.5

# --- Taxonomy Quality Gates (Section B.1, Table 2) ---

# Minimum completeness for taxonomy validation
SIMULA_TAXONOMY_MIN_COMPLETENESS=0.7

# Minimum soundness for taxonomy validation
SIMULA_TAXONOMY_MIN_SOUNDNESS=0.9

# --- Diversity Optimizer (Section 3.3, Figure 4) ---

# Target global diversity (pairwise cosine distance)
SIMULA_DIVERSITY_TARGET_GLOBAL=0.52

# Target local diversity (k-NN cosine distance)
SIMULA_DIVERSITY_TARGET_LOCAL=0.20

# Tolerance for diversity optimization
SIMULA_DIVERSITY_TOLERANCE=0.05

# Learning rate for weight adjustments
SIMULA_DIVERSITY_LEARNING_RATE=0.1

