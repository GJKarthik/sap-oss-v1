{
  "name": "cypher-errors",
  "description": "Queries expected to produce errors — verify both backends reject the same inputs.",
  "cases": [
    {
      "name": "unknown_table",
      "ordered": true,
      "setup": [],
      "query": "MATCH (x:NoSuchTable) RETURN x",
      "expect_error": true
    },
    {
      "name": "unknown_property",
      "ordered": true,
      "setup": [
        "CREATE NODE TABLE Person(name STRING, PRIMARY KEY(name))",
        "CREATE (:Person {name: 'A'})"
      ],
      "query": "MATCH (p:Person) RETURN p.nonexistent",
      "expect_error": true
    },
    {
      "name": "syntax_error_missing_return",
      "ordered": true,
      "setup": [],
      "query": "MATCH (p:Person)",
      "expect_error": true
    },
    {
      "name": "syntax_error_unclosed_paren",
      "ordered": true,
      "setup": [],
      "query": "MATCH (p:Person RETURN p.name",
      "expect_error": true
    },
    {
      "name": "type_mismatch_filter",
      "ordered": true,
      "setup": [
        "CREATE NODE TABLE Person(name STRING, age INT64, PRIMARY KEY(name))",
        "CREATE (:Person {name: 'A', age: 30})"
      ],
      "query": "MATCH (p:Person) WHERE p.age = 'thirty' RETURN p.name",
      "expect_error": true
    },
    {
      "name": "duplicate_primary_key",
      "ordered": true,
      "setup": [
        "CREATE NODE TABLE Person(name STRING, PRIMARY KEY(name))",
        "CREATE (:Person {name: 'A'})"
      ],
      "query": "CREATE (:Person {name: 'A'})",
      "expect_error": true
    },
    {
      "name": "empty_query",
      "ordered": true,
      "setup": [],
      "query": "",
      "expect_error": true
    },
    {
      "name": "create_existing_table",
      "ordered": true,
      "setup": [
        "CREATE NODE TABLE T(id INT64, PRIMARY KEY(id))"
      ],
      "query": "CREATE NODE TABLE T(id INT64, PRIMARY KEY(id))",
      "expect_error": true
    }
  ]
}

