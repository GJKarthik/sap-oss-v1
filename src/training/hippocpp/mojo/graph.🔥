from collections import Dict, List
from common import LogicalType, InternalID, Value

# ============================================================================
# Property Value
# ============================================================================

@value
struct PropertyValue:
    """Property value for graph entries"""
    var value_type: Int  # 0=null, 1=bool, 2=int, 3=float, 4=string
    var bool_val: Bool
    var int_val: Int64
    var float_val: Float64
    var string_val: String
    
    fn __init__(inout self):
        self.value_type = 0
        self.bool_val = False
        self.int_val = 0
        self.float_val = 0.0
        self.string_val = ""
    
    @staticmethod
    fn null_value() -> PropertyValue:
        return PropertyValue()
    
    @staticmethod
    fn boolean(val: Bool) -> PropertyValue:
        var v = PropertyValue()
        v.value_type = 1
        v.bool_val = val
        return v
    
    @staticmethod
    fn integer(val: Int64) -> PropertyValue:
        var v = PropertyValue()
        v.value_type = 2
        v.int_val = val
        return v
    
    @staticmethod
    fn double(val: Float64) -> PropertyValue:
        var v = PropertyValue()
        v.value_type = 3
        v.float_val = val
        return v
    
    @staticmethod
    fn from_string(val: String) -> PropertyValue:
        var v = PropertyValue()
        v.value_type = 4
        v.string_val = val
        return v
    
    fn is_null(self) -> Bool:
        return self.value_type == 0


# ============================================================================
# Node Label
# ============================================================================

struct NodeLabel:
    """Node label definition"""
    var name: String
    var table_id: UInt64
    var properties: List[PropertyDef]
    
    fn __init__(inout self, name: String, table_id: UInt64):
        self.name = name
        self.table_id = table_id
        self.properties = List[PropertyDef]()
    
    fn add_property(inout self, prop: PropertyDef):
        self.properties.append(prop)
    
    fn get_num_properties(self) -> Int:
        return len(self.properties)


# ============================================================================
# Property Definition
# ============================================================================

@value
struct PropertyDef:
    """Property definition for nodes/edges"""
    var name: String
    var data_type: LogicalType
    var is_primary_key: Bool
    
    fn __init__(inout self, name: String, data_type: LogicalType):
        self.name = name
        self.data_type = data_type
        self.is_primary_key = False
    
    @staticmethod
    fn primary(name: String, data_type: LogicalType) -> PropertyDef:
        var p = PropertyDef(name, data_type)
        p.is_primary_key = True
        return p


# ============================================================================
# Relationship Type
# ============================================================================

struct RelType:
    """Relationship type definition"""
    var name: String
    var table_id: UInt64
    var src_label: String
    var dst_label: String
    var properties: List[PropertyDef]
    
    fn __init__(inout self, name: String, table_id: UInt64, src: String, dst: String):
        self.name = name
        self.table_id = table_id
        self.src_label = src
        self.dst_label = dst
        self.properties = List[PropertyDef]()
    
    fn add_property(inout self, prop: PropertyDef):
        self.properties.append(prop)


# ============================================================================
# Graph Entry
# ============================================================================

@value
struct GraphEntryType:
    """Graph entry type"""
    var value: Int
    
    alias NODE = GraphEntryType(0)
    alias EDGE = GraphEntryType(1)
    
    fn __init__(inout self, value: Int):
        self.value = value
    
    fn __eq__(self, other: GraphEntryType) -> Bool:
        return self.value == other.value


struct GraphEntry:
    """Represents a node or edge in result"""
    var id: InternalID
    var entry_type: GraphEntryType
    var label: String
    var properties: Dict[String, PropertyValue]
    
    fn __init__(inout self, id: InternalID, entry_type: GraphEntryType, label: String):
        self.id = id
        self.entry_type = entry_type
        self.label = label
        self.properties = Dict[String, PropertyValue]()
    
    @staticmethod
    fn node(id: InternalID, label: String) -> GraphEntry:
        return GraphEntry(id, GraphEntryType.NODE, label)
    
    @staticmethod
    fn edge(id: InternalID, label: String) -> GraphEntry:
        return GraphEntry(id, GraphEntryType.EDGE, label)
    
    fn set_property(inout self, name: String, value: PropertyValue):
        self.properties[name] = value
    
    fn get_property(self, name: String) -> PropertyValue:
        if name in self.properties:
            return self.properties[name]
        return PropertyValue.null_value()
    
    fn is_node(self) -> Bool:
        return self.entry_type == GraphEntryType.NODE
    
    fn is_edge(self) -> Bool:
        return self.entry_type == GraphEntryType.EDGE


# ============================================================================
# Path
# ============================================================================

struct Path:
    """Path in graph - sequence of nodes and edges"""
    var nodes: List[GraphEntry]
    var edges: List[GraphEntry]
    
    fn __init__(inout self):
        self.nodes = List[GraphEntry]()
        self.edges = List[GraphEntry]()
    
    fn add_node(inout self, node: GraphEntry):
        self.nodes.append(node)
    
    fn add_edge(inout self, edge: GraphEntry):
        self.edges.append(edge)
    
    fn length(self) -> Int:
        """Path length = number of edges"""
        return len(self.edges)
    
    fn get_start_node(self) -> GraphEntry:
        if len(self.nodes) > 0:
            return self.nodes[0]
        return GraphEntry(InternalID.invalid(), GraphEntryType.NODE, "")
    
    fn get_end_node(self) -> GraphEntry:
        if len(self.nodes) > 0:
            return self.nodes[len(self.nodes) - 1]
        return GraphEntry(InternalID.invalid(), GraphEntryType.NODE, "")


# ============================================================================
# Graph Schema
# ============================================================================

struct GraphSchema:
    """Schema for graph database"""
    var node_labels: Dict[String, NodeLabel]
    var rel_types: Dict[String, RelType]
    
    fn __init__(inout self):
        self.node_labels = Dict[String, NodeLabel]()
        self.rel_types = Dict[String, RelType]()
    
    fn add_node_label(inout self, label: NodeLabel):
        self.node_labels[label.name] = label
    
    fn add_rel_type(inout self, rel: RelType):
        self.rel_types[rel.name] = rel
    
    fn get_node_label(self, name: String) -> NodeLabel:
        if name in self.node_labels:
            return self.node_labels[name]
        return NodeLabel("", 0)
    
    fn get_rel_type(self, name: String) -> RelType:
        if name in self.rel_types:
            return self.rel_types[name]
        return RelType("", 0, "", "")
    
    fn has_node_label(self, name: String) -> Bool:
        return name in self.node_labels
    
    fn has_rel_type(self, name: String) -> Bool:
        return name in self.rel_types


# ============================================================================
# Graph
# ============================================================================

struct Graph:
    """Main graph interface"""
    var name: String
    var schema: GraphSchema
    var next_node_id: UInt64
    var next_edge_id: UInt64
    
    fn __init__(inout self, name: String):
        self.name = name
        self.schema = GraphSchema()
        self.next_node_id = 0
        self.next_edge_id = 0
    
    fn create_node_label(inout self, name: String):
        """Create a new node label"""
        let table_id = self.next_node_id
        self.next_node_id += 1
        
        let label = NodeLabel(name, table_id)
        self.schema.add_node_label(label)
    
    fn create_rel_type(inout self, name: String, src: String, dst: String):
        """Create a new relationship type"""
        let table_id = self.next_edge_id
        self.next_edge_id += 1
        
        let rel = RelType(name, table_id, src, dst)
        self.schema.add_rel_type(rel)
    
    fn has_node_label(self, name: String) -> Bool:
        return self.schema.has_node_label(name)
    
    fn has_rel_type(self, name: String) -> Bool:
        return self.schema.has_rel_type(name)
    
    fn get_num_node_labels(self) -> Int:
        return len(self.schema.node_labels)
    
    fn get_num_rel_types(self) -> Int:
        return len(self.schema.rel_types)


# ============================================================================
# Pattern Matching (Cypher-style)
# ============================================================================

@value
struct Direction:
    """Edge direction in pattern"""
    var value: Int
    
    alias FORWARD = Direction(0)   # ->
    alias BACKWARD = Direction(1)  # <-
    alias BOTH = Direction(2)      # --
    
    fn __init__(inout self, value: Int):
        self.value = value


struct NodePattern:
    """Pattern for matching nodes"""
    var variable: String
    var labels: List[String]
    var properties: Dict[String, PropertyValue]
    
    fn __init__(inout self):
        self.variable = ""
        self.labels = List[String]()
        self.properties = Dict[String, PropertyValue]()
    
    fn set_variable(inout self, name: String):
        self.variable = name
    
    fn add_label(inout self, label: String):
        self.labels.append(label)
    
    fn add_property(inout self, name: String, value: PropertyValue):
        self.properties[name] = value
    
    fn matches(self, entry: GraphEntry) -> Bool:
        """Check if entry matches this pattern"""
        # Check labels
        for lbl in self.labels:
            if entry.label != lbl[]:
                return False
        
        # Check properties
        for item in self.properties.items():
            let entry_val = entry.properties.get(item[].key)
            if entry_val is None:
                return False
        
        return True


struct EdgePattern:
    """Pattern for matching edges"""
    var variable: String
    var types: List[String]
    var direction: Direction
    var min_length: Int
    var max_length: Int
    var properties: Dict[String, PropertyValue]
    
    fn __init__(inout self, direction: Direction = Direction.FORWARD):
        self.variable = ""
        self.types = List[String]()
        self.direction = direction
        self.min_length = 1
        self.max_length = 1
        self.properties = Dict[String, PropertyValue]()
    
    fn set_variable(inout self, name: String):
        self.variable = name
    
    fn add_type(inout self, rel_type: String):
        self.types.append(rel_type)
    
    fn set_length_range(inout self, min_len: Int, max_len: Int):
        self.min_length = min_len
        self.max_length = max_len
    
    fn is_variable_length(self) -> Bool:
        return self.min_length != self.max_length or self.max_length != 1


