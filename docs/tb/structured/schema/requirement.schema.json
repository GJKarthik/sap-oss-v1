{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sap-oss.local/schemas/tb/requirement.schema.json",
  "title": "TB Business Requirement",
  "description": "A single business requirement record sourced from a business case document.",
  "type": "object",
  "required": ["requirementId", "version", "title", "status", "scope", "processSteps"],
  "additionalProperties": false,
  "properties": {
    "requirementId": {"type": "string"},
    "version": {"type": "string"},
    "title": {"type": "string"},
    "createdBy": {"type": "string"},
    "createdOn": {"type": "string", "format": "date"},
    "status": {"type": "string", "enum": ["draft", "review", "approved", "rejected", "superseded"]},
    "source": {
      "type": "object",
      "required": ["file"],
      "additionalProperties": false,
      "properties": {
        "file": {"type": "string"},
        "extractedAt": {"type": "string", "format": "date"}
      }
    },
    "executiveSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {"type": "string"},
        "fteImpact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "currentEffort": {"type": "string"},
            "expectedSavings": {"type": "string"}
          }
        },
        "investmentRequired": {"type": "string"},
        "solution": {"type": "string"}
      }
    },
    "scope": {
      "type": "object",
      "required": ["inScope"],
      "additionalProperties": false,
      "properties": {
        "description": {"type": "string"},
        "legalEntities": {"type": "integer", "minimum": 0},
        "inScope": {"type": "array", "items": {"type": "string"}},
        "outOfScope": {"type": "array", "items": {"type": "string"}},
        "countries": {"type": "array", "items": {"type": "string"}},
        "reportingDimensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "current": {"type": "array", "items": {"type": "string"}},
            "target": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role"],
        "additionalProperties": false,
        "properties": {
          "role": {"type": "string"},
          "name": {"type": "string"},
          "responsibilities": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "processSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stepId", "name", "description"],
        "additionalProperties": false,
        "properties": {
          "stepId": {"type": "string"},
          "name": {"type": "string"},
          "timing": {"type": "string"},
          "description": {"type": "string"},
          "inputs": {"type": "array", "items": {"type": "string"}},
          "outputs": {"type": "array", "items": {"type": "string"}},
          "systems": {"type": "array", "items": {"type": "string"}},
          "participant": {"type": "string"},
          "manualEffort": {"type": "string", "enum": ["low", "medium", "high", "very high"]},
          "aiAugmentationOpportunity": {"type": "string"},
          "aiPriority": {"type": "string", "enum": ["low", "medium", "high", "critical"]}
        }
      }
    },
    "decisionPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decisionId", "name"],
        "additionalProperties": false,
        "properties": {
          "decisionId": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "currentApproach": {"type": "string"},
          "aiApproach": {"type": "string"}
        }
      }
    },
    "kpiRefs": {"type": "array", "items": {"type": "string"}},
    "controlRefs": {"type": "array", "items": {"type": "string"}},
    "riskAssessment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["riskId", "description", "severity"],
        "additionalProperties": false,
        "properties": {
          "riskId": {"type": "string"},
          "category": {"type": "string"},
          "description": {"type": "string"},
          "severity": {"type": "string", "enum": ["L", "M", "H"]},
          "owner": {"type": "string"},
          "mitigation": {"type": "string"}
        }
      }
    },
    "implementationPlan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalDuration": {"type": "string"},
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase", "name", "duration"],
            "additionalProperties": false,
            "properties": {
              "phase": {"type": "integer"},
              "name": {"type": "string"},
              "duration": {"type": "string"},
              "activities": {"type": "array", "items": {"type": "string"}},
              "milestones": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "projectObjectives": {"type": "array", "items": {"type": "string"}},
    "nonFinancialBenefits": {"type": "array", "items": {"type": "string"}}
  }
}
