{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sap-oss.github.io/schema/tb/variance-record.schema.json",
  "title": "Variance Record",
  "description": "Schema for variance records produced by Stage 2 anomaly detection (Chapter 3 of TB spec)",
  "type": "object",
  "required": ["variance_id", "account_code", "period", "variance_amount", "flags"],
  "properties": {
    "variance_id": {
      "type": "string",
      "description": "Unique identifier for this variance record"
    },
    "extract_id": {
      "type": "string",
      "description": "Reference to source TB/PL extract"
    },
    "account_code": {
      "type": "string",
      "description": "GL account code"
    },
    "account_name": {
      "type": "string",
      "description": "GL account name"
    },
    "account_category": {
      "type": "string",
      "enum": ["ASSET", "LIABILITY", "EQUITY", "REVENUE", "EXPENSE", "INTERCOMPANY"],
      "description": "Account category per docs/schema/common/enums.yaml"
    },
    "finance_caption": {
      "type": "string",
      "description": "Financial statement caption"
    },
    "segment": {
      "type": "string",
      "description": "Business segment"
    },
    "legal_entity": {
      "type": "string",
      "description": "Legal entity code"
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$",
      "description": "Accounting period (YYYY-MM format)"
    },
    "current_balance": {
      "type": "number",
      "description": "Current period balance"
    },
    "prior_balance": {
      "type": "number",
      "description": "Prior period balance"
    },
    "variance_amount": {
      "type": "number",
      "description": "Absolute variance (current - prior)"
    },
    "variance_percent": {
      "type": "number",
      "description": "Variance as percentage of prior"
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["PERIOD_SPIKE", "SIGN_FLIP", "NEW_ACCOUNT", "STALE_BALANCE"]
      },
      "description": "Anomaly flags per docs/schema/common/enums.yaml"
    },
    "anomaly_detection": {
      "$ref": "#/definitions/anomaly_detection",
      "description": "Anomaly detection details"
    },
    "materiality_assessment": {
      "$ref": "#/definitions/materiality_assessment",
      "description": "Materiality threshold assessment (DP-001)"
    },
    "journal_status": {
      "type": "string",
      "enum": ["posted", "posting_required", "not_posted"],
      "description": "Related journal posting status (DP-002)"
    },
    "journal_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Related journal entry IDs"
    },
    "investigation_status": {
      "type": "string",
      "enum": ["not_required", "pending", "in_progress", "completed"],
      "description": "Investigation status (DP-003)"
    },
    "confirmation_received": {
      "type": "boolean",
      "description": "Whether confirmation received by M+4 deadline (DP-004)"
    },
    "days_to_deadline": {
      "type": "integer",
      "description": "Days remaining to M+4 deadline"
    },
    "is_unexplained": {
      "type": "boolean",
      "default": false,
      "description": "Whether variance remains unexplained (DP-005)"
    },
    "unexplained_category": {
      "type": "string",
      "enum": ["substantiated_at_risk", "unsubstantiated_unowned", "unsubstantiated_owned"],
      "description": "BSS risk category for unexplained variances"
    },
    "workflow_state": {
      "type": "string",
      "description": "Current workflow state ID"
    },
    "metadata": {
      "$ref": "https://sap-oss.github.io/schema/common/base-types.schema.json#/definitions/Metadata",
      "description": "Record metadata"
    }
  },
  "definitions": {
    "anomaly_detection": {
      "type": "object",
      "description": "Anomaly detection results per Table 3.1 of TB spec",
      "properties": {
        "period_spike": {
          "$ref": "#/definitions/period_spike_check",
          "description": "Period spike check (3σ over prior 12 months)"
        },
        "sign_flip": {
          "$ref": "#/definitions/sign_flip_check",
          "description": "Sign flip check"
        },
        "new_account": {
          "$ref": "#/definitions/new_account_check",
          "description": "New account check"
        },
        "stale_balance": {
          "$ref": "#/definitions/stale_balance_check",
          "description": "Stale balance check"
        },
        "detection_method": {
          "type": "string",
          "enum": ["parametric_zscore", "mad_zscore", "percentile", "hybrid"],
          "default": "parametric_zscore",
          "description": "Statistical method used (see Phase 3 robust alternatives)"
        },
        "normality_test": {
          "$ref": "#/definitions/normality_test",
          "description": "Normality test results (Shapiro-Wilk)"
        }
      }
    },
    "period_spike_check": {
      "type": "object",
      "properties": {
        "triggered": {
          "type": "boolean",
          "description": "Whether check was triggered"
        },
        "z_score": {
          "type": "number",
          "description": "Z-score of current variance"
        },
        "threshold": {
          "type": "number",
          "default": 3.0,
          "description": "Z-score threshold (default: 3σ)"
        },
        "historical_mean": {
          "type": "number",
          "description": "Mean of prior 12 months"
        },
        "historical_std": {
          "type": "number",
          "description": "Standard deviation of prior 12 months"
        },
        "historical_mad": {
          "type": "number",
          "description": "Median Absolute Deviation (robust alternative)"
        },
        "mad_z_score": {
          "type": "number",
          "description": "MAD-based z-score (robust alternative)"
        },
        "percentile_rank": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentile rank in historical distribution"
        }
      }
    },
    "sign_flip_check": {
      "type": "object",
      "properties": {
        "triggered": {
          "type": "boolean",
          "description": "Whether sign flip was detected"
        },
        "prior_sign": {
          "type": "string",
          "enum": ["positive", "negative", "zero"],
          "description": "Sign of prior balance"
        },
        "current_sign": {
          "type": "string",
          "enum": ["positive", "negative", "zero"],
          "description": "Sign of current balance"
        },
        "above_threshold": {
          "type": "boolean",
          "description": "Whether absolute value exceeds threshold"
        }
      }
    },
    "new_account_check": {
      "type": "object",
      "properties": {
        "triggered": {
          "type": "boolean",
          "description": "Whether account is new"
        },
        "first_appearance_period": {
          "type": "string",
          "description": "Period when account first appeared"
        },
        "in_prior_master": {
          "type": "boolean",
          "description": "Whether account existed in prior period master"
        }
      }
    },
    "stale_balance_check": {
      "type": "object",
      "properties": {
        "triggered": {
          "type": "boolean",
          "description": "Whether balance is stale"
        },
        "zero_variance_periods": {
          "type": "integer",
          "description": "Number of consecutive periods with zero variance"
        },
        "threshold_periods": {
          "type": "integer",
          "default": 3,
          "description": "Threshold for stale detection (default: 3)"
        },
        "had_prior_activity": {
          "type": "boolean",
          "description": "Whether account had activity before stale period"
        }
      }
    },
    "normality_test": {
      "type": "object",
      "description": "Shapiro-Wilk normality test (caveat from spec)",
      "properties": {
        "test_performed": {
          "type": "boolean",
          "description": "Whether normality test was performed"
        },
        "statistic": {
          "type": "number",
          "description": "Shapiro-Wilk W statistic"
        },
        "p_value": {
          "type": "number",
          "description": "P-value of test"
        },
        "is_normal": {
          "type": "boolean",
          "description": "Whether distribution is approximately normal (p > 0.05)"
        },
        "recommended_method": {
          "type": "string",
          "enum": ["parametric_zscore", "mad_zscore", "percentile"],
          "description": "Recommended detection method based on normality"
        },
        "sample_size": {
          "type": "integer",
          "description": "Number of historical periods used"
        }
      }
    },
    "materiality_assessment": {
      "type": "object",
      "description": "DP-001 materiality check",
      "properties": {
        "is_material": {
          "type": "boolean",
          "description": "Whether variance exceeds materiality threshold"
        },
        "materiality_limit": {
          "type": "number",
          "description": "Materiality threshold applied"
        },
        "threshold_source": {
          "type": "string",
          "enum": ["manual", "fitted", "hybrid"],
          "description": "Source of threshold (manual vs ML-fitted)"
        },
        "threshold_version": {
          "type": "string",
          "description": "Version of threshold parameters"
        },
        "category_specific": {
          "type": "boolean",
          "description": "Whether threshold is account-category-specific"
        }
      }
    }
  }
}