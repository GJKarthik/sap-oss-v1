{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit-trail-entry.schema.json",
  "title": "Audit Trail Entry",
  "description": "Schema for audit trail entries supporting EUC retirement evidence standard and dashboard authoritative records",
  "type": "object",
  "required": ["audit_id", "timestamp", "persona_id", "action", "evidence_hash"],
  "properties": {
    "audit_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this audit entry"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the action"
    },
    "persona_id": {
      "type": "string",
      "description": "Employee ID from SAP IAS token (sub claim)",
      "pattern": "^[0-9]{7}$"
    },
    "action": {
      "type": "string",
      "enum": [
        "view",
        "claim",
        "decide",
        "escalate",
        "override",
        "bulk_assign",
        "bulk_priority_change",
        "bulk_requeue",
        "comment_edit",
        "comment_approve",
        "comment_reject",
        "export",
        "import",
        "divergence_detected",
        "threshold_change",
        "entity_params_update"
      ],
      "description": "Type of action performed"
    },
    "resource_type": {
      "type": "string",
      "enum": [
        "variance_record",
        "commentary",
        "workflow_state",
        "entity_params",
        "materiality_threshold",
        "user_assignment"
      ],
      "description": "Type of resource affected"
    },
    "resource_id": {
      "type": "string",
      "description": "ID of the affected resource"
    },
    "legal_entity": {
      "type": "string",
      "description": "Legal entity code (e.g., HKG, SGP)",
      "pattern": "^[A-Z]{3}$"
    },
    "period": {
      "type": "string",
      "description": "Accounting period in YYYY-MM format",
      "pattern": "^[0-9]{4}-[0-9]{2}$"
    },
    "before_state": {
      "type": ["object", "null"],
      "description": "Snapshot of resource state before action (null for create operations)"
    },
    "after_state": {
      "type": "object",
      "description": "Snapshot of resource state after action"
    },
    "change_summary": {
      "type": "object",
      "description": "Summary of changes for quick review",
      "properties": {
        "fields_changed": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of field names that changed"
        },
        "decision": {
          "type": "string",
          "enum": ["accept", "reject", "escalate", "defer"],
          "description": "Decision made (for decision actions)"
        },
        "previous_assignee": {
          "type": ["string", "null"],
          "description": "Previous assignee persona_id (for reassignment)"
        },
        "new_assignee": {
          "type": ["string", "null"],
          "description": "New assignee persona_id (for reassignment)"
        }
      }
    },
    "evidence_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of (timestamp + persona_id + action + resource_id + JSON.stringify(after_state))"
    },
    "bulk_operation_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Groups entries from same bulk operation (null for single operations)"
    },
    "bulk_operation_context": {
      "type": ["object", "null"],
      "description": "Context for bulk operations",
      "properties": {
        "total_items": {
          "type": "integer",
          "description": "Total items in bulk operation"
        },
        "success_count": {
          "type": "integer",
          "description": "Number of successful items"
        },
        "failure_count": {
          "type": "integer",
          "description": "Number of failed items"
        },
        "operation_type": {
          "type": "string",
          "enum": ["bulk_assign", "bulk_priority_change", "bulk_requeue"]
        }
      }
    },
    "ip_address": {
      "type": "string",
      "oneOf": [
        {"format": "ipv4"},
        {"format": "ipv6"}
      ],
      "description": "Client IP address"
    },
    "user_agent": {
      "type": "string",
      "description": "Browser/client user agent string"
    },
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "Session identifier for grouping related actions"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid",
      "description": "Correlation ID for tracing across services"
    },
    "source_system": {
      "type": "string",
      "enum": ["dashboard", "api", "batch", "import"],
      "description": "System that originated the action"
    },
    "euc_comparison": {
      "type": ["object", "null"],
      "description": "EUC vs Dashboard comparison data (for divergence_detected actions)",
      "properties": {
        "euc_value": {
          "description": "Value from Excel EUC"
        },
        "dashboard_value": {
          "description": "Value from Dashboard (authoritative)"
        },
        "divergence_amount": {
          "type": "number",
          "description": "Absolute difference between values"
        },
        "divergence_type": {
          "type": "string",
          "enum": ["value_mismatch", "euc_only", "dashboard_only"],
          "description": "Type of divergence detected"
        },
        "resolution_status": {
          "type": "string",
          "enum": ["pending_review", "resolved_dashboard_correct", "resolved_euc_correct", "acknowledged"],
          "description": "Resolution status (dashboard is authoritative)"
        },
        "resolution_date": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When divergence was resolved"
        },
        "resolution_notes": {
          "type": ["string", "null"],
          "description": "Notes from Controls Owner on resolution"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidence_hash_algorithm": {
      "description": "Evidence hash is computed as: sha256(timestamp + '|' + persona_id + '|' + action + '|' + resource_id + '|' + JSON.stringify(after_state, null, 0))"
    }
  }
}