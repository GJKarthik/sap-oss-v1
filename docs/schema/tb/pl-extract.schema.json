{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sap-oss.github.io/schema/tb/pl-extract.schema.json",
  "title": "P&L Extract",
  "description": "Schema for Profit & Loss extract records from PSGL/SC Bridge",
  "type": "object",
  "required": ["extract_id", "legal_entity", "period", "line_items", "totals"],
  "additionalProperties": false,
  "properties": {
    "extract_id": {
      "type": "string",
      "description": "Unique identifier for this P&L extract"
    },
    "legal_entity": {
      "type": "string",
      "description": "Legal entity code (e.g., HKG for Hong Kong)"
    },
    "legal_entity_name": {
      "type": "string",
      "description": "Legal entity full name"
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$",
      "description": "Accounting period (YYYY-MM format)"
    },
    "period_type": {
      "type": "string",
      "enum": ["monthly", "quarterly", "ytd", "annual"],
      "description": "Type of period covered"
    },
    "fiscal_year": {
      "type": "string",
      "pattern": "^[0-9]{4}$",
      "description": "Fiscal year"
    },
    "currency": {
      "type": "string",
      "description": "Reporting currency"
    },
    "source_system": {
      "type": "string",
      "enum": ["PSGL", "SC_BRIDGE", "S4HANA"],
      "description": "Source ERP system"
    },
    "line_items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/pl_line_item"
      },
      "description": "P&L line items"
    },
    "totals": {
      "$ref": "#/definitions/pl_totals",
      "description": "P&L summary totals"
    },
    "comparative_data": {
      "$ref": "#/definitions/comparative_data",
      "description": "Prior period and budget comparisons"
    },
    "extraction_metadata": {
      "$ref": "#/definitions/extraction_metadata",
      "description": "Extraction process metadata"
    },
    "metadata": {
      "$ref": "https://sap-oss.github.io/schema/common/base-types.schema.json#/definitions/Metadata",
      "description": "Record metadata"
    }
  },
  "definitions": {
    "pl_line_item": {
      "type": "object",
      "required": ["account_code", "description", "actual_amount"],
      "additionalProperties": false,
      "properties": {
        "account_code": {
          "type": "string",
          "description": "GL account code"
        },
        "description": {
          "type": "string",
          "description": "Line item description"
        },
        "category": {
          "type": "string",
          "enum": ["REVENUE", "COST_OF_SALES", "GROSS_PROFIT", "OPERATING_EXPENSE", "OPERATING_INCOME", "OTHER_INCOME", "OTHER_EXPENSE", "TAX", "NET_INCOME"],
          "description": "P&L category"
        },
        "sub_category": {
          "type": "string",
          "description": "Sub-category for detailed grouping"
        },
        "finance_caption": {
          "type": "string",
          "description": "Financial statement caption"
        },
        "segment": {
          "type": "string",
          "description": "Business segment"
        },
        "department": {
          "type": "string",
          "description": "Department code"
        },
        "actual_amount": {
          "type": "number",
          "description": "Actual amount for the period"
        },
        "budget_amount": {
          "type": "number",
          "description": "Budget amount for the period"
        },
        "prior_period_amount": {
          "type": "number",
          "description": "Amount from prior period (MoM)"
        },
        "prior_year_amount": {
          "type": "number",
          "description": "Amount from same period prior year (YoY)"
        },
        "ytd_actual": {
          "type": "number",
          "description": "Year-to-date actual"
        },
        "ytd_budget": {
          "type": "number",
          "description": "Year-to-date budget"
        },
        "variance_to_budget": {
          "type": "number",
          "description": "Variance vs budget (actual - budget)"
        },
        "variance_to_budget_percent": {
          "type": "number",
          "description": "Variance vs budget as percentage"
        },
        "variance_to_prior_period": {
          "type": "number",
          "description": "Month-over-month variance"
        },
        "variance_to_prior_year": {
          "type": "number",
          "description": "Year-over-year variance"
        },
        "is_subtotal": {
          "type": "boolean",
          "default": false,
          "description": "Whether this is a subtotal line"
        },
        "display_order": {
          "type": "integer",
          "description": "Order for display in reports"
        }
      }
    },
    "pl_totals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_revenue": {
          "type": "number",
          "description": "Total revenue"
        },
        "cost_of_sales": {
          "type": "number",
          "description": "Total cost of sales"
        },
        "gross_profit": {
          "type": "number",
          "description": "Gross profit (revenue - COGS)"
        },
        "gross_margin_percent": {
          "type": "number",
          "description": "Gross margin percentage"
        },
        "operating_expenses": {
          "type": "number",
          "description": "Total operating expenses"
        },
        "operating_income": {
          "type": "number",
          "description": "Operating income (EBIT)"
        },
        "other_income_expense_net": {
          "type": "number",
          "description": "Net other income/expense"
        },
        "income_before_tax": {
          "type": "number",
          "description": "Income before tax"
        },
        "tax_expense": {
          "type": "number",
          "description": "Tax expense"
        },
        "net_income": {
          "type": "number",
          "description": "Net income"
        },
        "net_margin_percent": {
          "type": "number",
          "description": "Net margin percentage"
        }
      }
    },
    "comparative_data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prior_period": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$",
          "description": "Prior period compared (YYYY-MM)"
        },
        "prior_year_period": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$",
          "description": "Same period prior year (YYYY-MM)"
        },
        "budget_version": {
          "type": "string",
          "description": "Budget version used for comparison"
        },
        "exchange_rate_used": {
          "type": "number",
          "description": "Exchange rate used for conversions"
        }
      }
    },
    "extraction_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extracted_at": {
          "type": "string",
          "format": "date-time",
          "description": "Extraction timestamp"
        },
        "source_file": {
          "type": "string",
          "description": "Source file path (e.g., HKG_PL review Nov'25.xlsm)"
        },
        "source_sheet": {
          "type": "string",
          "description": "Source worksheet name"
        },
        "row_count": {
          "type": "integer",
          "description": "Number of rows extracted"
        },
        "validation_status": {
          "type": "string",
          "enum": ["valid", "warnings", "errors"],
          "description": "Extraction validation status"
        }
      }
    }
  }
}