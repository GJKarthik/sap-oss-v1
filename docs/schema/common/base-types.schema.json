{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sap-oss.github.io/schema/common/base-types.schema.json",
  "title": "SAP OSS Common Base Types",
  "description": "Shared type definitions used across all domain schemas",
  "version": "1.1.0",
  
  "definitions": {
    "Metadata": {
      "type": "object",
      "description": "Standard metadata block for all records",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UUID or domain-specific ID)",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when record was created"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last update"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "SemVer version of the record schema"
        },
        "source": {
          "type": "string",
          "description": "Origin system or file path"
        },
        "traceability": {
          "$ref": "#/definitions/RoadmapTraceability",
          "description": "MoSCoW and milestone traceability (added v1.1.0)"
        }
      },
      "required": ["id"],
      "additionalProperties": false
    },
    
    "RoadmapTraceability": {
      "type": "object",
      "description": "MoSCoW priority and milestone traceability for requirements alignment. Added to address review gap: 'Zero MoSCoW traceability'",
      "properties": {
        "milestone_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^M0[1-9]$",
            "description": "Milestone ID (M01-M09)"
          },
          "description": "Associated milestone IDs from roadmap (see common/moscow.yaml)"
        },
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(ARA|TB|SIM|REG)-[A-Z]{2,4}-\\d+\\.\\d+(\\.\\d+)?-\\d{3}$"
          },
          "description": "Linked requirement IDs (e.g., REG-MGF-2.1.2-002)"
        },
        "moscow_priority": {
          "type": "string",
          "enum": ["Must", "Should", "Could", "Won't"],
          "description": "MoSCoW priority classification"
        },
        "roadmap_version": {
          "type": "string",
          "pattern": "^\\d{4}-Q[1-4]$",
          "description": "Roadmap version this traces to (e.g., 2026-Q2)"
        },
        "domain": {
          "type": "string",
          "enum": ["arabic", "tb", "simula", "regulations"],
          "description": "Domain this traceability belongs to"
        }
      },
      "additionalProperties": false
    },
    
    "Currency": {
      "type": "object",
      "description": "Monetary amount with currency code",
      "properties": {
        "amount": {
          "type": "number",
          "description": "Numeric value (positive or negative)"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code (e.g., USD, SAR, BHD)"
        }
      },
      "required": ["amount", "currency"],
      "additionalProperties": false
    },
    
    "DateRange": {
      "type": "object",
      "description": "Period with start and optional end date",
      "properties": {
        "start": {
          "type": "string",
          "format": "date",
          "description": "Start date (YYYY-MM-DD)"
        },
        "end": {
          "type": "string",
          "format": "date",
          "description": "End date (YYYY-MM-DD), null if ongoing"
        }
      },
      "required": ["start"],
      "additionalProperties": false
    },
    
    "TaxIdentifier": {
      "type": "object",
      "description": "Tax registration number with jurisdiction",
      "properties": {
        "number": {
          "type": "string",
          "description": "Tax ID number"
        },
        "type": {
          "type": "string",
          "enum": ["TIN", "TRN", "VAT", "GST", "OTHER"],
          "description": "Tax ID type"
        },
        "country": {
          "$ref": "#/definitions/CountryCode"
        }
      },
      "required": ["number", "country"],
      "additionalProperties": false
    },
    
    "CountryCode": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code"
    },
    
    "LanguageCode": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "description": "ISO 639-1 language code, optionally with region (e.g., ar, ar-SA, en-US)"
    },
    
    "EntityParty": {
      "type": "object",
      "description": "Business entity (buyer, seller, counterparty)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Legal entity name"
        },
        "tax_id": {
          "$ref": "#/definitions/TaxIdentifier"
        },
        "address": {
          "type": "string",
          "description": "Full postal address"
        },
        "country": {
          "$ref": "#/definitions/CountryCode"
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    
    "Status": {
      "type": "string",
      "enum": [
        "draft",
        "pending",
        "in_review",
        "approved",
        "rejected",
        "completed",
        "archived"
      ],
      "description": "Workflow status"
    },
    
    "Confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score between 0 and 1"
    },
    
    "FilePath": {
      "type": "string",
      "description": "Relative path from repository root",
      "pattern": "^[^/].*$"
    },
    
    "SHA256Hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash (lowercase hex)"
    },
    
    "WorkedExampleManifest": {
      "type": "object",
      "description": "Reproducibility manifest for worked examples (addresses Simula M06 gap)",
      "properties": {
        "commit_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$",
          "description": "Git commit hash (short or full)"
        },
        "git_tag": {
          "type": "string",
          "description": "Git tag for the release"
        },
        "seed": {
          "type": "integer",
          "description": "Random seed for reproducibility"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Generation timestamp"
        },
        "model_version": {
          "type": "string",
          "description": "Model version used for generation"
        },
        "expected_outputs": {
          "type": "object",
          "description": "Expected output metrics for validation",
          "properties": {
            "example_count": {
              "type": "integer",
              "description": "Expected number of examples"
            },
            "acceptance_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Expected acceptance rate"
            },
            "coverage_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Expected taxonomy coverage"
            },
            "diversity_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Expected diversity score"
            }
          },
          "additionalProperties": false
        },
        "variance_tolerance": {
          "type": "object",
          "description": "Acceptable variance from expected outputs",
          "properties": {
            "count_percent": {
              "type": "number",
              "default": 5,
              "description": "Acceptable count variance (±%)"
            },
            "metric_absolute": {
              "type": "number",
              "default": 0.02,
              "description": "Acceptable metric variance (±)"
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["commit_hash", "seed"],
      "additionalProperties": false
    }
  }
}