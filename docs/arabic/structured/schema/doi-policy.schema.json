{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sap-oss/docs/arabic/structured/schema/doi-policy.schema.json",
  "title": "DOI Policy",
  "description": "Departmental Operating Instruction — canonical representation of the Bahrain Accounts Payable DOI as structured data.",
  "type": "object",
  "required": ["id", "metadata", "activities", "controls", "source_document"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "schema_ref": { "type": "string", "const": "doi-policy.schema.json" },
    "metadata": {
      "type": "object",
      "required": ["country", "division", "effective_from"],
      "additionalProperties": false,
      "properties": {
        "country": { "type": "string", "enum": ["EG", "SA", "QA", "BH", "IQ", "AE", "PK"] },
        "division": { "type": "string" },
        "ownership": { "type": "string" },
        "effective_from": { "type": "string", "format": "date" },
        "review_cadence": { "type": "string" },
        "impacted_business_units": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "processes": { "type": "array", "items": { "type": "string" } },
        "products": { "type": "array", "items": { "type": "string" } }
      }
    },
    "activities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["n", "name", "description"],
        "additionalProperties": false,
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "systems": { "type": "array", "items": { "type": "string" } },
          "approvals_required": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "vat_invoice_types": {
      "type": "array",
      "description": "NBR-recognized VAT invoice types listed in Activity 3 of the DOI.",
      "items": { "type": "string" }
    },
    "suspense_accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["currency", "account"],
        "additionalProperties": false,
        "properties": {
          "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
          "account": { "type": "string" },
          "business_unit": { "type": "string" }
        }
      }
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "activity_ref": { "type": "integer" },
          "risk_addressed": { "type": "string" }
        }
      }
    },
    "source_document": { "$ref": "invoice.schema.json#/definitions/source_document" }
  }
}
