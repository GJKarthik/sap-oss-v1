{
  "name": "@sap-ai-sdk/vllm",
  "version": "0.1.0",
  "description": "vLLM integration for SAP Cloud SDK for AI - self-hosted LLM inference",
  "license": "Apache-2.0",
  "author": "SAP",
  "keywords": [
    "sap",
    "ai",
    "vllm",
    "llm",
    "inference",
    "openai",
    "self-hosted"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@sap-ai-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5"
  },
  "peerDependencies": {
    "@sap-ai-sdk/core": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SAP/ai-sdk-js.git",
    "directory": "packages/vllm"
  },
  "bugs": {
    "url": "https://github.com/SAP/ai-sdk-js/issues"
  },
  "homepage": "https://github.com/SAP/ai-sdk-js/tree/main/packages/vllm#readme"
}