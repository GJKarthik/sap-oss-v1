{
  "name": "@sap-ai-sdk-samples/elasticsearch-cloud",
  "version": "1.0.0",
  "private": true,
  "description": "Elastic Cloud deployment sample for SAP AI SDK",
  "type": "module",
  "scripts": {
    "setup": "npx tsx src/setup-index.ts",
    "ingest": "npx tsx src/ingest-data.ts",
    "query": "npx tsx src/query-cloud.ts",
    "rag": "npx tsx src/rag-pipeline.ts",
    "demo": "npm run setup && npm run ingest && npm run query",
    "test:connection": "npx tsx src/test-connection.ts",
    "create:api-key": "npx tsx src/create-api-key.ts",
    "verify:config": "npx tsx src/verify-config.ts"
  },
  "dependencies": {
    "@sap-ai-sdk/elasticsearch": "workspace:*",
    "@elastic/elasticsearch": "^8.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  }
}