.{
    .name = .mcp_mesh_gateway,
    .version = "1.0.0",
    // Fingerprint provides reproducible builds
    // Regenerate with: zig build --fetch
    .fingerprint = 0x234953c0f8f3d9fa,
    .minimum_zig_version = "0.14.0",
    
    // Dependencies with pinned versions
    // Internal dependencies use path-based references for monorepo
    .dependencies = .{
        // Shared fabric provides: blackboard, trace, router, http_server, openai_models
        .bdc_intelligence_fabric = .{
            .path = "../../../bdc-intelligence-fabric/zig",
        },
    },
    
    // Files included in package
    .paths = .{ 
        "build.zig", 
        "build.zig.zon", 
        "src",
    },
}