# ============================================================================
# SAP AI Fabric - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env
# ============================================================================

# ============================================================================
# SAP AI CORE CONFIGURATION (Required for all services)
# ============================================================================
# OAuth credentials from SAP AI Core service binding
AICORE_CLIENT_ID=your-client-id
AICORE_CLIENT_SECRET=your-client-secret
AICORE_AUTH_URL=https://your-subaccount.authentication.eu10.hana.ondemand.com/oauth/token
AICORE_BASE_URL=https://api.ai.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=default

# ============================================================================
# SAP HANA CLOUD CONFIGURATION
# ============================================================================
# HANA Cloud connection details
HANA_HOST=your-hana-instance.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=your-hana-user
HANA_PASSWORD=your-hana-password
HANA_SCHEMA=PAL_STORE
HANA_ENCRYPT=true

# Connection URL format (alternative to individual settings)
HANA_URL=hana://${HANA_USER}:${HANA_PASSWORD}@${HANA_HOST}:${HANA_PORT}/?encrypt=true&sslValidateCertificate=false

# ============================================================================
# ELASTICSEARCH CONFIGURATION
# ============================================================================
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=
ES_SCHEME=http

# Elasticsearch cluster settings
ES_CLUSTER_NAME=sap-ai-fabric
ES_NODE_NAME=es-node-1
ES_DISCOVERY_TYPE=single-node
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ============================================================================
# TIER 0: INFRASTRUCTURE SERVICES
# ============================================================================
# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ============================================================================
# TIER 1: MCP SERVERS
# ============================================================================

# OData Vocabularies MCP Server
ODATA_MCP_PORT=9150
ODATA_MCP_HOST=0.0.0.0

# Elasticsearch MCP Server
ES_MCP_PORT=9120
ES_MCP_HOST=0.0.0.0
ES_MCP_INDEX_PREFIX=sap-ai-

# LangChain HANA MCP Server
LANGCHAIN_HANA_MCP_PORT=9160
LANGCHAIN_HANA_MCP_HOST=0.0.0.0
LANGCHAIN_HANA_EMBEDDING_MODEL=text-embedding-ada-002
LANGCHAIN_HANA_VECTOR_TABLE=EMBEDDINGS

# ============================================================================
# TIER 2: INTELLIGENCE LAYER
# ============================================================================

# vLLM Inference Server
VLLM_PORT=8080
VLLM_HOST=0.0.0.0
VLLM_MODEL_PATH=/app/models
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-GGUF
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=32768
CUDA_VISIBLE_DEVICES=0

# AI-Core-PAL (Mesh Gateway)
AICORE_PAL_PORT=9881
AICORE_PAL_HOST=0.0.0.0
PRIVATE_LLM_URL=http://vllm:8080
MCP_PORT=9881

# Gen AI Toolkit
GENAI_TOOLKIT_PORT=8084
GENAI_TOOLKIT_HOST=0.0.0.0
GENAI_HUB_API_KEY=
GENAI_HUB_BASE_URL=

# ============================================================================
# TIER 3: TRAINING SERVICES
# ============================================================================

# ModelOpt API
MODELOPT_API_PORT=8001
MODELOPT_API_HOST=0.0.0.0
MODELOPT_OUTPUT_DIR=/app/outputs
MODELOPT_CACHE_DIR=/app/cache

# ModelOpt UI
MODELOPT_UI_PORT=8082
MODELOPT_UI_HOST=0.0.0.0
MODELOPT_API_URL=http://modelopt-api:8001

# ============================================================================
# APPLICATION SERVICES (Legacy ports from main docker-compose)
# ============================================================================

# World Monitor
WORLD_MONITOR_PORT=3000

# Data Copilot
DATA_COPILOT_PORT=8002

# CAP LLM Plugin
CAP_LLM_PLUGIN_PORT=4004

# Agent Router (Mangle)
AGENT_ROUTER_PORT=8010

# OData Schema Service
ODATA_SCHEMA_PORT=8003

# MCP-PAL
MCP_PAL_PORT=8020

# AI Shared Fabric
AI_SHARED_FABRIC_PORT=8030

# AI Prompt Agent
AI_PROMPT_AGENT_PORT=8040

# Embedded HANA
EMBEDDED_HANA_PORT=8050

# ============================================================================
# DOCKER REGISTRY CONFIGURATION (for AI Core deployment)
# ============================================================================
DOCKER_REGISTRY=ghcr.io/your-org
DOCKER_REGISTRY_USERNAME=
DOCKER_REGISTRY_PASSWORD=
IMAGE_TAG=latest

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# SECURITY
# ============================================================================
# XSUAA Configuration (for BTP authentication)
XSUAA_URL=
XSUAA_CLIENT_ID=
XSUAA_CLIENT_SECRET=

# API Keys (if required)
API_KEY=

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================
NETWORK_NAME=sap-ai-fabric-network
NETWORK_DRIVER=bridge

# ============================================================================
# VOLUME PATHS (Local development)
# ============================================================================
MODEL_CACHE_PATH=./volumes/model-cache
ES_DATA_PATH=./volumes/es-data
REDIS_DATA_PATH=./volumes/redis-data
MODELOPT_OUTPUT_PATH=./volumes/modelopt-outputs